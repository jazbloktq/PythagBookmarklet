    // ── Surd helpers ──────────────────────────────────────────────────────────
    // Simplify sqrt(n) into a*sqrt(b) where b is square-free
    function simplifySqrt(n) {
        // n must be a positive integer
        var coeff = 1, rad = n;
        for (var p = 2; p * p <= rad; p++) {
            while (rad % (p*p) === 0) { rad /= p*p; coeff *= p; }
        }
        return { coeff: coeff, rad: rad };
    }
    // Try to express `value` as a surd. Returns string or null.
    // If simplify is off, returns √N (raw). If on, returns simplified a√b.
    function toSurdStr(value) {
        var sq = value * value;
        var sqR = Math.round(sq);
        if (Math.abs(sq - sqR) > 1e-7 || sqR <= 0) return null;
        var s = simplifySqrt(sqR);
        if (s.rad === 1) return null; // perfect square, just show integer
        if (!getSimplify()) return '\u221a' + sqR; // unsimplified: √3300
        return (s.coeff === 1 ? '' : s.coeff) + '\u221a' + s.rad; // simplified: 10√33
    }
    // Format a computed value for display (main result + step strings)
    // In surd mode, show simplified surd; for steps show sqrt(original radicand)
    function fmt(value) {
        if (getSurd()) {
            var ss = toSurdStr(value);
            if (ss) return ss;
            var sqR = Math.round(value * value);
            if (Math.abs(value * value - sqR) < 1e-7 && Math.abs(value - Math.round(value)) < 1e-9) return String(Math.round(value));
        }
        return value.toFixed(getPrec());
    }
    // For step strings: in surd mode show sqrt(n) keeping the radicand explicit before simplification
    function fmtS(value) {
        if (getSurd()) {
            var sq = value * value, sqR = Math.round(sq);
            if (Math.abs(sq - sqR) < 1e-7 && sqR > 0) {
                var s = simplifySqrt(sqR);
                if (s.rad !== 1) {
                    if (!getSimplify()) return '\u221a' + sqR; // unsimplified: √3300
                    return (s.coeff===1?'':s.coeff)+'\u221a'+s.rad; // simplified: 10√33
                }
                if (Math.abs(value - Math.round(value)) < 1e-9) return String(Math.round(value));
            }
        }
        return value.toFixed(getPrec());
    }

