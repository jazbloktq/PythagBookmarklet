            tog.style.display='block';
        } else { tog.style.display='none'; }
        // Only reset result panel if there's nothing currently shown — don't wipe a live result
        if(!lastCalcResult && !_manualCalcPending) { get('res').style.display='none'; var _ub=get('unitBox');if(_ub)_ub.style.display='none'; ctx.clearRect(0,0,canvas.width,canvas.height); }
        // If autoCalc is on and there are filled inputs, trigger redraw for the new method
        clearTimeout(autoCalcTimer);
        var _hasVals = false;
        cfg.inputs.forEach(function(_,i){ var el=get('v'+i); if(el && el.value.trim()) _hasVals=true; });
        if(_hasVals && getAutoCalc()) {
            autoCalcTimer = setTimeout(function(){ doCalculate(true); }, 50);
        }
