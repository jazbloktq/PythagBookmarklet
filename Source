        angArr.forEach(function(ang,i){
            var sp=document.createElement('span');
            sp.style.cssText='font-weight:600;color:'+(d2?'#4a9eff':'#1a73e8')+';';
            sp.innerText=names[i]+' = '+fmtAngle(ang);
            anglesContent.appendChild(sp);
        });
        anglesBox.style.display='block';

        var drawS1=s1, drawH=h, drawB=b, drawS2=s2;
        if(currentTri==='right') drawH=s1;
        drawTri(drawS1, drawH, drawB, drawS2, isExt, anglesForCanvas);

