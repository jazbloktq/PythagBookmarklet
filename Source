                if(!isNaN(b)&&!isNaN(angA)&&angA>0&&angA<90&&isNaN(a)) a=b*Math.tan(angA*Math.PI/180);
                if(!isNaN(b)&&!isNaN(angA)&&angA>0&&angA<90&&isNaN(c)) c=b/Math.cos(angA*Math.PI/180);
                if(!isNaN(c)&&!isNaN(angA)&&angA>0&&angA<90&&isNaN(a)) a=c*Math.sin(angA*Math.PI/180);
