    function ck_newId() { return ++ck_autoCloseCounter; }

    function ck_buildStrings() {
        var e = '', d = '';
        for(var i = 0; i < ck_tokens.length; i++) {
            e += ck_tokens[i].e;
            d += ck_tokens[i].d;
        }
        return { e: e, d: d };
    }

    function ck_escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function ck_renderDisplay() {
        var s = ck_buildStrings();
        var mainText = s.d || '0';
        if(ck_inferBrackets) {
            var pending = ck_pendingAutoCloses();
            var suffix = '';
            for(var i = 0; i < pending.length; i++) suffix += ')';
            var dimCol = getDark() ? 'rgba(200,220,255,0.30)' : 'rgba(26,115,232,0.22)';
            if(suffix) {
                ckDisplay.innerHTML =
                    '<span>' + ck_escHtml(mainText) + '</span>' +
                    '<span style="color:' + dimCol + ';font-style:italic;font-weight:400;">' + suffix + '</span>';
                return;
            }
        }
        ckDisplay.innerHTML = '<span>' + ck_escHtml(mainText) + '</span>';
    }

    function ck_pendingAutoCloses() {
        var opens = [];
        for(var i = 0; i < ck_tokens.length; i++) {
            var t = ck_tokens[i];
            if(t.kind === 'sqrt-open' && !t.closingDeleted) {
                var hasClosed = false;
                for(var j = i+1; j < ck_tokens.length; j++) {
                    if(ck_tokens[j].isAutoClose && ck_tokens[j].autoCloseId === t.autoCloseId) {
                        hasClosed = true; break;
                    }
                }
                if(!hasClosed) opens.push({idx: i, id: t.autoCloseId});
            }
        }
        return opens;
    }

    function ck_openDepth() {
        var depth = 0;
        for(var i = 0; i < ck_tokens.length; i++) {
            var k = ck_tokens[i].kind;
            if(k === 'open' || k === 'sqrt-open') depth++;
            else if(k === 'close') depth--;
        }
        return depth;
    }

    function ck_lastKind() {
        if(!ck_tokens.length) return null;
        return ck_tokens[ck_tokens.length-1].kind;
    }

    function ck_lastIsOp() {
        var lk = ck_lastKind();
        return lk === 'op' || lk === 'sqrt-open' || lk === 'open';
    }
    function ck_lastIsNum() {
        var lk = ck_lastKind();
        return lk === 'num' || lk === 'close' || lk === 'pi';
    }

