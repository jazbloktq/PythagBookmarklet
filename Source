            var diffAB=Math.sqrt(inner2);
            s1=(sumAB+diffAB)/2; b=(sumAB-diffAB)/2; s2=hypH;
            formula='Altitude = (2A) / c = (2 \u00d7 '+v0+') / '+hypH+' = '+fmtS(res);
        }else if(type==='rt_b_cl'){
