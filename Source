    }

    function ck_insertPendingCloses() {
        if(!ck_inferBrackets) return;
        var pending = ck_pendingAutoCloses();
        for(var i = pending.length - 1; i >= 0; i--) {
            ck_tokens.push({
                e: ')', d: ')', kind: 'close',
                isAutoClose: true, autoCloseId: pending[i].id
