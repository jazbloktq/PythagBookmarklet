    var diagVertices = null;
    var diagDragIdx  = -1;
    var diagScale    = 1;
    var diagOffX     = 0, diagOffY = 0;
    var diagLastParams = null;

    function drawTri(s1, h, b, s2, isExt, anglesData, highlightGoal) {
        var W=canvas.width, H=canvas.height;
        ctx.clearRect(0,0,W,H);
        var d=getDark();
        var triCol=d?'#4a9eff':'#1a73e8';
        var hlCol ='#e87c00';
        var raw;
        if(currentTri==='equilateral'||currentTri==='isosceles') raw=[[0,h],[b/2,0],[b,h]];
        else if(currentTri==='right') raw=[[0,h],[0,0],[b,h]];
        else { var ax=Math.sqrt(Math.max(0,s1*s1-h*h)); raw=isExt?[[0,h],[ax,0],[Math.abs(ax-b),h]]:[[0,h],[ax,0],[b,h]]; }

        var padT=38, padB=52, padL=52, padR=52;
        var minX=raw[0][0],maxX=raw[0][0];
        for(var i=1;i<3;i++){if(raw[i][0]<minX)minX=raw[i][0];if(raw[i][0]>maxX)maxX=raw[i][0];}
        var rangeX=maxX-minX||1, rangeY=h||1;
        var scale=Math.min((W-padL-padR)/rangeX,(H-padT-padB)/rangeY);
        var offX=(W-rangeX*scale)/2-minX*scale, offY=padT+(H-padT-padB-rangeY*scale)/2;
        diagScale=scale; diagOffX=offX; diagOffY=offY;
        function tr(pt){return[pt[0]*scale+offX,pt[1]*scale+offY];}
        var pA=tr(raw[0]),pB=tr(raw[1]),pC=tr(raw[2]);
        var pH=[pB[0],pA[1]];

        diagVertices=[{x:pA[0],y:pA[1]},{x:pB[0],y:pB[1]},{x:pC[0],y:pC[1]}];
        diagLastParams={s1:s1,h:h,b:b,s2:s2,isExt:isExt,anglesData:anglesData,goal:highlightGoal};

        var hl = getColorCode() && highlightGoal;
        var hlAB=false,hlBC=false,hlAC=false;
        if(hl){
            if(highlightGoal==='base')  hlAC=true;
            else if(highlightGoal==='side') hlAB=true;
            else if(highlightGoal==='hypo') hlBC=true;
            else if(highlightGoal==='height'||highlightGoal==='area'||highlightGoal==='triple') { hlAB=false;hlBC=false;hlAC=false; }
        }

        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();
        ctx.fillStyle=d?'rgba(74,158,255,0.08)':'rgba(26,115,232,0.07)';ctx.fill();

        function tick(ax,ay,bx,by,n){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len*5,ny=dx/len*5,gap=4;
            ctx.strokeStyle=triCol;ctx.lineWidth=1.5;
            for(var t=0;t<n;t++){var o=(t-(n-1)/2)*gap,ox=dx/len*o,oy=dy/len*o;ctx.beginPath();ctx.moveTo(mx+ox-nx,my+oy-ny);ctx.lineTo(mx+ox+nx,my+oy+ny);ctx.stroke();}
        }
        if(currentTri==='equilateral'){tick(pA[0],pA[1],pB[0],pB[1],2);tick(pB[0],pB[1],pC[0],pC[1],2);tick(pA[0],pA[1],pC[0],pC[1],2);}
        else if(currentTri==='isosceles'){tick(pA[0],pA[1],pB[0],pB[1],1);tick(pB[0],pB[1],pC[0],pC[1],1);}

        function drawSide(x1,y1,x2,y2,highlighted){
            ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);
            ctx.strokeStyle=highlighted?hlCol:triCol;
            ctx.lineWidth=highlighted?3.5:2.5;
            ctx.lineJoin='round';
            ctx.stroke();
        }
        drawSide(pA[0],pA[1],pB[0],pB[1],hlAB);
        drawSide(pB[0],pB[1],pC[0],pC[1],hlBC);
        drawSide(pA[0],pA[1],pC[0],pC[1],hlAC);

        if(currentTri==='right'){var sq=7;ctx.strokeStyle=d?'#888':'#888';ctx.lineWidth=1.2;ctx.strokeRect(pA[0],pA[1]-sq,sq,sq);}

        var altOnLeft=false,altOnRight=false;
        if(currentTri==='scalene'){var eps=0.002*scale;altOnLeft=Math.abs(pB[0]-pA[0])<eps;altOnRight=Math.abs(pB[0]-pC[0])<eps;}
        var drawAlt=(currentTri==='isosceles'||currentTri==='equilateral'||(currentTri==='scalene'&&!altOnLeft&&!altOnRight));
        var sq2=6;
        if(drawAlt&&highlightGoal!=='height'){
            ctx.setLineDash([4,4]);ctx.lineWidth=1.5;ctx.strokeStyle=d?'#555':'#aaa';
            ctx.beginPath();ctx.moveTo(pB[0],pB[1]);ctx.lineTo(pH[0],pH[1]);ctx.stroke();ctx.setLineDash([]);
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;
            ctx.strokeRect(pH[0], pH[1]-sq2, sq2, sq2);
        } else if(drawAlt&&highlightGoal==='height'){
            ctx.setLineDash([4,4]);ctx.lineWidth=2.5;ctx.strokeStyle=hlCol;
            ctx.beginPath();ctx.moveTo(pB[0],pB[1]);ctx.lineTo(pH[0],pH[1]);ctx.stroke();ctx.setLineDash([]);
            ctx.strokeStyle=hlCol;ctx.lineWidth=1.5;
            ctx.strokeRect(pH[0], pH[1]-sq2, 6, 6);
        } else if(currentTri==='scalene'&&altOnLeft){
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;ctx.strokeRect(pA[0],pA[1],6,-6);
        } else if(currentTri==='scalene'&&altOnRight){
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;ctx.strokeRect(pC[0]-6,pC[1],6,-6);
        }

        if(anglesData){
            var verts=[[pA,anglesData[0]],[pB,anglesData[1]],[pC,anglesData[2]]];
            var otherVerts=[[pB,pC],[pA,pC],[pA,pB]];
            verts.forEach(function(vinfo,vi){
                var vp=vinfo[0], ang=vinfo[1];
                if(currentTri==='right'&&vi===0&&Math.abs(ang-Math.PI/2)<0.01) return;
                var o1=otherVerts[vi][0], o2=otherVerts[vi][1];
                var d1x=o1[0]-vp[0],d1y=o1[1]-vp[1];
                var d2x=o2[0]-vp[0],d2y=o2[1]-vp[1];
                var a1=Math.atan2(d1y,d1x), a2=Math.atan2(d2y,d2x);
                var r=13;
                ctx.beginPath();
                var diff=a2-a1;
                while(diff> Math.PI) diff-=2*Math.PI;
                while(diff<-Math.PI) diff+=2*Math.PI;
                ctx.arc(vp[0],vp[1],r,a1,a1+diff,diff<0);
                ctx.strokeStyle=hl?hlCol:d?'#4a9eff':'#4a90d0';ctx.lineWidth=1.2;ctx.stroke();

                var midA=a1+diff/2;
                var labelR=r+18;
                var lx=vp[0]+Math.cos(midA)*labelR, ly=vp[1]+Math.sin(midA)*labelR;
                var labelText=fmtAngle(ang);
                ctx.font='bold 9px system-ui';
                var tw=ctx.measureText(labelText).width;
                var ph=12, pw=tw+8;
                lx=Math.max(pw/2+2, Math.min(W-pw/2-2, lx));
                ly=Math.max(ph/2+2, Math.min(H-ph/2-2, ly));
                var bgCol = d ? '#1e1e2e' : '#fff';
                var bdCol = hl?hlCol:(d ? '#4a9eff' : '#4a90d0');
                ctx.beginPath();
                if(ctx.roundRect){ctx.roundRect(lx-pw/2, ly-ph/2, pw, ph, 4);}
                else{ctx.rect(lx-pw/2,ly-ph/2,pw,ph);}
                ctx.fillStyle=bgCol; ctx.fill();
                ctx.strokeStyle=bdCol; ctx.lineWidth=0.8; ctx.stroke();
                ctx.fillStyle=hl?hlCol:(d ? '#4a9eff' : '#1a73e8');
                ctx.textAlign='center'; ctx.textBaseline='middle';
                ctx.fillText(labelText, lx, ly);
            });
        }

        ctx.fillStyle=triCol;ctx.font='bold 11px system-ui';ctx.textAlign='center';ctx.textBaseline='middle';
        var OUT=16, adv2=getAdv(), hLbl=adv2?'alt=':'h=';
        var cx2=(pA[0]+pB[0]+pC[0])/3, cy2=(pA[1]+pB[1]+pC[1])/3;
        diagSideLabelPos=[];
        function labelSide(ax,ay,bx,by,lbl,sideKey){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len,ny=dx/len;
            if((mx+nx-cx2)*nx+(my+ny-cy2)*ny<0){nx=-nx;ny=-ny;}
            var lx2=mx+nx*OUT, ly2=my+ny*OUT;
            lx2=Math.max(8,Math.min(W-8,lx2)); ly2=Math.max(8,Math.min(H-8,ly2));
            var isHL=(hl&&((sideKey==='s1'&&hlAB)||(sideKey==='s2'&&hlBC)||(sideKey==='base'&&hlAC)||(sideKey==='height'&&highlightGoal==='height')));
            ctx.fillStyle=isHL?hlCol:triCol;
            ctx.fillText(lbl,lx2,ly2);
            ctx.fillStyle=triCol;
            if(sideKey) diagSideLabelPos.push({x:lx2,y:ly2,key:sideKey,val:lbl});
        }
        function altLabel(hVal){
            var hmy=(pB[1]+pH[1])/2;
            var margin=8;
            var isHLh=(hl&&highlightGoal==='height');
            ctx.fillStyle=isHLh?hlCol:triCol;
            if(pH[0]+margin+30 < W){ctx.textAlign='left';ctx.fillText(hLbl+hVal,pH[0]+margin,hmy);}
            else{ctx.textAlign='right';ctx.fillText(hLbl+hVal,pH[0]-margin,hmy);}
            ctx.fillStyle=triCol;
            diagSideLabelPos.push({x:pH[0]+(pH[0]+margin+30<W?margin+15:-margin-15),y:hmy,key:'height',val:hVal});
        }
        var s1L=fmt(s1),s2L=fmt(s2),bL=fmt(b),hL=fmt(h);
        if(currentTri==='equilateral'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L,'s1');
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L,'s2');
            labelSide(pA[0],pA[1],pC[0],pC[1],s1L,'base');
            altLabel(hL);
        } else if(currentTri==='isosceles'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L,'s1');
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L,'s2');
            labelSide(pA[0],pA[1],pC[0],pC[1],bL,'base');
            altLabel(hL);
        } else if(currentTri==='right'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L,'s1');
            labelSide(pA[0],pA[1],pC[0],pC[1],bL,'base');
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L,'s2');
        } else {
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L,'s1');
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L,'s2');
            labelSide(pA[0],pA[1],pC[0],pC[1],bL,'base');
            if(!altOnLeft&&!altOnRight) altLabel(hL);
        }

        if(getInteractDiag()&&diagVertices){
            diagVertices.forEach(function(v){
                ctx.beginPath();ctx.arc(v.x,v.y,6,0,2*Math.PI);
                ctx.fillStyle=d?'rgba(74,158,255,0.5)':'rgba(26,115,232,0.35)';
                ctx.fill();
                ctx.strokeStyle=triCol;ctx.lineWidth=1.5;ctx.stroke();
            });
        }
    }

    var diagSideLabelPos = [];

    // ── doShowAngles: display all three angles as the main result ───────────────
    function doShowAngles(angles, formula, s1, h, b, s2, area, perim) {
        var d2=getDark();
        var unitSfx = '';  // angles never have length units
        get('res').style.display='block';
        get('final').style.display='none';
        get('finalApprox').style.display='none';

        // Build the three-angle display inside the result area
        var existingAngleDisp = get('angleResultDisp');
        if(existingAngleDisp) existingAngleDisp.remove();
        var existingAllDisp2 = get('allResultDisp');
        if(existingAllDisp2) existingAllDisp2.remove();
        var disp = document.createElement('div');
        disp.id = 'angleResultDisp';
        disp.style.cssText='display:flex;gap:6px;justify-content:center;margin:4px 0 6px;';
        var names=['A','B','C'];
        var cols=['#e64c2e','#1a73e8','#2e7d32'];
        angles.forEach(function(ang,i){
            var box=document.createElement('div');
            box.style.cssText='flex:1;background:'+(d2?'#1e2a3e':'#f0f6ff')+';border:1.5px solid '+(d2?'#3a4a6e':'#c5d8f8')+';border-radius:8px;padding:8px 4px;text-align:center;';
            box.innerHTML='<div style="font-size:10px;font-weight:700;color:'+cols[i]+';letter-spacing:0.5px;margin-bottom:3px;">'+names[i]+'</div>'
                +'<div style="font-size:16px;font-weight:700;color:'+(d2?'#e0e8ff':'#222')+';">'+fmtAngle(ang)+'</div>';
            disp.appendChild(box);
        });
        var finalEl = get('final');
        finalEl.parentNode.insertBefore(disp, finalEl.nextSibling);

        var classTag=get('classTag');
        classTag.innerText=classifyTriangle(s1,s2,b); classTag.style.display='inline-block';
        get('tripleBox').style.display='none';
        get('formulaText').innerText=formula||'';

        var effOU = currentOutputUnit!=='same'?currentOutputUnit:(workingUnit!=='none'?workingUnit:(currentUnit!=='none'?currentUnit:'none'));
        function toOU(v,isAr){
            if(effOU==='none'||workingUnit==='none') return v;
            if(effOU===workingUnit) return v;
            var fF=unitFactors[workingUnit]||1,tF=unitFactors[effOU]||1;
            return isAr?v*(tF*tF)/(fF*fF):v*tF/fF;
        }
        var uSfx=effOU!=='none'?' '+effOU:'';
        get('areaRes').innerText=toOU(area,true).toFixed(getPrec())+(effOU!=='none'?' '+effOU+'\u00b2':'');
        get('perimRes').innerText=toOU(perim,false).toFixed(getPrec())+uSfx;

        var angFC=[angles[2],angles[1],angles[0]];
        var drawS1=s1,drawH=h,drawB=b,drawS2=s2;
        if(currentTri==='right') drawH=s1;
        get('anglesBox').style.display='none'; // angles shown in custom disp instead

        lastCalcResult={res:angles[0],s1:drawS1,h:drawH,b:drawB,s2:drawS2,area:area,perim:perim,anglesForCanvas:angFC,isExt:false,goal:'angle',workingUnit:workingUnit,resOut:angles[0],effOutUnit:'none'};
        drawTri(drawS1,drawH,drawB,drawS2,false,angFC,'angle');
        applyDark(); applyDiagramVisibility(); applyResultVisibility();
    }

    // ── doShowCircles: display inradius + circumradius prominently ────────────
    function doShowCircles(inR, circumR, formula, s1, h, b, s2, area, perim) {
        var d2=getDark();
        get('res').style.display='block';
        get('final').style.display='none';
        get('finalApprox').style.display='none';

        var effOU = currentOutputUnit!=='same'?currentOutputUnit:(workingUnit!=='none'?workingUnit:(currentUnit!=='none'?currentUnit:'none'));
        function toOU(v,isAr){
            if(effOU==='none'||workingUnit==='none') return v;
            if(effOU===workingUnit) return v;
            var fF=unitFactors[workingUnit]||1,tF=unitFactors[effOU]||1;
            return isAr?v*(tF*tF)/(fF*fF):v*tF/fF;
        }
        var uSfx=effOU!=='none'?' '+effOU:'';
        var inROut=toOU(inR,false), circumROut=toOU(circumR,false);

        var existingCircDisp = get('circleResultDisp');
