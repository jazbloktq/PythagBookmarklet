    function getMethodList() {
        var adv=getAdv(), list=(methods[currentTri]||{})[currentGoal]||[];
        return list.map(function(m){return{id:m.id,text:adv?m.a:m.s,inputs:adv?m.ai:m.si,toggle:m.toggle,angles:m.angles||false};});
    }

    function toRad(v) { return v * Math.PI / 180; }
    function isAngleLbl(lbl) { return lbl.indexOf('\u00b0') >= 0 || lbl.toLowerCase().indexOf('angle') >= 0; }

