        return rad.toFixed(p)+'\u02b3';
    }
    function computeAngles(a, b, c) {
        function ac(opp, adj1, adj2) {
            var val=(adj1*adj1+adj2*adj2-opp*opp)/(2*adj1*adj2);
            val=Math.max(-1,Math.min(1,val));
            return Math.acos(val);
        }
        return [ac(a,b,c), ac(b,a,c), ac(c,a,b)];
    }

    function classifyTriangle(a, b, c) {
        var sides=[a,b,c].sort(function(x,y){return x-y;});
        var A=sides[0],B=sides[1],C=sides[2];
        var eps=1e-6;
        var c2=C*C, ab=A*A+B*B;
        var type;
        if(Math.abs(c2-ab)<eps*C*C) type='Right';
        else if(c2<ab) type='Acute';
        else type='Obtuse';
        return type;
    }

    function gcd(a,b){ a=Math.round(a); b=Math.round(b); while(b){var t=b;b=a%b;a=t;} return a; }
    function checkTripleDetail(a, b, c) {
        var sides=[a,b,c].sort(function(x,y){return x-y;});
        var A=sides[0], B=sides[1], C=sides[2];
        var Ar=Math.round(A), Br=Math.round(B), Cr=Math.round(C);
        var allIntegers=(Math.abs(A-Ar)<0.001 && Math.abs(B-Br)<0.001 && Math.abs(C-Cr)<0.001);
        if(!allIntegers) return {isTriple:false, allIntegers:false, pa:0, pb:0, pc:0, scale:1};
        var g=gcd(gcd(Ar,Br),Cr);
        if(g<1) return {isTriple:false, allIntegers:true, pa:Ar, pb:Br, pc:Cr, scale:1};
        var pa=Ar/g, pb=Br/g, pc=Cr/g;
        if(Math.round(pa*pa+pb*pb) !== Math.round(pc*pc)) return {isTriple:false, allIntegers:true, pa:Ar, pb:Br, pc:Cr, scale:1};
        var isPrimitive=(g===1);
        return {isTriple:true, allIntegers:true, pa:pa, pb:pb, pc:pc, scale:g, isPrimitive:isPrimitive, Ar:Ar, Br:Br, Cr:Cr};
    }
    function checkTriple(a, b, c) {
        var d=checkTripleDetail(a,b,c);
        if(!d.isTriple) return null;
        var label=d.pa+'-'+d.pb+'-'+d.pc;
        if(!d.isPrimitive) label+=' \u00d7'+d.scale;
        return label;
    }

