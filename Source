                '<input type="number" id="'+f.id+'" placeholder="e.g. 5" style="flex:1;padding:8px 10px;border:1.5px solid;border-radius:7px;font-size:14px;box-sizing:border-box;outline:none;">'+
            '</div>';
        }).join('');
        fields.forEach(function(f){
            var inp=document.getElementById(f.id);
            if(inp) inp.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();calc3D();}});
        });
        get('res3D').style.display='none';
        var cb3=get('canvasBox3D'); if(cb3) cb3.style.display='none';
    }

    function saRow3D(label,val) {
        var p=getPrec();
        var vs=(!isNaN(val)&&val!==null)?trimZ(parseFloat(val).toFixed(p)):'—';
        return '<div class="gp-row" style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid;font-size:12px;">'+
            '<span class="gp-row-label">'+label+'</span>'+
            '<span class="gp-row-val">'+vs+'</span></div>';
    }

    // ── 3D Diagram Drawing ─────────────────────────────────────────────────────
    function draw3DShape(shape, dims) {
        var cv = get('canvas3D'), cb3 = get('canvasBox3D');
        if(!cv || !cb3) return;
        if(!getDiagram()) { cb3.style.display='none'; return; }
        cb3.style.display = 'block';

        // Read offsetWidth AFTER display:block so it's non-zero
        var W = cv.offsetWidth || 340;
        var H = cv.offsetHeight || 210;
        cv.width  = W;
        cv.height = H;
        var PAD = 28; // padding so labels don't clip

        var cx = cv.getContext('2d');
        cx.clearRect(0,0,W,H);
        var d = getDark();
        var stroke    = d?'#4a9eff':'#1a73e8';
        var strokeDim = d?'#334466':'#b0c8e8';
        var fill      = d?'rgba(30,50,90,0.75)':'rgba(220,235,255,0.75)';
        var fillSide  = d?'rgba(15,25,55,0.75)':'rgba(190,210,245,0.6)';
        var lblCol    = d?'#a0c0ff':'#1a4080';
        var accentCol = '#e05010';
        var bgCol     = d?'#12192b':'#f8faff';
        cx.fillStyle = bgCol; cx.fillRect(0,0,W,H);

        // ── Isometric projection (raw, unit coords) ───────────────────────────
        // We build all 2D points first, then compute bounding box, then translate+scale to fit
        var ISO_AX = 0.866, ISO_AY = 0.5; // isometric x-axis direction
        var ISO_ZX = -0.866, ISO_ZY = 0.5; // isometric z-axis direction
        var ISO_YX = 0, ISO_YY = -1;       // isometric y-axis direction (up)

        function iso2D(x,y,z) {
            return [
                x*ISO_AX + z*ISO_ZX + y*ISO_YX,
                x*ISO_AY + z*ISO_ZY + y*ISO_YY
            ];
        }

        // ── First pass: collect all raw 2D points to compute bounding box ─────
        var rawPts = [];
        function collectPts() {
            // All shapes work in normalised space; collect key vertices
            var L = dims.l||1, Wv = dims.w||1, Hv = dims.h||1;
            if(shape==='rect_prism') {
                [[0,0,0],[L,0,0],[L,0,Wv],[0,0,Wv],[0,Hv,0],[L,Hv,0],[L,Hv,Wv],[0,Hv,Wv]].forEach(function(v){rawPts.push(iso2D(v[0],v[1],v[2]));});
            } else if(shape==='rect_pyramid') {
                [[0,0,0],[L,0,0],[L,0,Wv],[0,0,Wv],[L/2,Hv,Wv/2]].forEach(function(v){rawPts.push(iso2D(v[0],v[1],v[2]));});
            } else if(shape==='tri_prism') {
                var a=dims.a||1,b=dims.b||1,c=dims.c||1,h=dims.h||1;
                var cosA=(c*c+b*b-a*a)/(2*c*b); cosA=Math.max(-1,Math.min(1,cosA));
                var Cx=b*cosA,Cz=b*Math.sqrt(1-cosA*cosA);
                [[0,0,0],[c,0,0],[Cx,0,Cz],[0,h,0],[c,h,0],[Cx,h,Cz]].forEach(function(v){rawPts.push(iso2D(v[0],v[1],v[2]));});
            } else if(shape==='tri_pyramid') {
                var a=dims.a||1,b=dims.b||1,c=dims.c||1,sh=dims.sh||1;
                var cosA=(c*c+b*b-a*a)/(2*c*b); cosA=Math.max(-1,Math.min(1,cosA));
                var Cx=b*cosA,Cz=b*Math.sqrt(1-cosA*cosA);
                var cX=(0+c+Cx)/3,cZ=(0+0+Cz)/3;
                var inR=(dims.baseArea||1)/((a+b+c)/2);
                var pyH=Math.sqrt(Math.max(0,sh*sh-inR*inR));
                [[0,0,0],[c,0,0],[Cx,0,Cz],[cX,pyH,cZ]].forEach(function(v){rawPts.push(iso2D(v[0],v[1],v[2]));});
            }
        }
        collectPts();

        // Compute bounding box of raw points
        var minX=Infinity,maxX=-Infinity,minY=Infinity,maxY=-Infinity;
        rawPts.forEach(function(p){minX=Math.min(minX,p[0]);maxX=Math.max(maxX,p[0]);minY=Math.min(minY,p[1]);maxY=Math.max(maxY,p[1]);});
        var spanX=maxX-minX||1, spanY=maxY-minY||1;
        var scaleX=(W-PAD*2)/spanX, scaleY=(H-PAD*2)/spanY;
        var sc=Math.min(scaleX,scaleY); // uniform scale to fit with padding
        var offX=PAD+(W-PAD*2-spanX*sc)/2 - minX*sc;
        var offY=PAD+(H-PAD*2-spanY*sc)/2 - minY*sc;

        // ── Final projection with computed scale/offset ───────────────────────
        function pt(x,y,z) {
            var p=iso2D(x,y,z);
            return [p[0]*sc+offX, p[1]*sc+offY];
        }

        function seg(p1,p2,dim,col,dash) {
            cx.beginPath(); cx.moveTo(p1[0],p1[1]); cx.lineTo(p2[0],p2[1]);
            cx.strokeStyle = col || (dim?strokeDim:stroke);
            cx.lineWidth   = dim ? 1.2 : 2;
            cx.setLineDash(dash || (dim?[5,4]:[]));
            cx.stroke(); cx.setLineDash([]);
        }
        function poly(pts, fillStyle) {
            cx.beginPath(); cx.moveTo(pts[0][0],pts[0][1]);
            for(var i=1;i<pts.length;i++) cx.lineTo(pts[i][0],pts[i][1]);
            cx.closePath(); cx.fillStyle=fillStyle; cx.fill();
            cx.strokeStyle=stroke; cx.lineWidth=1.8; cx.stroke();
        }
        function lbl(px,py,txt,accent) {
            cx.font='bold 10px system-ui,sans-serif';
            var tw=cx.measureText(txt).width;
            cx.fillStyle=d?'rgba(8,12,28,0.82)':'rgba(255,255,255,0.88)';
            cx.beginPath(); cx.roundRect?cx.roundRect(px-tw/2-3,py-7,tw+6,13,3):cx.rect(px-tw/2-3,py-7,tw+6,13);
            cx.fill();
            cx.fillStyle=accent?accentCol:lblCol;
            cx.fillText(txt, px-tw/2, py+3);
        }
        function midLbl(p1,p2,txt,ox,oy,accent) {
            lbl((p1[0]+p2[0])/2+(ox||0),(p1[1]+p2[1])/2+(oy||0),txt,accent);
        }
        function fmtV(v){ return (v!==undefined&&!isNaN(v)&&v!==null)?String(parseFloat(v.toFixed(2))):'?'; }

        // ── Draw each shape ───────────────────────────────────────────────────
        if(shape==='rect_prism') {
            var L=dims.l||1,Wv=dims.w||1,Hv=dims.h||1;
            var bp=[pt(0,0,0),pt(L,0,0),pt(L,0,Wv),pt(0,0,Wv)];
            var tp=[pt(0,Hv,0),pt(L,Hv,0),pt(L,Hv,Wv),pt(0,Hv,Wv)];
            // hidden back edges (dashed)
            seg(bp[0],bp[1],true); seg(bp[0],bp[3],true); seg(bp[0],tp[0],true);
            // faces back-to-front
            poly([tp[0],tp[1],tp[2],tp[3]],fill);
            poly([bp[3],bp[2],tp[2],tp[3]],fillSide);
            poly([bp[2],bp[1],tp[1],tp[2]],fill);
            // visible base edges
            seg(bp[1],bp[2],false); seg(bp[2],bp[3],false);
            seg(bp[1],tp[1],false); seg(bp[2],tp[2],false); seg(bp[3],tp[3],false);
            for(var ii=0;ii<4;ii++) seg(tp[ii],tp[(ii+1)%4],false);
            // space diagonal
            seg(pt(0,0,0),pt(L,Hv,Wv),false,accentCol,[6,4]);
            midLbl(pt(0,0,0),pt(L,Hv,Wv),'d='+fmtV(dims.diag),0,-8,true);
            // dimension labels
            midLbl(bp[2],bp[3],'l='+fmtV(dims.l),0,12);
            midLbl(bp[1],bp[2],'w='+fmtV(dims.w),10,6);
            midLbl(bp[2],tp[2],'h='+fmtV(dims.h),14,0);

        } else if(shape==='rect_pyramid') {
            var L=dims.l||1,Wv=dims.w||1,Hv=dims.h||1;
            var bp=[pt(0,0,0),pt(L,0,0),pt(L,0,Wv),pt(0,0,Wv)];
            var apex=pt(L/2,Hv,Wv/2);
            seg(bp[0],bp[1],true); seg(bp[0],bp[3],true); seg(bp[0],apex,true);
            seg(bp[1],bp[2],false); seg(bp[2],bp[3],false);
            poly([bp[3],bp[2],apex],fillSide);
            poly([bp[1],bp[2],apex],fill);
            poly([bp[0],bp[3],apex],fill);
            // lateral edge diagonal
            seg(apex,bp[2],false,accentCol,[6,4]);
            midLbl(apex,bp[2],'d='+fmtV(dims.diag),12,0,true);
            midLbl(bp[2],bp[3],'l='+fmtV(dims.l),0,12);
            midLbl(bp[1],bp[2],'w='+fmtV(dims.w),10,6);
            midLbl(pt(L/2,0,Wv/2),apex,'h='+fmtV(dims.h),14,0);

        } else if(shape==='tri_prism') {
            var a=dims.a||1,b=dims.b||1,c=dims.c||1,h=dims.h||1;
            var cosA=(c*c+b*b-a*a)/(2*c*b); cosA=Math.max(-1,Math.min(1,cosA));
            var Cx=b*cosA, Cz=b*Math.sqrt(1-cosA*cosA);
            var f0=[pt(0,0,0),pt(c,0,0),pt(Cx,0,Cz)];
            var fH=[pt(0,h,0),pt(c,h,0),pt(Cx,h,Cz)];
            seg(f0[0],f0[1],true); seg(f0[0],fH[0],true);
            poly(fH,fill);
            poly(f0,fillSide);
            poly([f0[1],f0[2],fH[2],fH[1]],fill);
            poly([f0[0],f0[2],fH[2],fH[0]],fillSide);
            seg(f0[1],fH[1],false); seg(f0[2],fH[2],false); seg(f0[0],f0[2],false);
            midLbl(fH[0],fH[1],'c='+fmtV(c),0,-10);
            midLbl(fH[0],fH[2],'b='+fmtV(b),-12,-4);
            midLbl(fH[1],fH[2],'a='+fmtV(a),10,-4);
            midLbl(f0[1],fH[1],'h='+fmtV(h),14,0);

        } else if(shape==='tri_pyramid') {
            var a=dims.a||1,b=dims.b||1,c=dims.c||1,sh=dims.sh||1;
            var cosA=(c*c+b*b-a*a)/(2*c*b); cosA=Math.max(-1,Math.min(1,cosA));
            var Cx=b*cosA,Cz=b*Math.sqrt(1-cosA*cosA);
            var centX=(0+c+Cx)/3, centZ=(0+0+Cz)/3;
            var sv=(a+b+c)/2;
            var baseArea=dims.baseArea||Math.sqrt(Math.max(0,sv*(sv-a)*(sv-b)*(sv-c)));
            var inR=baseArea/sv;
            var pyH=Math.sqrt(Math.max(0,sh*sh-inR*inR));
            var pA=pt(0,0,0),pB=pt(c,0,0),pC=pt(Cx,0,Cz),apex=pt(centX,pyH,centZ);
            seg(pA,pB,true);
            poly([pB,pC,apex],fill);
            poly([pA,pC,apex],fillSide);
            poly([pA,pB,apex],fill);
            seg(pA,pC,false); seg(pB,pC,false);
            midLbl(pA,pB,'c='+fmtV(c),0,12);
            midLbl(pA,pC,'b='+fmtV(b),-12,4);
            midLbl(pB,pC,'a='+fmtV(a),12,4);
            // slant height from mid of front base edge to apex
            var midBC=[( pB[0]+pC[0])/2,(pB[1]+pC[1])/2];
            seg(midBC,apex,false,accentCol,[5,4]);
            midLbl(midBC,apex,'sh='+fmtV(sh),14,0,true);
        }
    }

    // ── 3D Calculations ────────────────────────────────────────────────────────
    function calc3D() {
        var d=getDark(), p=getPrec(), html='', warn='';
        var surfArea=NaN, totalEdges=NaN;
        var dimsForDiag={};

        try {
        // ── Rectangular Prism ──────────────────────────────────────────────────
        if(current3DShape==='rect_prism'){
            var l,w,h,ba;
            if(current3DGoal==='all'||current3DGoal==='diagonal'||current3DGoal==='surface'||current3DGoal==='edges'){
                l=get3D('s3_l');w=get3D('s3_w');h=get3D('s3_h');
                if(isNaN(l)||isNaN(w)||isNaN(h)||l<=0||w<=0||h<=0) warn='Enter positive Length, Width, and Height.';
            } else if(current3DGoal==='volume'){
                var list=(methods3D.rect_prism.volume||[]);
                var m=list[current3DMethod]||list[0];
                if(m.id==='rp_v_bah'){ba=get3D('s3_ba');h=get3D('s3_h');if(isNaN(ba)||isNaN(h)||ba<=0||h<=0)warn='Enter Base Area and Height.';}
                else{l=get3D('s3_l');w=get3D('s3_w');h=get3D('s3_h');if(isNaN(l)||isNaN(w)||isNaN(h)||l<=0||w<=0||h<=0)warn='Enter L, W, H.';}
            }
            if(!warn){
                if(current3DGoal==='volume'&&!isNaN(ba)){
                    var vol=ba*h;
                    html+=saRow3D('Base Area',ba)+saRow3D('Height',h)+saRow3D('Volume',vol);
                    dimsForDiag={l:Math.sqrt(ba),w:Math.sqrt(ba),h:h};
                } else {
                    var diag=Math.sqrt(l*l+w*w+h*h);
                    var fdLW=Math.sqrt(l*l+w*w),fdLH=Math.sqrt(l*l+h*h),fdWH=Math.sqrt(w*w+h*h);
                    var vol=l*w*h; surfArea=2*(l*w+l*h+w*h); totalEdges=4*(l+w+h);
                    dimsForDiag={l:l,w:w,h:h,diag:diag};
                    if(current3DGoal==='all'){
                        html+=saRow3D('Length',l)+saRow3D('Width',w)+saRow3D('Height',h);
                        html+=saRow3D('Space Diagonal',diag);
                        html+=saRow3D('Face Diag (l×w)',fdLW)+saRow3D('Face Diag (l×h)',fdLH)+saRow3D('Face Diag (w×h)',fdWH);
                        html+=saRow3D('Volume',vol);
                    } else if(current3DGoal==='diagonal'){
                        html+=saRow3D('Space Diagonal',diag)+saRow3D('Face Diag (l×w)',fdLW)+saRow3D('Face Diag (l×h)',fdLH)+saRow3D('Face Diag (w×h)',fdWH);
                    } else if(current3DGoal==='surface'){
                        html+=saRow3D('Surface Area',surfArea);
                        html+=saRow3D('Face l×w (×2)',l*w)+saRow3D('Face l×h (×2)',l*h)+saRow3D('Face w×h (×2)',w*h);
                    } else if(current3DGoal==='volume'){
                        html+=saRow3D('Volume',vol);
                    } else if(current3DGoal==='edges'){
                        html+=saRow3D('Total Edge Length',totalEdges);
                        html+=saRow3D('12 edges: 4×l+4×w+4×h','');
                    }
                }
            }

        // ── Rectangular Pyramid ────────────────────────────────────────────────
        } else if(current3DShape==='rect_pyramid'){
            var l,w,h,ba;
            if(current3DGoal==='volume'){
                var list=methods3D.rect_pyramid.volume||[];
                var m=list[current3DMethod]||list[0];
                if(m.id==='rpyr_v_bah'){ba=get3D('s3_ba');h=get3D('s3_h');if(isNaN(ba)||isNaN(h)||ba<=0||h<=0)warn='Enter Base Area and Height.';}
                else{l=get3D('s3_l');w=get3D('s3_w');h=get3D('s3_h');if(isNaN(l)||isNaN(w)||isNaN(h)||l<=0||w<=0||h<=0)warn='Enter L, W, H.';}
            } else {
                l=get3D('s3_l');w=get3D('s3_w');h=get3D('s3_h');
                if(isNaN(l)||isNaN(w)||isNaN(h)||l<=0||w<=0||h<=0) warn='Enter positive Base Length, Width, and Height.';
            }
            if(!warn){
                if(current3DGoal==='volume'&&!isNaN(ba)){
                    var vol=(1/3)*ba*h;
                    html+=saRow3D('Base Area',ba)+saRow3D('Height',h)+saRow3D('Volume',vol);
                    dimsForDiag={l:Math.sqrt(ba),w:Math.sqrt(ba),h:h};
                } else {
                    var latEdge=Math.sqrt((l/2)*(l/2)+(w/2)*(w/2)+h*h);
                    var slantL=Math.sqrt(h*h+(w/2)*(w/2)), slantW=Math.sqrt(h*h+(l/2)*(l/2));
                    var baseDiag=Math.sqrt(l*l+w*w);
                    var diag=latEdge; // apex to base corner IS the lateral edge
                    var vol=(1/3)*l*w*h;
                    surfArea=l*w+l*slantL+w*slantW;
                    totalEdges=2*(l+w)+4*latEdge;
                    dimsForDiag={l:l,w:w,h:h,diag:latEdge};
                    if(current3DGoal==='all'){
                        html+=saRow3D('Base Length',l)+saRow3D('Base Width',w)+saRow3D('Height',h);
                        html+=saRow3D('Lateral Edge (apex→corner)',latEdge);
                        html+=saRow3D('Base Diagonal',baseDiag);
                        html+=saRow3D('Slant Height (l-face)',slantL)+saRow3D('Slant Height (w-face)',slantW);
                        html+=saRow3D('Volume',vol);
                    } else if(current3DGoal==='diagonal'){
                        html+=saRow3D('Lateral Edge (apex→corner)',latEdge)+saRow3D('Base Diagonal',baseDiag);
                        html+=saRow3D('Slant Height (l-face)',slantL)+saRow3D('Slant Height (w-face)',slantW);
                    } else if(current3DGoal==='surface'){
                        html+=saRow3D('Surface Area',surfArea);
                        html+=saRow3D('Base (l×w)',l*w)+saRow3D('2 Lateral (l-faces)',l*slantL)+saRow3D('2 Lateral (w-faces)',w*slantW);
                    } else if(current3DGoal==='volume'){
                        html+=saRow3D('Volume',vol);
                    } else if(current3DGoal==='edges'){
                        html+=saRow3D('Total Edge Length',totalEdges);
                        html+=saRow3D('4 Base + 4 Lateral','');
                    }
                }
            }

        // ── Triangular Prism ───────────────────────────────────────────────────
        } else if(current3DShape==='tri_prism'){
            var a,b,c,h,ba;
            if(current3DGoal==='volume'){
                var list=methods3D.tri_prism.volume||[];
                var m=list[current3DMethod]||list[0];
                if(m.id==='tp_v_bah'){ba=get3D('s3_ba');h=get3D('s3_h');if(isNaN(ba)||isNaN(h)||ba<=0||h<=0)warn='Enter Triangle Area and Length.';}
                else{a=get3D('s3_a');b=get3D('s3_b');c=get3D('s3_c');h=get3D('s3_h');if(isNaN(a)||isNaN(b)||isNaN(c)||isNaN(h)||a<=0||b<=0||c<=0||h<=0)warn='Enter all sides and length.';}
            } else {
                a=get3D('s3_a');b=get3D('s3_b');c=get3D('s3_c');h=get3D('s3_h');
                if(isNaN(a)||isNaN(b)||isNaN(c)||isNaN(h)||a<=0||b<=0||c<=0||h<=0)warn='Enter all three sides and prism length.';
                else if(a+b<=c||a+c<=b||b+c<=a)warn='Those sides don\'t form a valid triangle.';
            }
            if(!warn){
                if(current3DGoal==='volume'&&!isNaN(ba)){
                    var vol=ba*h;
                    html+=saRow3D('Triangle Area',ba)+saRow3D('Length',h)+saRow3D('Volume',vol);
                    dimsForDiag={a:Math.sqrt(ba*2),b:Math.sqrt(ba*2),c:Math.sqrt(ba*2),h:h};
                } else {
                    var sv=(a+b+c)/2;
                    var triArea=Math.sqrt(sv*(sv-a)*(sv-b)*(sv-c));
                    var vol=triArea*h;
                    surfArea=2*triArea+(a+b+c)*h;
                    totalEdges=3*h+2*(a+b+c);
                    dimsForDiag={a:a,b:b,c:c,h:h};
                    if(current3DGoal==='all'){
                        html+=saRow3D('Side a',a)+saRow3D('Side b',b)+saRow3D('Side c',c)+saRow3D('Length (h)',h);
                        html+=saRow3D('Triangle Area',triArea);
                        html+=saRow3D('Lateral Face a×h',a*h)+saRow3D('Lateral Face b×h',b*h)+saRow3D('Lateral Face c×h',c*h);
                        html+=saRow3D('Volume',vol);
                    } else if(current3DGoal==='surface'){
                        html+=saRow3D('Surface Area',surfArea);
                        html+=saRow3D('2 Triangle Faces',2*triArea)+saRow3D('Rect Face a×h',a*h)+saRow3D('Rect Face b×h',b*h)+saRow3D('Rect Face c×h',c*h);
                    } else if(current3DGoal==='volume'){
                        html+=saRow3D('Volume',vol);
                    } else if(current3DGoal==='edges'){
                        html+=saRow3D('Total Edge Length',totalEdges);
                        html+=saRow3D('3 length edges',3*h)+saRow3D('6 triangle edges',2*(a+b+c));
                    }
                }
            }

        // ── Triangular Pyramid ─────────────────────────────────────────────────
        } else if(current3DShape==='tri_pyramid'){
            var a,b,c,sh,ba,h;
            if(current3DGoal==='volume'){
                var list=methods3D.tri_pyramid.volume||[];
                var m=list[current3DMethod]||list[0];
                if(m.id==='tpyr_v_bah'){ba=get3D('s3_ba');h=get3D('s3_h');if(isNaN(ba)||isNaN(h)||ba<=0||h<=0)warn='Enter Base Area and Height.';}
                else{a=get3D('s3_a');b=get3D('s3_b');c=get3D('s3_c');sh=get3D('s3_sh');if(isNaN(a)||isNaN(b)||isNaN(c)||isNaN(sh)||a<=0||b<=0||c<=0||sh<=0)warn='Enter all sides and slant height.';}
            } else {
                a=get3D('s3_a');b=get3D('s3_b');c=get3D('s3_c');sh=get3D('s3_sh');
                if(isNaN(a)||isNaN(b)||isNaN(c)||isNaN(sh)||a<=0||b<=0||c<=0||sh<=0)warn='Enter all three sides and slant height.';
                else if(a+b<=c||a+c<=b||b+c<=a)warn='Those sides don\'t form a valid triangle.';
            }
            if(!warn){
                if(current3DGoal==='volume'&&!isNaN(ba)){
                    var vol=(1/3)*ba*h;
                    html+=saRow3D('Base Area',ba)+saRow3D('Height',h)+saRow3D('Volume',vol);
                    dimsForDiag={a:Math.sqrt(ba*2),b:Math.sqrt(ba*2),c:Math.sqrt(ba*2),sh:h};
                } else {
                    var sv=(a+b+c)/2;
                    var baseArea=Math.sqrt(sv*(sv-a)*(sv-b)*(sv-c));
                    var latA=0.5*a*sh, latB=0.5*b*sh, latC=0.5*c*sh;
                    surfArea=baseArea+latA+latB+latC;
                    var inR=baseArea/sv;
                    var pyH=Math.sqrt(Math.max(0,sh*sh-inR*inR));
                    var vol=(1/3)*baseArea*pyH;
                    var latEdge=Math.sqrt(sh*sh+inR*inR);
                    totalEdges=(a+b+c)+3*latEdge;
                    dimsForDiag={a:a,b:b,c:c,sh:sh,baseArea:baseArea};
                    if(current3DGoal==='all'){
                        html+=saRow3D('Base Side a',a)+saRow3D('Base Side b',b)+saRow3D('Base Side c',c)+saRow3D('Slant Height',sh);
                        html+=saRow3D('Base Area',baseArea);
                        html+=saRow3D('Lateral Face A',latA)+saRow3D('Lateral Face B',latB)+saRow3D('Lateral Face C',latC);
                        html+=saRow3D('Pyramid Height (approx)',pyH);
                        html+=saRow3D('Lateral Edge (approx)',latEdge);
                        html+=saRow3D('Volume (approx)',vol);
                    } else if(current3DGoal==='surface'){
                        html+=saRow3D('Surface Area',surfArea);
                        html+=saRow3D('Base Area',baseArea)+saRow3D('Lateral Face A',latA)+saRow3D('Lateral Face B',latB)+saRow3D('Lateral Face C',latC);
                    } else if(current3DGoal==='volume'){
                        html+=saRow3D('Volume (approx)',vol);
                        html+=saRow3D('Base Area',baseArea)+saRow3D('Height (approx)',pyH);
                    } else if(current3DGoal==='edges'){
                        html+=saRow3D('Total Edge Length',totalEdges);
                        html+=saRow3D('3 Base edges',a+b+c)+saRow3D('3 Lateral edges',3*latEdge);
                    }
                }
            }
        }
        } catch(err){ warn='Calculation error: '+err.message; }

        var r=get('res3D'); r.style.display='block';
        var rows=get('res3DRows');
        if(warn){
            rows.innerHTML='<div style="color:'+(d?'#ff7070':'#c0392b')+';font-weight:600;font-size:12px;">\u26a0 '+warn+'</div>';
            get('surfaceAreaRes').innerText=''; get('totalEdgesRes').innerText='';
            var cb3=get('canvasBox3D'); if(cb3) cb3.style.display='none';
        } else {
            rows.innerHTML=html;
            var pr=getPrec();
            get('surfaceAreaRes').innerText=(!isNaN(surfArea))?trimZ(surfArea.toFixed(pr)):'—';
            get('totalEdgesRes').innerText=(!isNaN(totalEdges))?trimZ(totalEdges.toFixed(pr)):'—';
            draw3DShape(current3DShape, dimsForDiag);
            lastCalcResult3D = {shape: current3DShape, dims: dimsForDiag};
        }
    }

