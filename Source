        }

        // ── ANGLE GOALS ──────────────────────────────────────────────────────────
        if(type==='sc_ang_aa'||type==='is_ang_aa'||type==='eq_ang_s'||type==='rt_ang_aa'){
            var angA,angB,angC;
            if(type==='eq_ang_s'){
                s1=v0; b=v0; s2=v0; h=Math.sqrt(3)/2*v0; area=Math.sqrt(3)/4*v0*v0; perim=3*v0;
                angA=Math.PI/3; angB=Math.PI/3; angC=Math.PI/3;
                formula='Equilateral triangle: all angles = 60\u00b0';
            } else if(type==='rt_ang_aa'){
                angA=toRad(v0); angB=Math.PI/2-angA; angC=Math.PI/2;
                formula='B = 90\u00b0 \u2212 A = '+fmtAngle(angB)+'\nAll angles: A='+fmtAngle(angA)+', B='+fmtAngle(angB)+', C=90\u00b0';
                s1=1; b=1; s2=Math.sqrt(2); h=s1; area=0.5; perim=s1+b+s2;
            } else {
                angA=toRad(v0); angB=toRad(v1); angC=Math.PI-angA-angB;
                if(angC<=0){if(!silent)showError('Impossible','Angles must sum to less than 180\u00b0.');return;}
                formula='C = 180\u00b0 \u2212 A \u2212 B\n= 180\u00b0 \u2212 '+v0+'\u00b0 \u2212 '+v1+'\u00b0 = '+fmtAngle(angC);
                s1=1; b=1; s2=1; h=0.5; area=0.25; perim=3;
            }
            doShowAngles([angA,angB,angC], formula, s1, h, b, s2, area, perim);
            return;
        }
        if(type==='sc_ang_sss'||type==='is_ang_lb'){
            var aa,bb,cc;
            if(type==='is_ang_lb'){ aa=v0; cc=v0; bb=v1; }
            else { aa=v0; bb=v1; cc=v2; }
            if(aa+bb<=cc||aa+cc<=bb||bb+cc<=aa){if(!silent)showError('Impossible','These sides don\'t form a valid triangle.');return;}
            var cosA=(bb*bb+cc*cc-aa*aa)/(2*bb*cc);
            var cosB=(aa*aa+cc*cc-bb*bb)/(2*aa*cc);
            var cosC=(aa*aa+bb*bb-cc*cc)/(2*aa*bb);
            var angAs=Math.acos(Math.max(-1,Math.min(1,cosA)));
            var angBs=Math.acos(Math.max(-1,Math.min(1,cosB)));
            var angCs=Math.acos(Math.max(-1,Math.min(1,cosC)));
            var sv=(aa+bb+cc)/2; var ar=Math.sqrt(sv*(sv-aa)*(sv-bb)*(sv-cc));
            formula='cos A = (b\u00b2+c\u00b2\u2212a\u00b2)/(2bc)\nA='+fmtAngle(angAs)+', B='+fmtAngle(angBs)+', C='+fmtAngle(angCs);
            var hh=type==='is_ang_lb'?Math.sqrt(aa*aa-(bb/2)*(bb/2)):ar/(0.5*(aa+bb+cc)/sv);
            doShowAngles([angAs,angBs,angCs], formula, aa, hh, bb, cc, ar, aa+bb+cc);
            return;
        }
        if(type==='sc_ang_sas'){
            var sa=v0, angCi=toRad(v1), sb=v2;
            var sc=Math.sqrt(sa*sa+sb*sb-2*sa*sb*Math.cos(angCi));
            var cosAi=(sb*sb+sc*sc-sa*sa)/(2*sb*sc);
            var cosBi=(sa*sa+sc*sc-sb*sb)/(2*sa*sc);
            var angAi=Math.acos(Math.max(-1,Math.min(1,cosAi)));
            var angBi=Math.acos(Math.max(-1,Math.min(1,cosBi)));
            var ari=0.5*sa*sb*Math.sin(angCi);
            var hi=2*ari/sc;
            formula='c = \u221a(a\u00b2+b\u00b2\u22122ab\u00b7cos C) = '+sc.toFixed(getPrec())+'\nA='+fmtAngle(angAi)+', B='+fmtAngle(angBi)+', C='+fmtAngle(angCi);
            doShowAngles([angAi,angBi,angCi], formula, sa, hi, sc, sb, ari, sa+sb+sc);
            return;
        }
        if(type==='sc_ang_ssa'){
            var sa2=v0, sb2=v1, angA2=toRad(v2);
            var sinB2=sb2*Math.sin(angA2)/sa2;
