            res=0.5*s1*s2*Math.sin(angCSAS);
            area=res;
            b=Math.sqrt(s1*s1+s2*s2-2*s1*s2*Math.cos(angCSAS));
            h=(2*area)/b;
            formula='Area = \u00bd \u00d7 a \u00d7 b \u00d7 sin(C)\n= \u00bd \u00d7 '+s1+' \u00d7 '+s2+' \u00d7 sin('+v1+'\u00b0)\n= '+fmtS(res);

        }else if(type==='is_b_asa'){
            var apexRad=toRad(v0), leg=v1;
            res=2*leg*Math.sin(apexRad/2);
            b=res; s1=leg; s2=leg;
            h=leg*Math.cos(apexRad/2);
            area=0.5*b*h;
            formula='Base = 2 \u00d7 Leg \u00d7 sin(Apex/2)\n= 2 \u00d7 '+leg+' \u00d7 sin('+v0+'\u00b0/2)\n= '+fmtS(res);

        }else if(type==='is_s_ba'){
            var baseLen=v0, baseAng=toRad(v1);
            if(baseAng>=Math.PI/2){if(!silent)showError('Impossible','Base angle must be less than 90\u00b0.');return;}
            res=(baseLen/2)/Math.cos(baseAng);
            s1=res;s2=res;b=baseLen;
            h=s1*Math.sin(baseAng);
            area=0.5*b*h;
            formula='Leg = (Base/2) / cos(Base Angle)\n= ('+baseLen+'/2) / cos('+v1+'\u00b0)\n= '+fmtS(res);

        }else if(type==='is_a_la'){
            var legLA=v0, apexLA=toRad(v1);
            res=0.5*legLA*legLA*Math.sin(apexLA);
            area=res; s1=legLA; s2=legLA;
            b=2*legLA*Math.sin(apexLA/2);
            h=(2*area)/b;
            formula='Area = \u00bd \u00d7 Leg\u00b2 \u00d7 sin(Apex)\n= \u00bd \u00d7 '+legLA+'\u00b2 \u00d7 sin('+v1+'\u00b0)\n= '+fmtS(res);

        }else if(type==='rt_c_la'){
            var legRT=v0, angRT=toRad(v1);
            if(angRT>=Math.PI/2){if(!silent)showError('Impossible','Acute angle must be less than 90\u00b0.');return;}
            res=legRT/Math.sin(angRT);
            s2=res; s1=legRT; h=legRT; b=res*Math.cos(angRT);
            area=0.5*s1*b; perim=s1+b+s2;
            formula='Hypotenuse = Leg / sin(A)\n= '+legRT+' / sin('+v1+'\u00b0)\n= '+fmtS(res);

        }else if(type==='rt_l_ca'){
            var hypCA=v0, angCA=toRad(v1);
            if(angCA>=Math.PI/2){if(!silent)showError('Impossible','Acute angle must be less than 90\u00b0.');return;}
            res=hypCA*Math.sin(angCA);
            s1=res; h=res; s2=hypCA; b=hypCA*Math.cos(angCA);
            area=0.5*s1*b; perim=s1+b+s2;
            formula='Leg = Hypotenuse \u00d7 sin(A)\n= '+hypCA+' \u00d7 sin('+v1+'\u00b0)\n= '+fmtS(res);
        }
        }catch(e){if(!silent)showError('Calculation error','Double-check your values form a valid triangle.');return;}

        if(isNaN(res)||res<=0||!isFinite(res)){if(!silent)showError('No solution','These values don\'t form a valid triangle.');return;}
        if(!s1||isNaN(s1))s1=res; if(!s2||isNaN(s2))s2=res;
        if(!b||isNaN(b))b=res;   if(!h||isNaN(h))h=res;

        if(!area||isNaN(area)) area=0.5*b*h;
        perim=s1+s2+b;
        get('res').style.display='block';

        var approxEl=get('finalApprox');
        if(useSurd){
            var ss=toSurdStr(res);
