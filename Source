                var td2=checkTripleDetail(allS1,allBase,allS2);
                var inR2=allArea/((allS1+allBase+allS2)/2);
                html2+=allRow('Inradius', inR2.toFixed(p));
                html2+=allRow('Circumradius', (allS2/2).toFixed(p));
                if(td2.isTriple) html2+='<div style="margin-top:6px;padding:5px 9px;background:'+(d2a?'#1a2e1a':'#e8f8e8')+';border:1px solid '+(d2a?'#3a6e3a':'#a8d8a8')+';border-radius:6px;font-size:11px;font-weight:700;color:'+(d2a?'#6abf6a':'#2a7a2a')+';">&#9733; Pythagorean triple: '+td2.pa+'-'+td2.pb+'-'+td2.pc+(td2.isPrimitive?'':' \u00d7'+td2.scale)+'</div>';
                else html2+='<div style="margin-top:6px;padding:4px 9px;background:'+(d2a?'#2a2a3e':'#f5f5f5')+';border-radius:6px;font-size:11px;color:'+(d2a?'#7070a0':'#888')+';">Not a Pythagorean triple</div>';
            } else if(currentTri==='equilateral') {
                var eInR=allS1/(2*Math.sqrt(3)), eCircR=allS1/Math.sqrt(3);
                html2+=allRow('Side', allS1.toFixed(p));
                html2+=allRow('Height', allH.toFixed(p));
                html2+=allRow('All angles', pDeg(60), degSfx);
                html2+=allRow('Area', allArea.toFixed(p));
                html2+=allRow('Perimeter', allPerim.toFixed(p));
                html2+=allRow('Inradius', eInR.toFixed(p));
                html2+=allRow('Circumradius', eCircR.toFixed(p));
            } else if(currentTri==='isosceles') {
                var iInR2=allArea/((allS1*2+allBase)/2);
                html2+=allRow('Leg (equal side)', allS1.toFixed(p));
                html2+=allRow('Base', allBase.toFixed(p));
                html2+=allRow('Height', allH.toFixed(p));
                html2+=allRow('Apex angle', pDeg(allAngA), degSfx);
                html2+=allRow('Base angle', pDeg(allAngB), degSfx);
                html2+=allRow('Area', allArea.toFixed(p));
