    function drawTri(s1, h, b, s2, isExt, anglesData) {
        var W=canvas.width, H=canvas.height;
        ctx.clearRect(0,0,W,H);
        var d=getDark();
        var triCol=d?'#4a9eff':'#1a73e8';
        var raw;
        if(currentTri==='equilateral'||currentTri==='isosceles') raw=[[0,h],[b/2,0],[b,h]];
        else if(currentTri==='right') raw=[[0,h],[0,0],[b,h]];
        else { var ax=Math.sqrt(Math.max(0,s1*s1-h*h)); raw=isExt?[[0,h],[ax,0],[Math.abs(ax-b),h]]:[[0,h],[ax,0],[b,h]]; }

        var padT=38, padB=52, padL=52, padR=52;
        var minX=raw[0][0],maxX=raw[0][0];
        for(var i=1;i<3;i++){if(raw[i][0]<minX)minX=raw[i][0];if(raw[i][0]>maxX)maxX=raw[i][0];}
        var rangeX=maxX-minX||1, rangeY=h||1;
        var scale=Math.min((W-padL-padR)/rangeX,(H-padT-padB)/rangeY);
        var offX=(W-rangeX*scale)/2-minX*scale, offY=padT+(H-padT-padB-rangeY*scale)/2;
        function tr(pt){return[pt[0]*scale+offX,pt[1]*scale+offY];}
        var pA=tr(raw[0]),pB=tr(raw[1]),pC=tr(raw[2]);
        var pH=[pB[0],pA[1]];

        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();
        ctx.fillStyle=d?'rgba(74,158,255,0.08)':'rgba(26,115,232,0.07)';ctx.fill();

        function tick(ax,ay,bx,by,n){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len*5,ny=dx/len*5,gap=4;
            ctx.strokeStyle=triCol;ctx.lineWidth=1.5;
            for(var t=0;t<n;t++){var o=(t-(n-1)/2)*gap,ox=dx/len*o,oy=dy/len*o;ctx.beginPath();ctx.moveTo(mx+ox-nx,my+oy-ny);ctx.lineTo(mx+ox+nx,my+oy+ny);ctx.stroke();}
        }
        if(currentTri==='equilateral'){tick(pA[0],pA[1],pB[0],pB[1],2);tick(pB[0],pB[1],pC[0],pC[1],2);tick(pA[0],pA[1],pC[0],pC[1],2);}
        else if(currentTri==='isosceles'){tick(pA[0],pA[1],pB[0],pB[1],1);tick(pB[0],pB[1],pC[0],pC[1],1);}

        ctx.strokeStyle=triCol;ctx.lineWidth=2.5;ctx.lineJoin='round';
        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();ctx.stroke();

        if(currentTri==='right'){var sq=7;ctx.strokeStyle=d?'#888':'#888';ctx.lineWidth=1.2;ctx.strokeRect(pA[0],pA[1]-sq,sq,sq);}

        var altOnLeft=false,altOnRight=false;
        if(currentTri==='scalene'){var eps=0.002*scale;altOnLeft=Math.abs(pB[0]-pA[0])<eps;altOnRight=Math.abs(pB[0]-pC[0])<eps;}
        var drawAlt=(currentTri==='isosceles'||currentTri==='equilateral'||(currentTri==='scalene'&&!altOnLeft&&!altOnRight));
        if(drawAlt){
            ctx.setLineDash([4,4]);ctx.lineWidth=1.5;ctx.strokeStyle=d?'#555':'#aaa';
            ctx.beginPath();ctx.moveTo(pB[0],pB[1]);ctx.lineTo(pH[0],pH[1]);ctx.stroke();ctx.setLineDash([]);
            var sq2=6;ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;
            ctx.strokeRect(pH[0], pH[1]-sq2, sq2, sq2);
        } else if(currentTri==='scalene'&&altOnLeft){
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;ctx.strokeRect(pA[0],pA[1],6,-6);
        } else if(currentTri==='scalene'&&altOnRight){
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;ctx.strokeRect(pC[0]-6,pC[1],6,-6);
        }

        if(anglesData){
            var verts=[[pA,anglesData[0]],[pB,anglesData[1]],[pC,anglesData[2]]];
            var otherVerts=[[pB,pC],[pA,pC],[pA,pB]];
            var arcColor = d ? '#4a9eff' : '#4a90d0';
            verts.forEach(function(vinfo,vi){
                var vp=vinfo[0], ang=vinfo[1];
                if(currentTri==='right'&&vi===0&&Math.abs(ang-Math.PI/2)<0.01) return;
                var o1=otherVerts[vi][0], o2=otherVerts[vi][1];
                var d1x=o1[0]-vp[0],d1y=o1[1]-vp[1];
                var d2x=o2[0]-vp[0],d2y=o2[1]-vp[1];
                var a1=Math.atan2(d1y,d1x), a2=Math.atan2(d2y,d2x);
                var r=13;
                ctx.beginPath();
                var diff=a2-a1;
                while(diff> Math.PI) diff-=2*Math.PI;
                while(diff<-Math.PI) diff+=2*Math.PI;
                ctx.arc(vp[0],vp[1],r,a1,a1+diff,diff<0);
                ctx.strokeStyle=arcColor;ctx.lineWidth=1.2;ctx.stroke();

                var midA=a1+diff/2;
                var labelR=r+18;
                var lx=vp[0]+Math.cos(midA)*labelR, ly=vp[1]+Math.sin(midA)*labelR;
                var labelText=fmtAngle(ang);
                ctx.font='bold 9px system-ui';
                var tw=ctx.measureText(labelText).width;
                var ph=12, pw=tw+8;
                lx=Math.max(pw/2+2, Math.min(W-pw/2-2, lx));
                ly=Math.max(ph/2+2, Math.min(H-ph/2-2, ly));
                var bgCol = d ? '#1e1e2e' : '#fff';
                var bdCol = d ? '#4a9eff' : '#4a90d0';
                ctx.beginPath();
                if(ctx.roundRect){
                    ctx.roundRect(lx-pw/2, ly-ph/2, pw, ph, 4);
                } else {
                    ctx.moveTo(lx-pw/2+4,ly-ph/2);ctx.lineTo(lx+pw/2-4,ly-ph/2);
                    ctx.quadraticCurveTo(lx+pw/2,ly-ph/2,lx+pw/2,ly-ph/2+4);
                    ctx.lineTo(lx+pw/2,ly+ph/2-4);
                    ctx.quadraticCurveTo(lx+pw/2,ly+ph/2,lx+pw/2-4,ly+ph/2);
                    ctx.lineTo(lx-pw/2+4,ly+ph/2);
                    ctx.quadraticCurveTo(lx-pw/2,ly+ph/2,lx-pw/2,ly+ph/2-4);
                    ctx.lineTo(lx-pw/2,ly-ph/2+4);
                    ctx.quadraticCurveTo(lx-pw/2,ly-ph/2,lx-pw/2+4,ly-ph/2);
                    ctx.closePath();
                }
                ctx.fillStyle=bgCol; ctx.fill();
                ctx.strokeStyle=bdCol; ctx.lineWidth=0.8; ctx.stroke();
                ctx.fillStyle=d ? '#4a9eff' : '#1a73e8';
                ctx.textAlign='center'; ctx.textBaseline='middle';
                ctx.fillText(labelText, lx, ly);
            });
        }

        ctx.fillStyle=triCol;ctx.font='bold 11px system-ui';ctx.textAlign='center';ctx.textBaseline='middle';
        var OUT=16, adv=getAdv(), hLbl=adv?'alt=':'h=';
        var cx=(pA[0]+pB[0]+pC[0])/3, cy=(pA[1]+pB[1]+pC[1])/3;
        function labelSide(ax,ay,bx,by,lbl){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len,ny=dx/len;
            if((mx+nx-cx)*nx+(my+ny-cy)*ny<0){nx=-nx;ny=-ny;}
            var lx2=mx+nx*OUT, ly2=my+ny*OUT;
            lx2=Math.max(8,Math.min(W-8,lx2)); ly2=Math.max(8,Math.min(H-8,ly2));
            ctx.fillText(lbl,lx2,ly2);
        }
        function altLabel(hVal){
            var hmy=(pB[1]+pH[1])/2;
            var margin=8;
            if(pH[0]+margin+30 < W){ctx.textAlign='left';ctx.fillText(hLbl+hVal,pH[0]+margin,hmy);}
            else{ctx.textAlign='right';ctx.fillText(hLbl+hVal,pH[0]-margin,hmy);}
        }
        var s1L=fmt(s1),s2L=fmt(s2),bL=fmt(b),hL=fmt(h);
        if(currentTri==='equilateral'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],s1L);
            altLabel(hL);
        } else if(currentTri==='isosceles'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            altLabel(hL);
        } else if(currentTri==='right'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L);
        } else {
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            if(!altOnLeft&&!altOnRight) altLabel(hL);
        }
    }

    get('calc').onclick = function() {
        clearError();
        var list=getMethodList();
        if(!list.length){showError('Not available','No formula for this combination.');return;}
        var cfg=list[Math.min(currentMethod,list.length-1)];
        var vals=[],missing=[];
        cfg.inputs.forEach(function(lbl,i){
            var el=get('v'+i),v=el?parseFloat(el.value):NaN;
            vals.push(v);
            if(isNaN(v)||!el||el.value.trim()==='') missing.push(lbl);
        });
        if(missing.length){showError('Missing values','Please fill in: '+missing.join(', ')+'.');return;}
        for(var j=0;j<vals.length;j++) if(vals[j]<=0){showError('Values must be positive',cfg.inputs[j]+' must be greater than zero.');return;}

        var v0=vals[0],v1=vals.length>1?vals[1]:NaN,v2=vals.length>2?vals[2]:NaN;
        var p=getPrec(),useSurd=getSurd();
        var posEl=ui.querySelector('input[name="geopro_pos"]:checked');
        var isExt=posEl?posEl.value==='ext':false;
        var type=cfg.id;
        var res,area,perim,formula,s1,h,b,s2;

        if(type==='rt_triple_check'){
