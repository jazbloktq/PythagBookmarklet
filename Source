(function() {
    if (document.getElementById('geo-ultimate-vscroll')) { document.getElementById('geo-ultimate-vscroll').remove(); }

    var LS_KEY = 'geoPro_settings';
    var saved = {};

    // ── Persistent cross-origin settings via IndexedDB + BroadcastChannel sync ─
    // localStorage is per-origin so settings are lost across different-domain tabs.
    // IndexedDB is also per-origin, BUT we open our own dedicated DB on EVERY origin
    // the bookmarklet runs on, always using the same DB+store name. On first load we
    // ask peer tabs (via BroadcastChannel, which IS cross-origin) for the latest
    // settings, apply them, and write them into THIS origin's IndexedDB so future
    // loads on the same site are instant. Any settings change is broadcast live to
    // all open tabs AND written to the current origin's IndexedDB.

    var _IDB_NAME  = 'geoProDB';
    var _IDB_STORE = 'settings';
    var _IDB_KEY   = 'main';
    var _idb = null;  // will hold the open DB connection

    // BroadcastChannel — works cross-origin in the same browser session
    var _geoChannel = null;
    var _geoInstanceId = Math.random().toString(36).slice(2); // unique per tab
    try { _geoChannel = new BroadcastChannel('geoPro_sync'); } catch(e) {}

    // Try reading from localStorage immediately (fast, works when same origin)
    try { saved = JSON.parse(localStorage.getItem(LS_KEY) || '{}'); } catch(e) {}

    // _applySettingsObj is defined after UI is built; placeholder until then
    var _applySettingsObj = null;
    var _settingsFromPeer = false;

    // Open (or create) our IndexedDB on this origin
    function _openIDB(cb) {
        try {
            var req = indexedDB.open(_IDB_NAME, 1);
            req.onupgradeneeded = function(e) {
                e.target.result.createObjectStore(_IDB_STORE);
            };
            req.onsuccess = function(e) { _idb = e.target.result; if(cb) cb(_idb); };
            req.onerror   = function()  { if(cb) cb(null); };
        } catch(e) { if(cb) cb(null); }
    }

    function _idbGet(cb) {
        if(!_idb) { _openIDB(function(db){ if(db) _idbGet(cb); else cb(null); }); return; }
        try {
            var tx = _idb.transaction(_IDB_STORE, 'readonly');
            var req = tx.objectStore(_IDB_STORE).get(_IDB_KEY);
            req.onsuccess = function() { cb(req.result || null); };
            req.onerror   = function() { cb(null); };
        } catch(e) { cb(null); }
    }

    function _idbPut(obj) {
        if(!_idb) { _openIDB(function(db){ if(db) _idbPut(obj); }); return; }
        try {
            var tx = _idb.transaction(_IDB_STORE, 'readwrite');
            tx.objectStore(_IDB_STORE).put(obj, _IDB_KEY);
        } catch(e) {}
    }

    // BroadcastChannel message handler
    if(_geoChannel) {
        _geoChannel.onmessage = function(ev) {
            var msg = ev.data;
            if(!msg) return;
            if(msg._src === _geoInstanceId) return; // ignore own messages
            if(msg.type === 'geoProReqSettings') {
                // Another tab is asking — send them our latest settings
                try {
                    var myS = localStorage.getItem(LS_KEY);
                    if(myS) _geoChannel.postMessage({type:'geoProSettings', data: myS});
                } catch(e) {}
            } else if(msg.type === 'geoProSettings') {
                // Received settings from a peer (response to our request on load)
                if(_settingsFromPeer) return;
                try {
                    var incoming = JSON.parse(msg.data || '{}');
                    _settingsFromPeer = true;
                    // Persist locally so next load on this origin is instant
                    try { localStorage.setItem(LS_KEY, msg.data); } catch(e) {}
                    _idbPut(incoming);
                    if(typeof _applySettingsObj === 'function') _applySettingsObj(incoming);
                } catch(e) {}
            } else if(msg.type === 'geoProUpdate') {
                // Another tab saved settings — mirror here
                try {
                    try { localStorage.setItem(LS_KEY, msg.data); } catch(e) {}
                    var upd = JSON.parse(msg.data || '{}');
                    _idbPut(upd);
                    if(typeof _applySettingsObj === 'function') _applySettingsObj(upd);
                } catch(e) {}
            }
        };
    }

    // On load: open IDB and read saved settings; if empty ask peers via BroadcastChannel
    _openIDB(function(db) {
        _idbGet(function(idbSaved) {
            if(idbSaved && idbSaved.tri) {
                // IDB has settings — merge with what localStorage gave us, prefer IDB
                saved = idbSaved;
                // Also mirror to localStorage for fast access next time
                try { localStorage.setItem(LS_KEY, JSON.stringify(idbSaved)); } catch(e) {}
                if(typeof _applySettingsObj === 'function') _applySettingsObj(saved);
            } else if(!saved || !saved.tri) {
                // Neither IDB nor localStorage has settings — ask other tabs
                if(_geoChannel) _geoChannel.postMessage({type:'geoProReqSettings'});
            }
        });
