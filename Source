        }).join('');
        cfg.inputs.forEach(function(_,i){
            var inp=get('v'+i);
            if(inp) inp.addEventListener('keydown',function(e){
                if(e.key==='Enter'||e.keyCode===13){e.preventDefault();e.stopPropagation();doCalculate(false);}
            },true);
            if(inp) inp.addEventListener('input',function(){
                updateInputUnitBadge(this, this.value);
                if(!getAutoCalc()) return;
                clearTimeout(autoCalcTimer);
                autoCalcTimer = setTimeout(function(){ doCalculate(true); }, 350);
            });
        });
        // ── Restore saved values for inputs whose label matches memory ──
        cfg.inputs.forEach(function(lbl, i) {
            var inp = get('v'+i);
