                var el=get('trigIn_'+k); if(el&&parseFloat(el.value)===360) el.value='';
            });
            _trigDrawDiagram(null);
        }, 4000);
    }

    // ── Space mode ────────────────────────────────────────────────────
    var _spaceModeActive = false;
    var _spaceTwinkTimer = null;
    var _spaceShootTimer = null;
    var _spaceStars      = [];
    var _spaceStarCv     = null;
    var _spaceStarCtx    = null;

    function _spaceUnlock() {
        if(_spaceUnlocked) return;
        _spaceUnlocked = true;
        try { localStorage.setItem('geoPro_spaceUnlocked','1'); } catch(e) {}
        var sl = get('optSpaceLabel');
        if(sl) sl.style.display = 'flex';
    }

    // Called with no args = "space" typed in input → just unlock, show setting, do nothing else
    function _secretSpaceMode() {
        _spaceUnlock();
    }

    function _spaceStartStars() {
        _spaceStopStars();

        // Canvas sized and positioned to exactly cover the panel
        var panelEl = get('geo-ultimate-vscroll');
        if(!panelEl) return;
        var pr = panelEl.getBoundingClientRect();
        var starCv = document.createElement('canvas');
        starCv.id = 'gpStarfield';
        // z-index above panel (10000) but pointer-events:none so clicks pass through
        starCv.style.cssText = 'position:fixed;pointer-events:none;z-index:10001;border-radius:14px;overflow:hidden;';
        starCv.style.left   = pr.left + 'px';
        starCv.style.top    = pr.top  + 'px';
        starCv.style.width  = pr.width + 'px';
        starCv.style.height = pr.height + 'px';
        starCv.width  = Math.round(pr.width);
        starCv.height = Math.round(pr.height);
        document.body.appendChild(starCv);
        _spaceStarCv = starCv;

        var W2 = starCv.width, H2 = starCv.height;
        var sctx = starCv.getContext('2d');
        _spaceStarCtx = sctx;

        // Draw stars (transparent background — panel CSS handles bg colour)
        _spaceStars = [];
        for(var i=0;i<140;i++){
            var sx=Math.random()*W2, sy=Math.random()*H2;
            var sr=0.3+Math.random()*1.4, bright=0.3+Math.random()*0.7;
            _spaceStars.push({x:sx,y:sy,r:sr,b:bright});
            sctx.beginPath(); sctx.arc(sx,sy,sr,0,Math.PI*2);
            sctx.fillStyle='rgba(255,255,255,'+bright+')'; sctx.fill();
        }

        // ── Continuous render loop ──────────────────────────────────────
        // Give each star its animated alpha state
        _spaceStars.forEach(function(s){
            s.cur    = s.b;
            s.target = s.b;
            s.peak   = Math.min(1, s.b + 0.55);
            s.phase  = 'idle'; // idle | up | down
        });

        // Kick off a random twinkle every ~400ms
        var _twinkInterval = setInterval(function(){
            if(!_spaceStarCv){ clearInterval(_twinkInterval); return; }
            var s = _spaceStars[Math.floor(Math.random()*_spaceStars.length)];
            if(s.phase === 'idle'){ s.phase = 'up'; }
        }, 400);
        _spaceTwinkTimer = _twinkInterval; // kept so _spaceStopStars can clear it

        // Shooting stars queue
        var _shooters = [];
        function _spawnShooter(){
            if(!_spaceStarCv) return;
            var angle = Math.PI/6 + Math.random()*Math.PI/4;
            var len   = 60 + Math.random()*80;
            _shooters.push({
                x: Math.random() * W2,
                y: Math.random() * H2,
                vx: Math.cos(angle),
                vy: Math.sin(angle),
                len: len,
                t: 0,
                dur: 600 + Math.random()*500
            });
            _spaceShootTimer = setTimeout(_spawnShooter, 4000 + Math.random()*6000);
        }
        _spaceShootTimer = setTimeout(_spawnShooter, 1200 + Math.random()*2000);

        // Render loop
        var _loopActive = true;
        var _lastFrame  = null;
        function _spaceRenderLoop(now){
            if(!_loopActive || !_spaceStarCv) return;
            var dt = _lastFrame ? Math.min(now - _lastFrame, 50) : 16;
            _lastFrame = now;

            sctx.clearRect(0, 0, W2, H2);

            // Stars
            var twinkSpeed = dt / 200; // 200ms per phase = 400ms full cycle
            _spaceStars.forEach(function(s){
                if(s.phase === 'up'){
                    s.cur = Math.min(s.peak, s.cur + twinkSpeed * (s.peak - s.b + 0.01));
                    if(s.cur >= s.peak - 0.01){ s.cur = s.peak; s.phase = 'down'; }
                } else if(s.phase === 'down'){
                    s.cur = Math.max(s.b, s.cur - twinkSpeed * (s.peak - s.b + 0.01));
                    if(s.cur <= s.b + 0.01){ s.cur = s.b; s.phase = 'idle'; }
                }
                sctx.globalAlpha = s.cur;
                sctx.fillStyle   = '#ffffff';
                sctx.beginPath();
                sctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
                sctx.fill();
            });
            sctx.globalAlpha = 1;

            // Shooting stars
            for(var i = _shooters.length - 1; i >= 0; i--){
                var sh = _shooters[i];
                sh.t = Math.min(1, sh.t + dt / sh.dur);
                // Smooth fade in (0-20%) and fade out (80-100%)
                var fade = sh.t < 0.2 ? sh.t / 0.2
                         : sh.t > 0.8 ? (1 - sh.t) / 0.2
                         : 1;
                // Head position
                var hx = sh.x + sh.vx * sh.len * sh.t;
                var hy = sh.y + sh.vy * sh.len * sh.t;
                // Tail trails 30% behind head
                var tailT = Math.max(0, sh.t - 0.3);
                var tx = sh.x + sh.vx * sh.len * tailT;
                var ty = sh.y + sh.vy * sh.len * tailT;
                // Only draw if head and tail differ
                if(Math.abs(hx - tx) > 0.5 || Math.abs(hy - ty) > 0.5){
                    var grd = sctx.createLinearGradient(tx, ty, hx, hy);
                    grd.addColorStop(0, 'rgba(255,255,255,0)');
                    grd.addColorStop(0.6, 'rgba(255,255,255,'+(fade*0.6).toFixed(3)+')');
                    grd.addColorStop(1, 'rgba(255,255,255,'+fade.toFixed(3)+')');
                    sctx.beginPath();
                    sctx.moveTo(tx, ty);
                    sctx.lineTo(hx, hy);
                    sctx.strokeStyle = grd;
                    sctx.lineWidth   = 1.5;
                    sctx.stroke();
                }
                if(sh.t >= 1) _shooters.splice(i, 1);
            }

            requestAnimationFrame(_spaceRenderLoop);
        }
        requestAnimationFrame(_spaceRenderLoop);

        // Expose stop hook
        _spaceStarCv._stopLoop = function(){ _loopActive = false; };
    }

    function _spaceStopStars() {
        clearInterval(_spaceTwinkTimer);
        clearTimeout(_spaceShootTimer);
        _spaceTwinkTimer=null; _spaceShootTimer=null;
        if(_spaceStarCv && _spaceStarCv._stopLoop) _spaceStarCv._stopLoop();
        var sc2=document.getElementById('gpStarfield'); if(sc2) sc2.remove();
        _spaceStarCv=null; _spaceStarCtx=null; _spaceStars=[];
    }

        // ── Quiz: 10-streak gold trophy ───────────────────────────────────
    // (handled inline in _quizRenderQuestion — already injected above)

    // ── Confetti burst ────────────────────────────────────────────────
    function _secretConfetti() {
        var N = 90;
        var particles = [];
        var colors = ['#1a73e8','#22a05a','#e67e22','#e74c3c','#9b59b6','#f0c040','#1abc9c'];
        for(var i=0;i<N;i++){
            particles.push({
                x: Math.random()*window.innerWidth, y: window.innerHeight+10,
                vx: (Math.random()-0.5)*12,
                vy: -(8 + Math.random()*14),
                r: 4+Math.random()*5,
                col: colors[Math.floor(Math.random()*colors.length)],
                rot: Math.random()*Math.PI*2,
                rv: (Math.random()-0.5)*0.3,
                shape: Math.random()>0.5?'rect':'circle'
            });
        }
        var cv = document.createElement('canvas');
        cv.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999999;';
        cv.width = window.innerWidth; cv.height = window.innerHeight;
        document.body.appendChild(cv);
        var cx = cv.getContext('2d');
        var start = performance.now();
        function confettiFrame(now){
            cx.clearRect(0,0,cv.width,cv.height);
            var alive = false;
            particles.forEach(function(p){
                p.x+=p.vx; p.y+=p.vy; p.vy+=0.38; p.vx*=0.99; p.rot+=p.rv;
                if(p.y<cv.height+20) alive=true;
                cx.save(); cx.translate(p.x,p.y); cx.rotate(p.rot);
                cx.fillStyle=p.col;
                cx.globalAlpha=Math.max(0,1-(now-start)/2200);
                if(p.shape==='rect'){ cx.fillRect(-p.r,-p.r/2,p.r*2,p.r); }
                else{ cx.beginPath(); cx.arc(0,0,p.r,0,Math.PI*2); cx.fill(); }
                cx.restore();
            });
            if(alive&&now-start<2500) requestAnimationFrame(confettiFrame);
            else cv.remove();
        }
        requestAnimationFrame(confettiFrame);
    }

    // ── DVD screensaver (5 min idle) ──────────────────────────────────
    (function(){
        var _idleTimer=null, _dvdActive=false, _dvdAnim=null;
        function _resetIdle(){
            clearTimeout(_idleTimer);
            if(_dvdActive) _stopDVD();
            _idleTimer=setTimeout(_startDVD, 5*60*1000);
        }
        function _startDVD(){
            var c=get('triCanvas'), cb=get('canvasBox');
            if(!c||mode3D||modeTrig){_resetIdle();return;}
            cb.style.display='block';
            var W=c.offsetWidth||c.width||340, H=c.offsetHeight||c.height||210;
            c.width=W; c.height=H;
            _dvdActive=true;
            var r=Math.min(W,H)*0.28;
            var colors=['#1a73e8','#22a05a','#e67e22','#e74c3c','#9b59b6'];
            var col=colors[0],colIdx=0,px=W/2,py=H/2,vx=1.4,vy=1.1;
            var ctx2=c.getContext('2d'),d=getDark(),bw=getBW();
            function dvdFrame(){
                var bg=bw?'#fff':(d?'#181828':'#fafbff');
                ctx2.fillStyle=bg; ctx2.fillRect(0,0,W,H);
                px+=vx; py+=vy;
                var bounced=false;
                if(px-r<0){px=r;vx=Math.abs(vx);bounced=true;}
                if(px+r>W){px=W-r;vx=-Math.abs(vx);bounced=true;}
                if(py-r<0){py=r;vy=Math.abs(vy);bounced=true;}
                if(py+r>H){py=H-r;vy=-Math.abs(vy);bounced=true;}
                if(bounced){colIdx=(colIdx+1)%colors.length;col=colors[colIdx];}
                ctx2.save(); ctx2.translate(px,py);
                ctx2.strokeStyle=col; ctx2.lineWidth=2.5;
                ctx2.beginPath();
                for(var i=0;i<3;i++){
                    var a=i*2*Math.PI/3-Math.PI/2;
                    if(i===0) ctx2.moveTo(Math.cos(a)*r,Math.sin(a)*r);
                    else ctx2.lineTo(Math.cos(a)*r,Math.sin(a)*r);
                }
                ctx2.closePath(); ctx2.stroke(); ctx2.restore();
                _dvdAnim=requestAnimationFrame(dvdFrame);
            }
            dvdFrame();
        }
        function _stopDVD(){
            _dvdActive=false;
            cancelAnimationFrame(_dvdAnim);
            // Restore last diagram
            var c=get('triCanvas');
            if(c&&lastCalcResult){
                drawTri(lastCalcResult.s1,lastCalcResult.h,lastCalcResult.b,lastCalcResult.s2,
                    lastCalcResult.isExt,lastCalcResult.anglesForCanvas,lastCalcResult.goal);
            } else if(c){
                var ctx2=c.getContext('2d'),d=getDark(),bw=getBW();
                ctx2.fillStyle=bw?'#fff':(d?'#181828':'#fafbff');
                ctx2.fillRect(0,0,c.width,c.height);
            }
        }
        ['mousemove','mousedown','keydown','touchstart','scroll'].forEach(function(ev){
            document.addEventListener(ev,_resetIdle,{passive:true});
        });
        _resetIdle();
    })();

