    function drawTri(s1, h, b, s2, isExt) {
        var W = canvas.width, H = canvas.height;
        ctx.clearRect(0, 0, W, H);
        var raw;

        if (currentTri === 'equilateral') {
            raw = [[0,h],[b/2,0],[b,h]];
        } else if (currentTri === 'isosceles') {
            raw = [[0,h],[b/2,0],[b,h]];
        } else if (currentTri === 'right') {
            // right angle at bottom-left: vertical leg up, horizontal leg right
            raw = [[0,h],[0,0],[b,h]];
        } else {
            // scalene: compute apex x from s1 and h
            var ax = Math.sqrt(Math.max(0, s1*s1 - h*h));
            raw = isExt ? [[0,h],[ax,0],[Math.abs(ax-b),h]] : [[0,h],[ax,0],[b,h]];
        }

        var pad = 44;
        var minX=raw[0][0], maxX=raw[0][0];
        for(var i=1;i<3;i++){if(raw[i][0]<minX)minX=raw[i][0];if(raw[i][0]>maxX)maxX=raw[i][0];}
        var rangeX = maxX - minX || 1, rangeY = h || 1;
        var scale = Math.min((W-pad*2)/rangeX, (H-pad*2)/rangeY);
        var offX = (W - rangeX*scale)/2 - minX*scale;
        var offY = (H - rangeY*scale)/2;
        function tr(pt){return[pt[0]*scale+offX, pt[1]*scale+offY];}
        var pA=tr(raw[0]), pB=tr(raw[1]), pC=tr(raw[2]);
        var pH=[pB[0],pA[1]]; // altitude foot on base

        // fill
        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();
        ctx.fillStyle='rgba(26,115,232,0.07)';ctx.fill();

        // Equal-side tick marks
        function tick(ax,ay,bx,by,n){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len*5,ny=dx/len*5,gap=4;
            ctx.strokeStyle='#1a73e8';ctx.lineWidth=1.5;
            for(var t=0;t<n;t++){var o=(t-(n-1)/2)*gap,ox=dx/len*o,oy=dy/len*o;ctx.beginPath();ctx.moveTo(mx+ox-nx,my+oy-ny);ctx.lineTo(mx+ox+nx,my+oy+ny);ctx.stroke();}
        }
        if(currentTri==='equilateral'){tick(pA[0],pA[1],pB[0],pB[1],2);tick(pB[0],pB[1],pC[0],pC[1],2);tick(pA[0],pA[1],pC[0],pC[1],2);}
        else if(currentTri==='isosceles'){tick(pA[0],pA[1],pB[0],pB[1],1);tick(pB[0],pB[1],pC[0],pC[1],1);}

        // triangle outline
        ctx.strokeStyle='#1a73e8';ctx.lineWidth=2.5;ctx.lineJoin='round';
        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();ctx.stroke();

        // Right angle box
        if(currentTri==='right'){
            var sq=7;ctx.strokeStyle='#888';ctx.lineWidth=1.2;
            ctx.strokeRect(pA[0],pA[1]-sq,sq,sq);
        }

        // Scalene: detect if altitude falls on a side (right angle at base corner)
        var altOnLeft=false, altOnRight=false;
        if(currentTri==='scalene'){
            var eps=0.002*scale;
            altOnLeft  = Math.abs(pB[0]-pA[0])<eps;
            altOnRight = Math.abs(pB[0]-pC[0])<eps;
        }

        // Dashed altitude line
        var drawAlt = (currentTri==='isosceles'||currentTri==='equilateral'||
                      (currentTri==='scalene'&&!altOnLeft&&!altOnRight));
        if(drawAlt){
            ctx.setLineDash([4,4]);ctx.lineWidth=1.5;ctx.strokeStyle='#aaa';
            ctx.beginPath();ctx.moveTo(pB[0],pB[1]);ctx.lineTo(pH[0],pH[1]);ctx.stroke();
            ctx.setLineDash([]);
            var sq2=6;ctx.strokeStyle='#aaa';ctx.lineWidth=1;
            ctx.strokeRect(pH[0],pH[1],sq2,sq2);
        } else if(currentTri==='scalene'&&altOnLeft){
            ctx.strokeStyle='#aaa';ctx.lineWidth=1;ctx.strokeRect(pA[0],pA[1],6,-6);
        } else if(currentTri==='scalene'&&altOnRight){
            ctx.strokeStyle='#aaa';ctx.lineWidth=1;ctx.strokeRect(pC[0]-6,pC[1],6,-6);
        }

        // Labels
        ctx.fillStyle='#1a73e8';ctx.font='bold 11px system-ui';ctx.textAlign='center';ctx.textBaseline='middle';
        var OUT=14, adv=getAdv(), hLbl=adv?'alt=':'h=';

        function labelSide(ax,ay,bx,by,lbl){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var cx=(pA[0]+pB[0]+pC[0])/3,cy=(pA[1]+pB[1]+pC[1])/3;
            var nx=-dy/len,ny=dx/len;
            if((mx+nx-cx)*nx+(my+ny-cy)*ny<0){nx=-nx;ny=-ny;}
            ctx.fillText(lbl,mx+nx*OUT,my+ny*OUT);
        }

        function altLabel(hVal){
            var hmy=(pB[1]+pH[1])/2;
            if(W-pH[0]>=pH[0]){ctx.textAlign='left';ctx.fillText(hLbl+hVal,pH[0]+8,hmy);}
            else{ctx.textAlign='right';ctx.fillText(hLbl+hVal,pH[0]-8,hmy);}
        }

        var s1L=fmt(s1),s2L=fmt(s2),bL=fmt(b),hL=fmt(h);

        if(currentTri==='equilateral'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],s1L);
            altLabel(hL);
        } else if(currentTri==='isosceles'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            altLabel(hL);
        } else if(currentTri==='right'){
            // s1=vertical leg, b=horizontal leg, s2=hypotenuse
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L);
        } else {
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            if(!altOnLeft&&!altOnRight) altLabel(hL);
        }
    }

    // ── Calculate ─────────────────────────────────────────────────────────────
    get('calc').onclick = function() {
        clearError();
        var list = getMethodList();
        if(!list.length){showError('Not available','No formula for this combination.');return;}
        var cfg = list[Math.min(currentMethod,list.length-1)];
        var vals=[], missing=[];
        cfg.inputs.forEach(function(lbl,i){
            var el=get('v'+i), v=el?parseFloat(el.value):NaN;
            vals.push(v);
            if(isNaN(v)||!el||el.value.trim()==='') missing.push(lbl);
        });
        if(missing.length){showError('Missing values','Please fill in: '+missing.join(', ')+'.');return;}
        for(var j=0;j<vals.length;j++) if(vals[j]<=0){showError('Values must be positive',cfg.inputs[j]+' must be greater than zero.');return;}

        var v0=vals[0], v1=vals.length>1?vals[1]:NaN, v2=vals.length>2?vals[2]:NaN;
        var p=getPrec(), useSurd=getSurd();
        var posEl=ui.querySelector('input[name="geopro_pos"]:checked');
        var isExt=posEl?posEl.value==='ext':false;
        var type=cfg.id;
        var res, area, perim, formula, s1, h, b, s2;

        try{
        // ─ Scalene ─────────────────────────────────────────────────────────
        if(type==='sc_b_shs'){
            s1=v0;h=v1;s2=v2;
            if(h>=s1){showError('Impossible','Height must be less than Side 1.');return;}
            if(h>=s2){showError('Impossible','Height must be less than Side 2.');return;}
            var xA=Math.sqrt(s1*s1-h*h),xB=Math.sqrt(s2*s2-h*h);
            res=isExt?Math.abs(xA-xB):(xA+xB); b=res;
            formula='Part1 = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xA)+
                    '\nPart2 = \u221a('+s2+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xB)+
                    '\nBase = '+fmtS(xA)+(isExt?' \u2212 ':' + ')+fmtS(xB)+' = '+fmtS(res);
        }else if(type==='sc_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Base = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='sc_s_shb'){
            s1=v0;h=v1;b=v2;
            if(h>=s1){showError('Impossible','Height must be less than Known Side.');return;}
            var xxS=Math.sqrt(s1*s1-h*h);
            if(isExt){
                if(xxS<=b){showError('Impossible','Side\'s horizontal reach ('+fmtS(xxS)+') must exceed base.');return;}
                res=Math.sqrt(b*b+h*h);s2=res;
                formula='Reach = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xxS)+'\nSide 2 = \u221a('+b+'\u00b2 + '+h+'\u00b2) = '+fmtS(res);
            }else{
                var yS=Math.abs(b-xxS);
                res=Math.sqrt(yS*yS+h*h);s2=res;
                formula='Reach = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xxS)+'\nSeg = |'+b+' \u2212 '+fmtS(xxS)+'| = '+fmtS(yS)+'\nSide 2 = \u221a('+fmtS(yS)+'\u00b2 + '+h+'\u00b2) = '+fmtS(res);
            }
        }else if(type==='sc_s_hb'){
            h=v0;b=v1;res=Math.sqrt(h*h+b*b);s1=res;s2=res;
            formula='Side = \u221a(h\u00b2 + seg\u00b2)\n= \u221a('+h+'\u00b2 + '+b+'\u00b2) = '+fmtS(res);
        }else if(type==='sc_h_ab'){
            res=(2*v0)/v1;h=res;b=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Height = (2 \u00d7 Area) / Base\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='sc_h_ssb'){
            s1=v0;s2=v1;b=v2;
            if(b/2>=s1){showError('Impossible','Base is too wide for Side 1.');return;}
            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(S1\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        // ─ Isosceles ───────────────────────────────────────────────────────
        }else if(type==='is_b_sh'){
            s1=v0;h=v1;s2=v0;
            if(h>=s1){showError('Impossible','Height must be less than Leg.');return;}
            var hfI=Math.sqrt(s1*s1-h*h);
            res=2*hfI;b=res;
            formula='Half-base = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(hfI)+'\nBase = 2 \u00d7 '+fmtS(hfI)+' = '+fmtS(res);
        }else if(type==='is_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Base = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='is_b_al'){
            // A=0.5*b*sqrt(s^2-(b/2)^2) => b^4/4 - b^2*s^2 + 4A^2 = 0 => let u=b^2
            // u = 2s^2 - sqrt(4s^4-16A^2)  (smaller root = real base)
            var Ai=v0,Si=v1;
            var inner=4*Si*Si*Si*Si-16*Ai*Ai;
            if(inner<0){showError('Impossible','Area too large for that leg.');return;}
            var u=2*Si*Si-Math.sqrt(inner);
            if(u<=0){showError('Impossible','No valid solution.');return;}
            res=Math.sqrt(u);b=res;s1=Si;s2=Si;h=(2*Ai)/b;
            formula='b\u00b2 = 2s\u00b2 \u2212 \u221a(4s\u2074\u22124A\u00b2)\nBase = \u221a'+fmtS(res)+' (approx)';
        }else if(type==='is_s_bh'){
            b=v0;h=v1;res=Math.sqrt(h*h+(b/2)*(b/2));s1=res;s2=res;
            formula='Leg = \u221a(h\u00b2 + (b/2)\u00b2)\n= \u221a('+h+'\u00b2 + '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='is_s_ab'){
            var Ais=v0,bis=v1;h=(2*Ais)/bis;res=Math.sqrt(h*h+(bis/2)*(bis/2));s1=res;s2=res;b=bis;
            formula='h = 2A/b = '+fmtS(h)+'\nLeg = \u221a(h\u00b2+(b/2)\u00b2) = '+fmtS(res);
        }else if(type==='is_h_bl'){
            b=v0;s1=v1;s2=v1;
            if(b/2>=s1){showError('Impossible','Base too wide for Leg.');return;}
            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(Leg\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='is_h_ab'){
            res=(2*v0)/v1;h=res;b=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Height = (2 \u00d7 Area) / Base\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        // ─ Equilateral ─────────────────────────────────────────────────────
        }else if(type==='eq_h_s'){
            var side=v0;b=side;s1=side;s2=side;
            h=Math.sqrt(3)/2*side;
            if(currentGoal==='height'){res=h;}else{res=side;}
            formula='Height = (\u221a3 / 2) \u00d7 '+side+(useSurd?' = '+fmtS(h):' \u2248 '+h.toFixed(p));
        }else if(type==='eq_b_ah'){
            // A = sqrt(3)/4 * b^2 => b = 2*sqrt(A/sqrt(3)*2) = 2*sqrt(2A/sqrt(3))
            var beq=2*Math.sqrt(v0/(Math.sqrt(3)/2));
            // from A=0.5*beq*v1 check consistency — use side formula
            // Actually just use A=(sqrt(3)/4)*b^2 => b=2*sqrt(A/sqrt(3)*2)
            beq=Math.sqrt(4*v0/Math.sqrt(3));
            res=beq;b=beq;s1=beq;s2=beq;h=Math.sqrt(3)/2*beq;
            formula='A = (\u221a3/4) \u00d7 b\u00b2\nb = \u221a(4A / \u221a3) = '+fmtS(res);
        // ─ Right ───────────────────────────────────────────────────────────
        }else if(type==='rt_c_ll'){
            s1=v0;b=v1;res=Math.sqrt(s1*s1+b*b);s2=res;h=s1;
            formula='c = \u221a(a\u00b2 + b\u00b2)\n= \u221a('+s1+'\u00b2 + '+b+'\u00b2)\n= \u221a'+(s1*s1+b*b)+' = '+fmtS(res);
        }else if(type==='rt_c_al'){
            var legA=v1;h=(2*v0)/legA;res=Math.sqrt(legA*legA+h*h);s1=h;b=legA;s2=res;
            formula='Other leg = (2A)/known = '+fmtS(h)+'\nc = \u221a('+legA+'\u00b2 + '+fmtS(h)+'\u00b2) = '+fmtS(res);
        }else if(type==='rt_l_cl'){
            var hyp=v0,oLeg=v1;
            if(oLeg>=hyp){showError('Impossible','Leg must be shorter than hypotenuse.');return;}
            res=Math.sqrt(hyp*hyp-oLeg*oLeg);s1=res;b=oLeg;s2=hyp;h=res;
            formula='Leg = \u221a(c\u00b2 \u2212 b\u00b2)\n= \u221a('+hyp+'\u00b2 \u2212 '+oLeg+'\u00b2)\n= \u221a'+(hyp*hyp-oLeg*oLeg)+' = '+fmtS(res);
        }else if(type==='rt_l_ac'){
            var hypR=v1;res=(2*v0)/hypR;s1=res;h=res;
            b=Math.sqrt(Math.max(0,hypR*hypR-res*res));s2=hypR;
            formula='Leg = (2A) / c = (2 \u00d7 '+v0+') / '+hypR+' = '+fmtS(res);
        }else if(type==='rt_h_ll'){
            s1=v0;b=v1;var hyp2=Math.sqrt(s1*s1+b*b);
            res=(s1*b)/hyp2;h=res;s2=hyp2;
            formula='Altitude = (a \u00d7 b) / c\n= ('+s1+' \u00d7 '+b+') / \u221a'+(s1*s1+b*b)+' = '+fmtS(res);
        }else if(type==='rt_h_ac'){
            var hypH=v1;res=(2*v0)/hypH;h=res;
            s1=Math.sqrt(Math.max(0,hypH*hypH/4+Math.sqrt(Math.max(0,(hypH*hypH/4)*(hypH*hypH/4)-h*h*hypH*hypH/4))));
            b=Math.sqrt(Math.max(0,hypH*hypH-s1*s1));s2=hypH;
            formula='Altitude = (2A) / c = (2 \u00d7 '+v0+') / '+hypH+' = '+fmtS(res);
        }else if(type==='rt_b_cl'){
            var hypB=v0,legB=v1;
            if(legB>=hypB){showError('Impossible','Leg must be shorter than hypotenuse.');return;}
            res=Math.sqrt(hypB*hypB-legB*legB);b=res;s1=legB;s2=hypB;h=legB;
            formula='Base = \u221a(c\u00b2 \u2212 leg\u00b2)\n= \u221a('+hypB+'\u00b2 \u2212 '+legB+'\u00b2)\n= \u221a'+(hypB*hypB-legB*legB)+' = '+fmtS(res);
        }else if(type==='rt_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=h;s2=Math.sqrt(h*h+b*b);
            formula='Base = (2A) / height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }
        }catch(e){showError('Calculation error','Double-check your values form a valid triangle.');return;}

        if(isNaN(res)||res<=0||!isFinite(res)){showError('No solution','These values don\'t form a valid triangle.');return;}
        if(!s1||isNaN(s1))s1=res; if(!s2||isNaN(s2))s2=res;
        if(!b||isNaN(b))b=res;   if(!h||isNaN(h))h=res;

        area=0.5*b*h; perim=s1+s2+b;
        get('res').style.display='block';

        // Display result with surd
        var approxEl=get('finalApprox');
        if(useSurd){
            var ss=toSurdStr(res);
            if(ss){get('final').innerText=ss;approxEl.innerText='\u2248 '+res.toFixed(p);approxEl.style.display='block';}
            else{get('final').innerText=fmt(res);approxEl.style.display='none';}
        }else{
            get('final').innerText=res.toFixed(p);approxEl.style.display='none';
        }
        get('formulaText').innerText=formula||'';
        get('areaRes').innerText=area.toFixed(p);
        get('perimRes').innerText=perim.toFixed(p);

        // Draw canvas
        if(currentTri==='right'){
            // s1=vertical leg, b=horizontal leg, s2=hypotenuse; h=s1 for drawTri
            drawTri(s1, s1, b, s2, false);
        }else{
            drawTri(s1, h, b, s2, isExt);
        }

        var adv=getAdv();
        var gLbl=((adv?goalLabel.a:goalLabel.s)[currentGoal])||currentGoal;
        // Store full state so left-arrow can restore it
        var inputVals=[];
        cfg.inputs.forEach(function(_,i){var el=get('v'+i);inputVals.push(el?el.value:'');});
        history.unshift({
            label: gLbl+': '+get('final').innerText,
            tri: currentTri, goal: currentGoal, method: currentMethod,
            inputs: inputVals, isExt: isExt,
            // result display state
            finalText: get('final').innerText,
            approxText: approxEl.innerText, approxVis: approxEl.style.display,
            formula: formula||'', area: area.toFixed(p), perim: perim.toFixed(p),
            // draw params
            ds1: currentTri==='right'?s1:s1, dh: currentTri==='right'?s1:h, db: b, ds2: s2
        });
        if(history.length>10)history.pop();
        get('histList').innerHTML=history.map(function(hh){return'<span style="display:block;padding:3px 0;border-bottom:1px solid #f0f0f0;">'+(hh.label||hh)+'</span>';}).join('');
        saveSettings();
    };

