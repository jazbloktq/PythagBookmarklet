    function drawTri(s1, h, b, s2, isExt, anglesData) {
        var W=canvas.width, H=canvas.height;
        ctx.clearRect(0,0,W,H);
        var d=getDark();
        var triCol=d?'#4a9eff':'#1a73e8';
        var raw;
        if(currentTri==='equilateral'||currentTri==='isosceles') raw=[[0,h],[b/2,0],[b,h]];
        else if(currentTri==='right') raw=[[0,h],[0,0],[b,h]];
        else { var ax=Math.sqrt(Math.max(0,s1*s1-h*h)); raw=isExt?[[0,h],[ax,0],[Math.abs(ax-b),h]]:[[0,h],[ax,0],[b,h]]; }

        var padT=38, padB=52, padL=52, padR=52;
        var minX=raw[0][0],maxX=raw[0][0];
        for(var i=1;i<3;i++){if(raw[i][0]<minX)minX=raw[i][0];if(raw[i][0]>maxX)maxX=raw[i][0];}
        var rangeX=maxX-minX||1, rangeY=h||1;
        var scale=Math.min((W-padL-padR)/rangeX,(H-padT-padB)/rangeY);
        var offX=(W-rangeX*scale)/2-minX*scale, offY=padT+(H-padT-padB-rangeY*scale)/2;
        function tr(pt){return[pt[0]*scale+offX,pt[1]*scale+offY];}
        var pA=tr(raw[0]),pB=tr(raw[1]),pC=tr(raw[2]);
        var pH=[pB[0],pA[1]];

        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();
        ctx.fillStyle=d?'rgba(74,158,255,0.08)':'rgba(26,115,232,0.07)';ctx.fill();

        function tick(ax,ay,bx,by,n){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len*5,ny=dx/len*5,gap=4;
            ctx.strokeStyle=triCol;ctx.lineWidth=1.5;
            for(var t=0;t<n;t++){var o=(t-(n-1)/2)*gap,ox=dx/len*o,oy=dy/len*o;ctx.beginPath();ctx.moveTo(mx+ox-nx,my+oy-ny);ctx.lineTo(mx+ox+nx,my+oy+ny);ctx.stroke();}
        }
        if(currentTri==='equilateral'){tick(pA[0],pA[1],pB[0],pB[1],2);tick(pB[0],pB[1],pC[0],pC[1],2);tick(pA[0],pA[1],pC[0],pC[1],2);}
        else if(currentTri==='isosceles'){tick(pA[0],pA[1],pB[0],pB[1],1);tick(pB[0],pB[1],pC[0],pC[1],1);}

        ctx.strokeStyle=triCol;ctx.lineWidth=2.5;ctx.lineJoin='round';
        ctx.beginPath();ctx.moveTo(pA[0],pA[1]);ctx.lineTo(pB[0],pB[1]);ctx.lineTo(pC[0],pC[1]);ctx.closePath();ctx.stroke();

        if(currentTri==='right'){var sq=7;ctx.strokeStyle=d?'#888':'#888';ctx.lineWidth=1.2;ctx.strokeRect(pA[0],pA[1]-sq,sq,sq);}

        var altOnLeft=false,altOnRight=false;
        if(currentTri==='scalene'){var eps=0.002*scale;altOnLeft=Math.abs(pB[0]-pA[0])<eps;altOnRight=Math.abs(pB[0]-pC[0])<eps;}
        var drawAlt=(currentTri==='isosceles'||currentTri==='equilateral'||(currentTri==='scalene'&&!altOnLeft&&!altOnRight));
        if(drawAlt){
            ctx.setLineDash([4,4]);ctx.lineWidth=1.5;ctx.strokeStyle=d?'#555':'#aaa';
            ctx.beginPath();ctx.moveTo(pB[0],pB[1]);ctx.lineTo(pH[0],pH[1]);ctx.stroke();ctx.setLineDash([]);
            var sq2=6;ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;
            ctx.strokeRect(pH[0], pH[1]-sq2, sq2, sq2);
        } else if(currentTri==='scalene'&&altOnLeft){
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;ctx.strokeRect(pA[0],pA[1],6,-6);
        } else if(currentTri==='scalene'&&altOnRight){
            ctx.strokeStyle=d?'#555':'#aaa';ctx.lineWidth=1;ctx.strokeRect(pC[0]-6,pC[1],6,-6);
        }

        if(anglesData){
            var verts=[[pA,anglesData[0]],[pB,anglesData[1]],[pC,anglesData[2]]];
            var otherVerts=[[pB,pC],[pA,pC],[pA,pB]];
            var arcColor = d ? '#4a9eff' : '#4a90d0';
            verts.forEach(function(vinfo,vi){
                var vp=vinfo[0], ang=vinfo[1];
                if(currentTri==='right'&&vi===0&&Math.abs(ang-Math.PI/2)<0.01) return;
                var o1=otherVerts[vi][0], o2=otherVerts[vi][1];
                var d1x=o1[0]-vp[0],d1y=o1[1]-vp[1];
                var d2x=o2[0]-vp[0],d2y=o2[1]-vp[1];
                var a1=Math.atan2(d1y,d1x), a2=Math.atan2(d2y,d2x);
                var r=13;
                ctx.beginPath();
                var diff=a2-a1;
                while(diff> Math.PI) diff-=2*Math.PI;
                while(diff<-Math.PI) diff+=2*Math.PI;
                ctx.arc(vp[0],vp[1],r,a1,a1+diff,diff<0);
                ctx.strokeStyle=arcColor;ctx.lineWidth=1.2;ctx.stroke();

                var midA=a1+diff/2;
                var labelR=r+18;
                var lx=vp[0]+Math.cos(midA)*labelR, ly=vp[1]+Math.sin(midA)*labelR;
                var labelText=fmtAngle(ang);
                ctx.font='bold 9px system-ui';
                var tw=ctx.measureText(labelText).width;
                var ph=12, pw=tw+8;
                lx=Math.max(pw/2+2, Math.min(W-pw/2-2, lx));
                ly=Math.max(ph/2+2, Math.min(H-ph/2-2, ly));
                var bgCol = d ? '#1e1e2e' : '#fff';
                var bdCol = d ? '#4a9eff' : '#4a90d0';
                ctx.beginPath();
                if(ctx.roundRect){
                    ctx.roundRect(lx-pw/2, ly-ph/2, pw, ph, 4);
                } else {
                    ctx.moveTo(lx-pw/2+4,ly-ph/2);ctx.lineTo(lx+pw/2-4,ly-ph/2);
                    ctx.quadraticCurveTo(lx+pw/2,ly-ph/2,lx+pw/2,ly-ph/2+4);
                    ctx.lineTo(lx+pw/2,ly+ph/2-4);
                    ctx.quadraticCurveTo(lx+pw/2,ly+ph/2,lx+pw/2-4,ly+ph/2);
                    ctx.lineTo(lx-pw/2+4,ly+ph/2);
                    ctx.quadraticCurveTo(lx-pw/2,ly+ph/2,lx-pw/2,ly+ph/2-4);
                    ctx.lineTo(lx-pw/2,ly-ph/2+4);
                    ctx.quadraticCurveTo(lx-pw/2,ly-ph/2,lx-pw/2+4,ly-ph/2);
                    ctx.closePath();
                }
                ctx.fillStyle=bgCol; ctx.fill();
                ctx.strokeStyle=bdCol; ctx.lineWidth=0.8; ctx.stroke();
                ctx.fillStyle=d ? '#4a9eff' : '#1a73e8';
                ctx.textAlign='center'; ctx.textBaseline='middle';
                ctx.fillText(labelText, lx, ly);
            });
        }

        ctx.fillStyle=triCol;ctx.font='bold 11px system-ui';ctx.textAlign='center';ctx.textBaseline='middle';
        var OUT=16, adv=getAdv(), hLbl=adv?'alt=':'h=';
        var cx=(pA[0]+pB[0]+pC[0])/3, cy=(pA[1]+pB[1]+pC[1])/3;
        function labelSide(ax,ay,bx,by,lbl){
            var mx=(ax+bx)/2,my=(ay+by)/2,dx=bx-ax,dy=by-ay,len=Math.sqrt(dx*dx+dy*dy)||1;
            var nx=-dy/len,ny=dx/len;
            if((mx+nx-cx)*nx+(my+ny-cy)*ny<0){nx=-nx;ny=-ny;}
            var lx2=mx+nx*OUT, ly2=my+ny*OUT;
            lx2=Math.max(8,Math.min(W-8,lx2)); ly2=Math.max(8,Math.min(H-8,ly2));
            ctx.fillText(lbl,lx2,ly2);
        }
        function altLabel(hVal){
            var hmy=(pB[1]+pH[1])/2;
            var margin=8;
            if(pH[0]+margin+30 < W){ctx.textAlign='left';ctx.fillText(hLbl+hVal,pH[0]+margin,hmy);}
            else{ctx.textAlign='right';ctx.fillText(hLbl+hVal,pH[0]-margin,hmy);}
        }
        var s1L=fmt(s1),s2L=fmt(s2),bL=fmt(b),hL=fmt(h);
        if(currentTri==='equilateral'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],s1L);
            altLabel(hL);
        } else if(currentTri==='isosceles'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            altLabel(hL);
        } else if(currentTri==='right'){
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L);
        } else {
            labelSide(pA[0],pA[1],pB[0],pB[1],s1L);
            labelSide(pB[0],pB[1],pC[0],pC[1],s2L);
            labelSide(pA[0],pA[1],pC[0],pC[1],bL);
            if(!altOnLeft&&!altOnRight) altLabel(hL);
        }
    }

    // ── Core calculation — silent=true suppresses error toasts (used by auto-calc) ──
    function doCalculate(silent) {
        if(!silent) clearError();
        var list=getMethodList();
        if(!list.length){if(!silent)showError('Not available','No formula for this combination.');return;}
        var cfg=list[Math.min(currentMethod,list.length-1)];
        var vals=[],missing=[];
        cfg.inputs.forEach(function(lbl,i){
            var el=get('v'+i),v=el?parseFloat(el.value):NaN;
            vals.push(v);
            if(isNaN(v)||!el||el.value.trim()==='') missing.push(lbl);
        });
        if(missing.length){if(!silent)showError('Missing values','Please fill in: '+missing.join(', ')+'.');return;}
        for(var j=0;j<vals.length;j++) if(vals[j]<=0){if(!silent)showError('Values must be positive',cfg.inputs[j]+' must be greater than zero.');return;}

        var v0=vals[0],v1=vals.length>1?vals[1]:NaN,v2=vals.length>2?vals[2]:NaN;
        var p=getPrec(),useSurd=getSurd();
        var posEl=ui.querySelector('input[name="geopro_pos"]:checked');
        var isExt=posEl?posEl.value==='ext':false;
        var type=cfg.id;
        var res,area,perim,formula,s1,h,b,s2;

        if(type==='rt_triple_check'){
            var legA=v0, legB=v1, hypIn=v2;
            if(hypIn<=legA||hypIn<=legB){if(!silent)showError('Check your values','Hypotenuse must be larger than both legs.');return;}
            var lhs=legA*legA+legB*legB, rhs=hypIn*hypIn;
            var isRightTri=Math.abs(lhs-rhs)/rhs<0.001;
            if(!isRightTri){
                if(!silent)showError('Not a right triangle','These sides do not satisfy a\u00b2 + b\u00b2 = c\u00b2.\n'+
                    legA+'\u00b2 + '+legB+'\u00b2 = '+lhs.toFixed(4)+'\n'+
                    hypIn+'\u00b2 = '+rhs.toFixed(4)+'\nCheck your values.');
                return;
            }
            var td=checkTripleDetail(legA,legB,hypIn);
            s1=legA; b=legB; s2=hypIn; h=legA;
            area=0.5*legA*legB; perim=legA+legB+hypIn;

            var lhsStr=legA+'\u00b2 + '+legB+'\u00b2 = '+Math.round(lhs);
            var rhsStr=hypIn+'\u00b2 = '+Math.round(rhs);
            var formulaLines=[];
            formulaLines.push('Step 1 \u2014 Check a\u00b2 + b\u00b2 = c\u00b2:');
            formulaLines.push('  '+lhsStr);
            formulaLines.push('  '+rhsStr);
            formulaLines.push('  \u2713 Valid right triangle');
            formulaLines.push('');
            formulaLines.push('Step 2 \u2014 Integer requirement:');
            if(!td.allIntegers){
                formulaLines.push('  \u2715 Not all sides are whole numbers.');
                formulaLines.push('  ('+legA+', '+legB+', '+hypIn+') \u2014 not a Pythagorean triple.');
                formula=formulaLines.join('\n');
                get('tripleBox').innerHTML='\u2715 Not a Pythagorean triple \u2014 sides must be whole numbers';
                get('tripleBox').style.display='block';
                res=hypIn;
            } else {
                formulaLines.push('  \u2713 All sides are integers: ('+td.Ar+', '+td.Br+', '+td.Cr+')');
                formulaLines.push('');
                formulaLines.push('Step 3 \u2014 Find primitive triple (divide by GCD):');
                var g=td.scale;
                formulaLines.push('  GCD('+td.Ar+', '+td.Br+', '+td.Cr+') = '+g);
                formulaLines.push('  Primitive: ('+td.Ar+'/'+g+', '+td.Br+'/'+g+', '+td.Cr+'/'+g+') = ('+td.pa+', '+td.pb+', '+td.pc+')');
                formulaLines.push('  Check: '+td.pa+'\u00b2+'+td.pb+'\u00b2 = '+(td.pa*td.pa+td.pb*td.pb)+' = '+td.pc+'\u00b2 \u2713');
                formulaLines.push('');
                if(td.isPrimitive){
                    formulaLines.push('Step 4 \u2014 Primitive check (GCD of triple = 1):');
                    formulaLines.push('  GCD('+td.pa+', '+td.pb+', '+td.pc+') = 1 \u2713 Primitive triple');
                    var tripleLabel=td.pa+'-'+td.pb+'-'+td.pc;
                    formula=formulaLines.join('\n');
                    get('tripleBox').innerHTML='\u2605 Primitive Pythagorean triple: ('+td.pa+', '+td.pb+', '+td.pc+')';
                    get('tripleBox').style.display='block';
                    res=hypIn; get('final').innerText=tripleLabel;
                } else {
                    formulaLines.push('Step 4 \u2014 Primitive check:');
                    formulaLines.push('  GCD('+td.Ar+', '+td.Br+', '+td.Cr+') = '+g+' \u2260 1');
                    formulaLines.push('  \u2192 Non-primitive triple: ('+td.pa+', '+td.pb+', '+td.pc+') \u00d7 '+g);
                    formulaLines.push('  Scaling rule: k\u00d7('+td.pa+','+td.pb+','+td.pc+') \u2192 ('+td.Ar+','+td.Br+','+td.Cr+')');
                    var tripleLabel=(td.pa+'-'+td.pb+'-'+td.pc)+' \u00d7'+g;
                    formula=formulaLines.join('\n');
                    get('tripleBox').innerHTML='\u2605 Non-primitive triple: ('+td.Ar+', '+td.Br+', '+td.Cr+') = '+g+'\u00d7('+td.pa+', '+td.pb+', '+td.pc+')';
                    get('tripleBox').style.display='block';
                    res=hypIn; get('final').innerText=tripleLabel;
                }
            }

            var angArr=computeAngles(s1,b,s2);
            var anglesForCanvas=[angArr[2],angArr[1],angArr[0]];
            get('res').style.display='block';
            if(!td.allIntegers || !td.isTriple) get('final').innerText='Not a triple';
            get('finalApprox').style.display='none';
            get('formulaText').innerText=formula;
            get('areaRes').innerText=area.toFixed(p);
            get('perimRes').innerText=perim.toFixed(p);
            var classTag=get('classTag');
            classTag.innerText='Right'; classTag.style.display='inline-block';
            var anglesContent=get('anglesContent'); anglesContent.innerHTML='';
            var names=['A','B','C']; var d2=getDark();
            angArr.forEach(function(ang,i){
                var sp=document.createElement('span');
                sp.style.cssText='font-weight:600;color:'+(d2?'#4a9eff':'#1a73e8')+';';
                sp.innerText=names[i]+' = '+fmtAngle(ang);
                anglesContent.appendChild(sp);
            });
            get('anglesBox').style.display='block';
            drawTri(s1,h,b,s2,false,anglesForCanvas);
            applyDark();
            applyDiagramVisibility();
            applyResultVisibility();
            if(!silent){
                var finalLabel=get('final').innerText;
                history.unshift({label:'Py. Triple: '+finalLabel,tri:currentTri,goal:currentGoal,method:currentMethod,inputs:vals.map(String),isExt:false,finalText:finalLabel,approxText:'',approxVis:'none',formula:formula,area:area.toFixed(p),perim:perim.toFixed(p),ds1:s1,dh:h,db:b,ds2:s2,anglesForCanvas:anglesForCanvas});
                if(history.length>10)history.pop();
                get('histList').innerHTML=history.map(function(hh){return'<span style="display:block;padding:3px 0;border-bottom:1px solid #f0f0f0;">'+(hh.label||hh)+'</span>';}).join('');
                saveSettings();
            }
            return;
        }

        try{
        if(type==='sc_b_shs'){
            s1=v0;h=v1;s2=v2;
            if(h>=s1){if(!silent)showError('Impossible','Height must be less than Side 1.');return;}
            if(h>=s2){if(!silent)showError('Impossible','Height must be less than Side 2.');return;}
            var xA=Math.sqrt(s1*s1-h*h),xB=Math.sqrt(s2*s2-h*h);
            res=isExt?Math.abs(xA-xB):(xA+xB);b=res;
            formula='Part1 = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xA)+'\nPart2 = \u221a('+s2+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xB)+'\nBase = '+fmtS(xA)+(isExt?' \u2212 ':' + ')+fmtS(xB)+' = '+fmtS(res);
        }else if(type==='sc_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Base = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='sc_s_shb'){
            s1=v0;h=v1;b=v2;
            if(h>=s1){if(!silent)showError('Impossible','Height must be less than Known Side.');return;}
            var xxS=Math.sqrt(s1*s1-h*h);
            if(isExt){
                if(xxS<=b){if(!silent)showError('Impossible','Side\'s reach must exceed base.');return;}
                res=Math.sqrt(b*b+h*h);s2=res;
                formula='Reach = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xxS)+'\nSide 2 = \u221a('+b+'\u00b2 + '+h+'\u00b2) = '+fmtS(res);
            }else{
                var yS=Math.abs(b-xxS);res=Math.sqrt(yS*yS+h*h);s2=res;
                formula='Reach = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xxS)+'\nSeg = |'+b+' \u2212 '+fmtS(xxS)+'| = '+fmtS(yS)+'\nSide 2 = \u221a('+fmtS(yS)+'\u00b2 + '+h+'\u00b2) = '+fmtS(res);
            }
        }else if(type==='sc_s_hb'){
            h=v0;b=v1;res=Math.sqrt(h*h+b*b);s1=res;s2=res;
            formula='Side = \u221a(h\u00b2 + seg\u00b2)\n= \u221a('+h+'\u00b2 + '+b+'\u00b2) = '+fmtS(res);
        }else if(type==='sc_h_ab'){
            res=(2*v0)/v1;h=res;b=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Height = (2 \u00d7 Area) / Base\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='sc_h_ssb'){
            s1=v0;s2=v1;b=v2;
            if(b/2>=s1){if(!silent)showError('Impossible','Base is too wide for Side 1.');return;}
            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(S1\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='sc_a_heron'||type==='is_a_heron'){
            s1=v0;s2=v1;b=v2;
            var sv=(s1+s2+b)/2;
            var areaH=Math.sqrt(sv*(sv-s1)*(sv-s2)*(sv-b));
            if(isNaN(areaH)||areaH<=0){if(!silent)showError('Impossible','These sides don\'t form a valid triangle.');return;}
            res=areaH;area=areaH;h=(2*areaH)/b;perim=s1+s2+b;
            formula="Heron's: s = ("+s1+'+'+s2+'+'+b+') / 2 = '+sv.toFixed(p)+'\nArea = \u221a(s(s\u2212a)(s\u2212b)(s\u2212c))\n= \u221a('+sv.toFixed(p)+'\u00d7'+(sv-s1).toFixed(p)+'\u00d7'+(sv-s2).toFixed(p)+'\u00d7'+(sv-b).toFixed(p)+')\n= '+fmtS(res);
        }else if(type==='is_b_sh'){
            s1=v0;h=v1;s2=v0;
            if(h>=s1){if(!silent)showError('Impossible','Height must be less than Leg.');return;}
            var hfI=Math.sqrt(s1*s1-h*h);res=2*hfI;b=res;
            formula='Half-base = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(hfI)+'\nBase = 2 \u00d7 '+fmtS(hfI)+' = '+fmtS(res);
        }else if(type==='is_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Base = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='is_b_al'){
            var Ai=v0,Si=v1,inner=4*Si*Si*Si*Si-16*Ai*Ai;
            if(inner<0){if(!silent)showError('Impossible','Area too large for that leg.');return;}
            var u=2*Si*Si-Math.sqrt(inner);
            if(u<=0){if(!silent)showError('Impossible','No valid solution.');return;}
            res=Math.sqrt(u);b=res;s1=Si;s2=Si;h=(2*Ai)/b;
            formula='b\u00b2 = 2s\u00b2 \u2212 \u221a(4s\u2074\u22124A\u00b2)\nBase = \u221a'+fmtS(res);
        }else if(type==='is_s_bh'){
            b=v0;h=v1;res=Math.sqrt(h*h+(b/2)*(b/2));s1=res;s2=res;
            formula='Leg = \u221a(h\u00b2 + (b/2)\u00b2)\n= \u221a('+h+'\u00b2 + '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='is_s_ab'){
            var Ais=v0,bis=v1;h=(2*Ais)/bis;res=Math.sqrt(h*h+(bis/2)*(bis/2));s1=res;s2=res;b=bis;
            formula='h = 2A/b = '+fmtS(h)+'\nLeg = \u221a(h\u00b2+(b/2)\u00b2) = '+fmtS(res);
        }else if(type==='is_h_bl'){
            b=v0;s1=v1;s2=v1;
            if(b/2>=s1){if(!silent)showError('Impossible','Base too wide for Leg.');return;}
            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(Leg\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='is_h_ab'){
            res=(2*v0)/v1;h=res;b=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Height = (2 \u00d7 Area) / Base\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='eq_h_s'){
            var side=v0;b=side;s1=side;s2=side;h=Math.sqrt(3)/2*side;
            res=currentGoal==='height'?h:side;
            formula='Height = (\u221a3 / 2) \u00d7 '+side+(useSurd?' = '+fmtS(h):' \u2248 '+h.toFixed(p));
        }else if(type==='eq_b_ah'){
            var hConsistent=Math.sqrt(v0*Math.sqrt(3));
            if(Math.abs(hConsistent-v1)>0.001*v1){
                if(!silent)showError('Impossible combination','For an equilateral triangle, Area and Height are not independent. With Area = '+v0+', the height must be \u2248 '+hConsistent.toFixed(getPrec())+', not '+v1+'.');
                return;
            }
            var beq=(2*v0)/v1;
            res=beq;b=beq;s1=beq;s2=beq;h=v1;
            formula='b = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='eq_a_heron'){
            var seq=v0;s1=seq;s2=seq;b=seq;
            var svEq=3*seq/2;
            res=Math.sqrt(svEq*(svEq-seq)*(svEq-seq)*(svEq-seq));
            area=res;h=Math.sqrt(3)/2*seq;
            formula="Heron's (equilateral): s = 3a/2 = "+svEq.toFixed(p)+'\nArea = \u221a(s(s\u2212a)\u00b3) = '+fmtS(res);
        }else if(type==='rt_c_ll'){
            s1=v0;b=v1;res=Math.sqrt(s1*s1+b*b);s2=res;h=s1;
            formula='c = \u221a(a\u00b2 + b\u00b2)\n= \u221a('+s1+'\u00b2 + '+b+'\u00b2)\n= \u221a'+(s1*s1+b*b)+' = '+fmtS(res);
        }else if(type==='rt_c_al'){
            var legA=v1;h=(2*v0)/legA;res=Math.sqrt(legA*legA+h*h);s1=h;b=legA;s2=res;
            formula='Other leg = (2A)/known = '+fmtS(h)+'\nc = \u221a('+legA+'\u00b2 + '+fmtS(h)+'\u00b2) = '+fmtS(res);
        }else if(type==='rt_l_cl'){
            var hyp=v0,oLeg=v1;
            if(oLeg>=hyp){if(!silent)showError('Impossible','Leg must be shorter than hypotenuse.');return;}
            res=Math.sqrt(hyp*hyp-oLeg*oLeg);s1=res;b=oLeg;s2=hyp;h=res;
            formula='Leg = \u221a(c\u00b2 \u2212 b\u00b2)\n= \u221a('+hyp+'\u00b2 \u2212 '+oLeg+'\u00b2)\n= \u221a'+(hyp*hyp-oLeg*oLeg)+' = '+fmtS(res);
        }else if(type==='rt_l_ac'){
            var hypR=v1;
            var inner3=hypR*hypR-4*v0;
            if(inner3<0){if(!silent)showError('Impossible','Area is too large for that hypotenuse.');return;}
            res=(Math.sqrt(hypR*hypR+4*v0)+Math.sqrt(inner3))/2;
            s1=res;h=res;
            b=(Math.sqrt(hypR*hypR+4*v0)-Math.sqrt(inner3))/2;
            s2=hypR;
            formula='Leg = (\u221a(c\u00b2+4A) + \u221a(c\u00b2\u22124A)) / 2\n= (\u221a'+(hypR*hypR+4*v0).toFixed(getPrec())+' + \u221a'+inner3.toFixed(getPrec())+') / 2\n= '+fmtS(res);
        }else if(type==='rt_h_ll'){
            s1=v0;b=v1;var hyp2=Math.sqrt(s1*s1+b*b);
            res=(s1*b)/hyp2;h=res;s2=hyp2;
            formula='Altitude = (a \u00d7 b) / c\n= ('+s1+' \u00d7 '+b+') / \u221a'+(s1*s1+b*b)+' = '+fmtS(res);
        }else if(type==='rt_h_ac'){
            var hypH=v1;res=(2*v0)/hypH;h=res;
            var sumAB=Math.sqrt(hypH*hypH+4*v0);
            var inner2=hypH*hypH-4*v0;
            if(inner2<0){if(!silent)showError('Impossible','Area is too large for that hypotenuse.');return;}
            var diffAB=Math.sqrt(inner2);
            s1=(sumAB+diffAB)/2; b=(sumAB-diffAB)/2; s2=hypH;
            formula='Altitude = (2A) / c = (2 \u00d7 '+v0+') / '+hypH+' = '+fmtS(res);
        }else if(type==='rt_b_cl'){
            var hypB=v0,legB=v1;
            if(legB>=hypB){if(!silent)showError('Impossible','Leg must be shorter than hypotenuse.');return;}
            res=Math.sqrt(hypB*hypB-legB*legB);b=res;s1=legB;s2=hypB;h=legB;
            formula='Base = \u221a(c\u00b2 \u2212 leg\u00b2)\n= \u221a('+hypB+'\u00b2 \u2212 '+legB+'\u00b2)\n= \u221a'+(hypB*hypB-legB*legB)+' = '+fmtS(res);
        }else if(type==='rt_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=h;s2=Math.sqrt(h*h+b*b);
            formula='Base = (2A) / height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }
        }catch(e){if(!silent)showError('Calculation error','Double-check your values form a valid triangle.');return;}

        if(isNaN(res)||res<=0||!isFinite(res)){if(!silent)showError('No solution','These values don\'t form a valid triangle.');return;}
        if(!s1||isNaN(s1))s1=res; if(!s2||isNaN(s2))s2=res;
        if(!b||isNaN(b))b=res;   if(!h||isNaN(h))h=res;

        if(!area||isNaN(area)) area=0.5*b*h;
        perim=s1+s2+b;
        get('res').style.display='block';

        var approxEl=get('finalApprox');
        if(useSurd){
            var ss=toSurdStr(res);
            if(ss){get('final').innerText=ss;approxEl.innerText='\u2248 '+res.toFixed(p);approxEl.style.display='block';}
            else{get('final').innerText=fmt(res);approxEl.style.display='none';}
        }else{
            get('final').innerText=res.toFixed(p);approxEl.style.display='none';
        }
        get('formulaText').innerText=formula||'';
        get('areaRes').innerText=area.toFixed(p);
        get('perimRes').innerText=perim.toFixed(p);

        var classTag=get('classTag');
        var classification=classifyTriangle(s1,s2,b);
        classTag.innerText=classification;
        classTag.style.display='inline-block';

        var tripleBox=get('tripleBox');
        if(currentTri==='right'&&currentGoal!=='triple'){
            var trip=checkTriple(s1,b,s2);
            if(trip){tripleBox.innerText='\u2605 Pythagorean triple: '+trip;tripleBox.style.display='block';}
            else{tripleBox.style.display='none';}
        } else if(currentGoal!=='triple') { tripleBox.style.display='none'; }

        var anglesBox=get('anglesBox'), anglesContent=get('anglesContent');
        var angArr=computeAngles(s1, b, s2);
        var anglesForCanvas=[angArr[2], angArr[1], angArr[0]];
        anglesContent.innerHTML='';
        var names=['A','B','C'];
        var d2=getDark();
        angArr.forEach(function(ang,i){
            var sp=document.createElement('span');
            sp.style.cssText='font-weight:600;color:'+(d2?'#4a9eff':'#1a73e8')+';';
            sp.innerText=names[i]+' = '+fmtAngle(ang);
            anglesContent.appendChild(sp);
        });
        anglesBox.style.display='block';

        var drawS1=s1, drawH=h, drawB=b, drawS2=s2;
        if(currentTri==='right') drawH=s1;
        drawTri(drawS1, drawH, drawB, drawS2, isExt, anglesForCanvas);

        applyDark();
        applyDiagramVisibility();
        applyResultVisibility();

        if(!silent){
            var adv=getAdv();
            var gLbl=((adv?goalLabel.a:goalLabel.s)[currentGoal])||currentGoal;
            var inputVals=[];
            cfg.inputs.forEach(function(_,i){var el=get('v'+i);inputVals.push(el?el.value:'');});
            history.unshift({
                label:gLbl+': '+get('final').innerText,
                tri:currentTri,goal:currentGoal,method:currentMethod,
                inputs:inputVals,isExt:isExt,
                finalText:get('final').innerText,
                approxText:approxEl.innerText,approxVis:approxEl.style.display,
                formula:formula||'',area:area.toFixed(p),perim:perim.toFixed(p),
                ds1:drawS1,dh:drawH,db:drawB,ds2:drawS2,
                anglesForCanvas:anglesForCanvas
            });
            if(history.length>10)history.pop();
            get('histList').innerHTML=history.map(function(hh){return'<span style="display:block;padding:3px 0;border-bottom:1px solid #f0f0f0;">'+(hh.label||hh)+'</span>';}).join('');
            saveSettings();
        }
    }

