        ckError.style.borderColor = d ? '#883333' : '#f5c2c2';
        ckError.style.color       = d ? '#ff8080' : '#c0392b';
    }

    function ck_insertPendingCloses() {
        if(!ck_inferBrackets) return;
        var pending = ck_pendingAutoCloses();
        for(var i = pending.length - 1; i >= 0; i--) {
            ck_tokens.push({
                e: ')', d: ')', kind: 'close',
                isAutoClose: true, autoCloseId: pending[i].id
            });
        }
    }

    function ck_evaluate() {
        if(!ck_tokens.length) return;
        ck_clearCalcError();

        ck_insertPendingCloses();

        var s = ck_buildStrings();
        var evalStr = s.e.replace(/\u03c0/g, '(' + Math.PI + ')');

        // Trig helpers: use degrees if the main panel is set to degrees, else radians
        var _useDeg = getDeg();
        var _trigPre = _useDeg
            ? 'var _geo_sin=function(x){return Math.sin(x*Math.PI/180)};'
            + 'var _geo_cos=function(x){return Math.cos(x*Math.PI/180)};'
            + 'var _geo_tan=function(x){return Math.tan(x*Math.PI/180)};'
            + 'var _geo_asin=function(x){return Math.asin(x)*180/Math.PI};'
            + 'var _geo_acos=function(x){return Math.acos(x)*180/Math.PI};'
            + 'var _geo_atan=function(x){return Math.atan(x)*180/Math.PI};'
            : 'var _geo_sin=Math.sin,_geo_cos=Math.cos,_geo_tan=Math.tan,'
            + '_geo_asin=Math.asin,_geo_acos=Math.acos,_geo_atan=Math.atan;';

        try {
            var result = Function('"use strict"; ' + _trigPre + ' return (' + evalStr + ')')();
            if(!isFinite(result)) { ck_showCalcError('Cannot divide by zero'); return; }
            if(isNaN(result))     { ck_showCalcError('Invalid expression'); return; }
            var rounded = parseFloat(result.toPrecision(12));
            ckExpr.innerText = s.d + ' =';
            ck_tokens = [{ e: String(rounded), d: String(rounded), kind: 'num' }];
            ck_justEvaled = true;
            ck_renderDisplay();
        } catch(err) {
            ck_showCalcError('Invalid expression');
        }
    }

    function ck_handleKey(k) {
        ck_clearCalcError();

        if(k === 'C') {
            ck_tokens = [];
            ck_justEvaled = false;
            ck_clearCalcError();
            ckExpr.innerText = '';
            ckDisplay.innerHTML = '<span>0</span>';
            return;
        }

        if(k === '\u232b') {
            if(ck_justEvaled) {
                ck_tokens = [];
                ck_justEvaled = false;
                ckExpr.innerText = '';
                ck_renderDisplay();
                return;
            }
            if(!ck_tokens.length) return;

            var last = ck_tokens[ck_tokens.length - 1];

            if(last.isAutoClose) {
                var closeId = last.autoCloseId;
                ck_tokens.pop();
                for(var i = ck_tokens.length - 1; i >= 0; i--) {
                    if(ck_tokens[i].kind === 'sqrt-open' && ck_tokens[i].autoCloseId === closeId) {
                        ck_tokens[i].closingDeleted = true;
                        break;
                    }
                }
                ck_renderDisplay();
                return;
            }

            if(last.kind === 'sqrt-open') {
                var openId = last.autoCloseId;
                var closeIdx = -1;
                for(var j = ck_tokens.length - 1; j >= 0; j--) {
                    if(ck_tokens[j].isAutoClose && ck_tokens[j].autoCloseId === openId) {
                        closeIdx = j; break;
                    }
                }
                if(closeIdx >= 0) {
                    ck_tokens.splice(closeIdx, 1);
                }
                ck_tokens.pop();
                ck_renderDisplay();
                return;
            }

            ck_tokens.pop();
            ck_renderDisplay();
            return;
        }

        if(k === '=') {
            ck_evaluate();
            return;
        }

        if(ck_justEvaled) {
            var isOp  = (k==='+' || k==='-' || k==='\u00d7' || k==='\u00f7');
            if(!isOp) {
                ck_tokens = [];
                ckExpr.innerText = '';
            }
            ck_justEvaled = false;
        }

        var isOperator = (k==='+' || k==='\u00d7' || k==='\u00f7');
        if(isOperator && ck_lastIsNum()) {
            ck_insertPendingCloses();
        }

        if(k === '(') {
            ck_tokens.push({ e:'(', d:'(', kind:'open' });

        } else if(k === ')') {
            if(ck_openDepth() > 0) {
                var innermostOpen = null;
                var innermostIdx = -1;
                var depthCheck = 0;
                for(var ci = 0; ci < ck_tokens.length; ci++) {
                    var ck = ck_tokens[ci].kind;
                    if(ck === 'open' || ck === 'sqrt-open') { depthCheck++; innermostOpen = ck_tokens[ci]; innermostIdx = ci; }
                    else if(ck === 'close') { depthCheck--; }
                }
                if(ck_inferBrackets && innermostOpen && innermostOpen.kind === 'sqrt-open' && !innermostOpen.closingDeleted) {
                    innermostOpen.closingDeleted = true;
                    ck_tokens.push({ e:')', d:')', kind:'close',
                        realizedFromId: innermostOpen.autoCloseId });
                } else {
                    ck_tokens.push({ e:')', d:')', kind:'close' });
                }
            }

        } else if(k === '+') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'+', d:'+', kind:'op' });
            }

        } else if(k === '-') {
            ck_tokens.push({ e:'-', d:'-', kind:'op' });

        } else if(k === '\u00d7') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }

        } else if(k === '\u00f7') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'/', d:'\u00f7', kind:'op' });
            }

        } else if(k === '\u221a') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            var id = ck_newId();
            ck_tokens.push({
                e: 'Math.sqrt(', d: '\u221a(',
                kind: 'sqrt-open',
                autoCloseId: id,
                closingDeleted: false
            });

        } else if(k === '\u03c0') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            ck_tokens.push({ e:'\u03c0', d:'\u03c0', kind:'pi' });

        } else if(k === 'sin' || k === 'cos' || k === 'tan' || k === 'asin' || k === 'acos' || k === 'atan') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            var id = ck_newId();
            var mathFn = k; // sin, cos, tan, asin, acos, atan
            // All trig fns work in radians in Math.*; we convert degrees input via wrapper
            var eStr = '_geo_'+k+'(';
            ck_tokens.push({
                e: eStr, d: k+'(',
                kind: 'sqrt-open',
                autoCloseId: id,
                closingDeleted: false
            });

        } else if(k === 'x\u00b2') {
            // Append ² as a postfix power token — evaluates on = or Enter
            if(ck_lastIsNum()) {
                ck_insertPendingCloses();
                ck_tokens.push({ e:'**2', d:'\u00b2', kind:'pow' });
            }

        } else if(k === 'x\u00b3') {
            // Append ³ as a postfix power token
            if(ck_lastIsNum()) {
                ck_insertPendingCloses();
                ck_tokens.push({ e:'**3', d:'\u00b3', kind:'pow' });
            }

        } else if(k === 'x\u02b8') {
            // Power operator: x^y — inserts ** ready for exponent input
            if(ck_lastIsNum()) {
                ck_insertPendingCloses();
                ck_tokens.push({ e:'**', d:'^', kind:'op' });
            }

        } else if(k === '.') {
            var lastNumTok = null;
            for(var ni = ck_tokens.length - 1; ni >= 0; ni--) {
                if(ck_tokens[ni].kind === 'num') { lastNumTok = ck_tokens[ni]; break; }
                if(ck_tokens[ni].kind !== 'num') break;
            }
            var lastTokIsNum = ck_lastKind() === 'num';
            if(lastTokIsNum && ck_tokens[ck_tokens.length-1].e.indexOf('.') < 0) {
                ck_tokens[ck_tokens.length-1].e += '.';
                ck_tokens[ck_tokens.length-1].d += '.';
            } else if(!lastTokIsNum) {
                ck_tokens.push({ e:'0.', d:'0.', kind:'num' });
            }

        } else {
            if(ck_lastKind() === 'num') {
                var nt = ck_tokens[ck_tokens.length-1];
                if(nt.e === '0') { nt.e = k; nt.d = k; }
                else { nt.e += k; nt.d += k; }
            } else {
                ck_tokens.push({ e: k, d: k, kind: 'num' });
            }
        }

        ck_renderDisplay();
    }

