    // ── Shared 360° spinning triangle (main canvas) ───────────────────
    function _secret360() {
        var c = get('triCanvas'), cb = get('canvasBox');
        if(!c || !cb) return;
        cb.style.display = 'block';
        var W = c.offsetWidth || c.width || 340;
        var H = c.offsetHeight || c.height || 210;
        c.width = W; c.height = H;
        var ctx2 = c.getContext('2d');
        var d = getDark(), bw = getBW();
        var bg  = bw?'#fff':(d?'#181828':'#fafbff');
        var acc = bw?'#000':(d?'#4a9eff':'#1a73e8');
        get('res').style.display = 'block';
        get('final').style.display = 'block';
        get('final').innerText = '360°';
        var classTag = get('classTag'); if(classTag) classTag.style.display='none';
        var angle = 0, spinTimer = null;
        function spinFrame() {
            ctx2.fillStyle = bg; ctx2.fillRect(0,0,W,H);
            ctx2.save();
            ctx2.translate(W/2, H/2);
            ctx2.rotate(angle);
            var r = Math.min(W,H)*0.32;
            ctx2.beginPath();
            for(var i=0;i<3;i++){
                var a = (i*2*Math.PI/3) - Math.PI/2;
                if(i===0) ctx2.moveTo(Math.cos(a)*r, Math.sin(a)*r);
                else ctx2.lineTo(Math.cos(a)*r, Math.sin(a)*r);
            }
            ctx2.closePath();
            ctx2.strokeStyle = acc; ctx2.lineWidth = 2.5; ctx2.stroke();
            ctx2.fillStyle = d?'#5050aa':'#aac0ee';
            ctx2.font = 'bold 11px system-ui,sans-serif';
            ctx2.textAlign = 'center';
            ctx2.fillText("that's a full rotation...", 0, r+22);
            ctx2.restore();
            angle += 0.04;
            spinTimer = requestAnimationFrame(spinFrame);
        }
        spinFrame();
        setTimeout(function(){
            cancelAnimationFrame(spinTimer);
            get('final').innerText = '';
            get('res').style.display = 'none';
            if(lastCalcResult) {
                drawTri(lastCalcResult.s1, lastCalcResult.h, lastCalcResult.b, lastCalcResult.s2,
                    lastCalcResult.isExt, lastCalcResult.anglesForCanvas, lastCalcResult.goal);
            } else {
                ctx2.fillStyle = bg; ctx2.fillRect(0,0,W,H);
            }
        }, 4000);
    }

