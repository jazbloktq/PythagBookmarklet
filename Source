                    formulaLines.push('  \u2192 Non-primitive triple: ('+td.pa+', '+td.pb+', '+td.pc+') \u00d7 '+g);
                    formulaLines.push('  Scaling rule: k\u00d7('+td.pa+','+td.pb+','+td.pc+') \u2192 ('+td.Ar+','+td.Br+','+td.Cr+')');
                    var tripleLabel=(td.pa+'-'+td.pb+'-'+td.pc)+' \u00d7'+g;
                    formula=formulaLines.join('\n');
                    get('tripleBox').innerHTML='\u2605 Non-primitive triple: ('+td.Ar+', '+td.Br+', '+td.Cr+') = '+g+'\u00d7('+td.pa+', '+td.pb+', '+td.pc+')';
