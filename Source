    function simplifySqrt(n) {
        var coeff=1, rad=n;
        for(var p=2;p*p<=rad;p++) while(rad%(p*p)===0){rad/=p*p;coeff*=p;}
        return {coeff:coeff,rad:rad};
    }
    function toSurdStr(value) {
        var sq=value*value, sqR=Math.round(sq);
        if(Math.abs(sq-sqR)>1e-7||sqR<=0) return null;
        var s=simplifySqrt(sqR);
        if(s.rad===1) return null;
        if(!getSimplify()) return '\u221a'+sqR;
        return (s.coeff===1?'':s.coeff)+'\u221a'+s.rad;
    }
    function fmt(value) {
        if(getSurd()){
            var ss=toSurdStr(value); if(ss) return ss;
            var sqR=Math.round(value*value);
            if(Math.abs(value*value-sqR)<1e-7&&Math.abs(value-Math.round(value))<1e-9) return String(Math.round(value));
        }
        return value.toFixed(getPrec());
    }
    function fmtS(value) {
        if(getSurd()){
            var sq=value*value, sqR=Math.round(sq);
            if(Math.abs(sq-sqR)<1e-7&&sqR>0){
                var s=simplifySqrt(sqR);
                if(s.rad!==1){ if(!getSimplify()) return '\u221a'+sqR; return (s.coeff===1?'':s.coeff)+'\u221a'+s.rad; }
                if(Math.abs(value-Math.round(value))<1e-9) return String(Math.round(value));
            }
        }
        return value.toFixed(getPrec());
    }

    function fmtAngle(rad) {
