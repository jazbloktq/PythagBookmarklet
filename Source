    // ── Draggable header ──────────────────────────────────────────────────────
    var header = ui.querySelector('div[style*="background:#1a73e8"]');
    header.style.cursor = 'grab';
    var dragState = null;
    header.addEventListener('mousedown', function(e) {
        if (e.target !== header && e.target.tagName !== 'H3') return;
        e.preventDefault();
        var rect = ui.getBoundingClientRect();
        dragState = { startX: e.clientX - rect.left, startY: e.clientY - rect.top };
        header.style.cursor = 'grabbing';
        ui.style.right = 'auto';
        ui.style.left  = rect.left + 'px';
        ui.style.top   = rect.top  + 'px';
    });
    document.addEventListener('mousemove', function(e) {
        if (!dragState) return;
        var x = e.clientX - dragState.startX;
        var y = e.clientY - dragState.startY;
        x = Math.max(0, Math.min(window.innerWidth  - ui.offsetWidth,  x));
        y = Math.max(0, Math.min(window.innerHeight - ui.offsetHeight, y));
        ui.style.left = x + 'px';
        ui.style.top  = y + 'px';
    });
    document.addEventListener('mouseup', function() {
        if (!dragState) return;
        dragState = null;
        header.style.cursor = 'grab';
    });
    get('closeHist').onclick=function(){get('histMenu').style.display='none';};
    document.addEventListener('click',function(e){
        var sm=get('setMenu'),hm=get('histMenu'),sb=get('setBtn'),hb=get('histBtn');
        if(sm.style.display!=='none'&&!sm.contains(e.target)&&e.target!==sb) sm.style.display='none';
        if(hm.style.display!=='none'&&!hm.contains(e.target)&&e.target!==hb) hm.style.display='none';
    });

    // Settings listeners — direct element bindings, not document-level
    get('prec').addEventListener('change', saveSettings);
    get('optSurd').addEventListener('change', saveSettings);
    get('optSimplify').addEventListener('change', saveSettings);
    get('optAdvanced').addEventListener('change', function(){rebuildAll();saveSettings();});

    // ── Keyboard shortcuts ────────────────────────────────────────────────────
    var historyIndex = -1; // tracks which history entry we're browsing
    document.addEventListener('keydown', function(e) {
        // Only act if focus is inside the widget or no input is focused elsewhere
        var active = document.activeElement;
        var focusedElsewhere = active && active !== document.body && !ui.contains(active);
        if (focusedElsewhere) return;

        if (e.key === 'Enter') {
            e.preventDefault();
            historyIndex = -1;
            get('calc').click();
        } else if (e.key === 'ArrowLeft') {
            if (!history.length) return;
            e.preventDefault();
            historyIndex = Math.min(historyIndex + 1, history.length - 1);
            var entry = history[historyIndex];
            if (!entry || !entry.tri) return;
            // Restore triangle type + goal + method
            currentTri    = entry.tri;
            currentGoal   = entry.goal;
            currentMethod = entry.method;
            buildTriBtns(); buildGoalBtns(); buildMethodBtns(); renderInputs();
            // Restore input values
            entry.inputs.forEach(function(val, i) {
                var el = get('v' + i); if (el) el.value = val;
            });
            // Restore position toggle
            if (entry.isExt) {
                var extRadio = ui.querySelector('input[name="geopro_pos"][value="ext"]');
                if (extRadio) extRadio.checked = true;
            }
            // Restore result panel
            get('final').innerText = entry.finalText;
            var approxEl = get('finalApprox');
            approxEl.innerText = entry.approxText;
            approxEl.style.display = entry.approxVis;
            get('formulaText').innerText = entry.formula;
            get('areaRes').innerText = entry.area;
            get('perimRes').innerText = entry.perim;
            get('res').style.display = 'block';
            // Restore canvas
            drawTri(entry.ds1, entry.dh, entry.db, entry.ds2, entry.isExt);
        } else if (e.key === 'ArrowRight') {
            // Go forward in history (towards more recent)
            if (historyIndex <= 0) { historyIndex = -1; return; }
            e.preventDefault();
            historyIndex--;
            var entry = history[historyIndex];
            if (!entry || !entry.tri) return;
            currentTri    = entry.tri;
            currentGoal   = entry.goal;
            currentMethod = entry.method;
            buildTriBtns(); buildGoalBtns(); buildMethodBtns(); renderInputs();
            entry.inputs.forEach(function(val, i) {
                var el = get('v' + i); if (el) el.value = val;
            });
            if (entry.isExt) {
                var extRadio2 = ui.querySelector('input[name="geopro_pos"][value="ext"]');
                if (extRadio2) extRadio2.checked = true;
            }
            get('final').innerText = entry.finalText;
            var approxEl2 = get('finalApprox');
            approxEl2.innerText = entry.approxText;
            approxEl2.style.display = entry.approxVis;
            get('formulaText').innerText = entry.formula;
            get('areaRes').innerText = entry.area;
            get('perimRes').innerText = entry.perim;
            get('res').style.display = 'block';
            drawTri(entry.ds1, entry.dh, entry.ds2, entry.isExt);
        }
    });

    // ── Initial build ─────────────────────────────────────────────────────────
    if(triGoals[currentTri].indexOf(currentGoal)<0) currentGoal=triGoals[currentTri][0];
    var mLen=(methods[currentTri]&&methods[currentTri][currentGoal]?methods[currentTri][currentGoal].length:0);
    if(currentMethod>=mLen) currentMethod=0;

    buildTriBtns(); buildGoalBtns(); buildMethodBtns(); renderInputs();
})();

