    function drawTri(s1, h, b, s2, isExt) {
        var W = canvas.width, H = canvas.height;
        ctx.clearRect(0,0,W,H);

        var x1 = Math.sqrt(Math.max(0, s1*s1 - h*h));
        // raw triangle points (y=0 is top of triangle, y=h is base)
        var raw = isExt ? [[0,h],[x1,0],[Math.abs(x1-b),h]] : [[0,h],[x1,0],[b,h]];

        var pad = 42; // padding so labels have room
        var minX = Math.min(raw[0][0],raw[1][0],raw[2][0]);
        var maxX = Math.max(raw[0][0],raw[1][0],raw[2][0]);
        var rangeX = maxX - minX || 1;
        var rangeY = h || 1;
        var scale = Math.min((W - pad*2) / rangeX, (H - pad*2) / rangeY);

        // center the scaled triangle in the canvas
        var triW = rangeX * scale;
        var triH = rangeY * scale;
        var offX = (W - triW) / 2 - minX * scale;
        var offY = (H - triH) / 2;

        function tr(p) { return [p[0]*scale + offX, p[1]*scale + offY]; }
        var pA=tr(raw[0]), pB=tr(raw[1]), pC=tr(raw[2]);
        var pH=[pB[0], pA[1]]; // foot of height on base

        // fill
        ctx.beginPath(); ctx.moveTo(pA[0],pA[1]); ctx.lineTo(pB[0],pB[1]); ctx.lineTo(pC[0],pC[1]); ctx.closePath();
        ctx.fillStyle='rgba(26,115,232,0.06)'; ctx.fill();

        // triangle stroke
        ctx.strokeStyle='#1a73e8'; ctx.lineWidth=2.5; ctx.lineJoin='round';
        ctx.beginPath(); ctx.moveTo(pA[0],pA[1]); ctx.lineTo(pB[0],pB[1]); ctx.lineTo(pC[0],pC[1]); ctx.closePath(); ctx.stroke();

        // height dashed line
        ctx.setLineDash([4,4]); ctx.lineWidth=1.5; ctx.strokeStyle='#aaa';
        ctx.beginPath(); ctx.moveTo(pB[0],pB[1]); ctx.lineTo(pH[0],pH[1]); ctx.stroke(); ctx.setLineDash([]);

        // right angle box
        var sq=6; ctx.strokeStyle='#aaa'; ctx.lineWidth=1;
        ctx.strokeRect(pH[0], pH[1], sq, sq);

        // --- labels: all same color, pushed outward from each side ---
        var LABEL = '#1a73e8';
        ctx.fillStyle = LABEL;
        ctx.font = 'bold 11px system-ui';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        var OUT = 14; // outward offset in px

        // helper: midpoint + outward normal offset
        function labelSide(ax,ay,bxp,by,lbl) {
            var mx=(ax+bxp)/2, my=(ay+by)/2;
            var dx=bxp-ax, dy=by-ay, len=Math.sqrt(dx*dx+dy*dy)||1;
            // normal pointing away from triangle centroid
            var cx=(pA[0]+pB[0]+pC[0])/3, cy=(pA[1]+pB[1]+pC[1])/3;
            var nx=-dy/len, ny=dx/len;
            if ((mx+nx-cx)*nx+(my+ny-cy)*ny < 0) { nx=-nx; ny=-ny; }
            ctx.fillText(lbl, mx+nx*OUT, my+ny*OUT);
        }

        labelSide(pA[0],pA[1],pB[0],pB[1], s1.toFixed(1));   // left slant
        labelSide(pB[0],pB[1],pC[0],pC[1], s2.toFixed(1));   // right slant
        labelSide(pA[0],pA[1],pC[0],pC[1], b.toFixed(1));    // base

        // height label: place on whichever horizontal side of the dashed line has more room
        // pH[0] is the foot x; pB[0] is the apex x (same, it's vertical)
        // check space to left vs right of the dashed line
        var hmy = (pB[1]+pH[1])/2;
        var spaceRight = W - pH[0];
        var spaceLeft  = pH[0];
        if (spaceRight >= spaceLeft) {
            ctx.textAlign='left';
            ctx.fillText('h='+h.toFixed(1), pH[0]+8, hmy);
        } else {
            ctx.textAlign='right';
            ctx.fillText('h='+h.toFixed(1), pH[0]-8, hmy);
        }
    }

    get('setBtn').onclick = function(e) { e.stopPropagation(); var m=get('setMenu'); m.style.display=m.style.display==='none'?'block':'none'; get('histMenu').style.display='none'; };
