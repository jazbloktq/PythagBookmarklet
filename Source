    var ck_tokens = [];
    var ck_autoCloseCounter = 0;
    var ck_justEvaled = false;
    var ck_pinOpen = false;
    var ck_inferBrackets = true;

    var ckDisplay = get('calcDisplay');
    var ckExpr    = get('calcExpr');
    var ckError   = get('calcError');

    get('calcPinOpen').addEventListener('change', function() {
        ck_pinOpen = this.checked;
    });
    get('calcInferBrackets').addEventListener('change', function() {
        ck_inferBrackets = this.checked;
        ck_renderDisplay();
    });

    function ck_newId() { return ++ck_autoCloseCounter; }

    function ck_buildStrings() {
        var e = '', d = '';
        for(var i = 0; i < ck_tokens.length; i++) {
            e += ck_tokens[i].e;
            d += ck_tokens[i].d;
        }
        return { e: e, d: d };
    }

    function ck_escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function ck_renderDisplay() {
        var s = ck_buildStrings();
        var mainText = s.d || '0';
        if(ck_inferBrackets) {
            var pending = ck_pendingAutoCloses();
            var suffix = '';
            for(var i = 0; i < pending.length; i++) suffix += ')';
            var dimCol = getDark() ? 'rgba(200,220,255,0.30)' : 'rgba(26,115,232,0.22)';
            if(suffix) {
                ckDisplay.innerHTML =
                    '<span>' + ck_escHtml(mainText) + '</span>' +
                    '<span style="color:' + dimCol + ';font-style:italic;font-weight:400;">' + suffix + '</span>';
                return;
            }
        }
        ckDisplay.innerHTML = '<span>' + ck_escHtml(mainText) + '</span>';
    }

    function ck_pendingAutoCloses() {
        var opens = [];
        for(var i = 0; i < ck_tokens.length; i++) {
            var t = ck_tokens[i];
            if(t.kind === 'sqrt-open' && !t.closingDeleted) {
                var hasClosed = false;
                for(var j = i+1; j < ck_tokens.length; j++) {
                    if(ck_tokens[j].isAutoClose && ck_tokens[j].autoCloseId === t.autoCloseId) {
                        hasClosed = true; break;
                    }
                }
                if(!hasClosed) opens.push({idx: i, id: t.autoCloseId});
            }
        }
        return opens;
    }

    function ck_openDepth() {
        var depth = 0;
        for(var i = 0; i < ck_tokens.length; i++) {
            var k = ck_tokens[i].kind;
            if(k === 'open' || k === 'sqrt-open') depth++;
            else if(k === 'close') depth--;
        }
        return depth;
    }

    function ck_lastKind() {
        if(!ck_tokens.length) return null;
        return ck_tokens[ck_tokens.length-1].kind;
    }

    function ck_lastIsOp() {
        var lk = ck_lastKind();
        return lk === 'op' || lk === 'sqrt-open' || lk === 'open';
    }
    function ck_lastIsNum() {
        var lk = ck_lastKind();
        return lk === 'num' || lk === 'close' || lk === 'pi';
    }

    function ck_clearCalcError() {
        ckError.style.display = 'none';
        ckError.innerText = '';
    }
    function ck_showCalcError(msg) {
        ckError.style.display = 'block';
        ckError.innerText = msg;
        var d = getDark();
        ckError.style.background  = d ? '#3a1010' : '#fff5f5';
        ckError.style.borderColor = d ? '#883333' : '#f5c2c2';
        ckError.style.color       = d ? '#ff8080' : '#c0392b';
    }

    function ck_insertPendingCloses() {
        if(!ck_inferBrackets) return;
        var pending = ck_pendingAutoCloses();
        for(var i = pending.length - 1; i >= 0; i--) {
            ck_tokens.push({
                e: ')', d: ')', kind: 'close',
                isAutoClose: true, autoCloseId: pending[i].id
            });
        }
    }

    function ck_evaluate() {
        if(!ck_tokens.length) return;
        ck_clearCalcError();

        ck_insertPendingCloses();

        var s = ck_buildStrings();
        var evalStr = s.e.replace(/π/g, '(' + Math.PI + ')');

        try {
            var result = Function('"use strict"; return (' + evalStr + ')')();
            if(!isFinite(result)) { ck_showCalcError('Cannot divide by zero'); return; }
            if(isNaN(result))     { ck_showCalcError('Invalid expression'); return; }
            var rounded = parseFloat(result.toPrecision(12));
            ckExpr.innerText = s.d + ' =';
            ck_tokens = [{ e: String(rounded), d: String(rounded), kind: 'num' }];
            ck_justEvaled = true;
            ck_renderDisplay();
        } catch(err) {
            ck_showCalcError('Invalid expression');
        }
    }

    function ck_handleKey(k) {
        ck_clearCalcError();

        if(k === 'C') {
            ck_tokens = [];
            ck_justEvaled = false;
            ck_clearCalcError();
            ckExpr.innerText = '';
            ckDisplay.innerHTML = '<span>0</span>';
            return;
        }

        if(k === '\u232b') {
            if(ck_justEvaled) {
                ck_tokens = [];
                ck_justEvaled = false;
                ckExpr.innerText = '';
                ck_renderDisplay();
                return;
            }
            if(!ck_tokens.length) return;

            var last = ck_tokens[ck_tokens.length - 1];

            if(last.isAutoClose) {
                var closeId = last.autoCloseId;
                ck_tokens.pop();
                for(var i = ck_tokens.length - 1; i >= 0; i--) {
                    if(ck_tokens[i].kind === 'sqrt-open' && ck_tokens[i].autoCloseId === closeId) {
                        ck_tokens[i].closingDeleted = true;
                        break;
                    }
                }
                ck_renderDisplay();
                return;
            }

            if(last.kind === 'sqrt-open') {
                var openId = last.autoCloseId;
                var closeIdx = -1;
                for(var j = ck_tokens.length - 1; j >= 0; j--) {
                    if(ck_tokens[j].isAutoClose && ck_tokens[j].autoCloseId === openId) {
                        closeIdx = j; break;
                    }
                }
                if(closeIdx >= 0) {
                    ck_tokens.splice(closeIdx, 1);
                }
                ck_tokens.pop();
                ck_renderDisplay();
                return;
            }

            ck_tokens.pop();
            ck_renderDisplay();
            return;
        }

        if(k === '=') {
            ck_evaluate();
            return;
        }

        if(ck_justEvaled) {
            var isOp  = (k==='+' || k==='-' || k==='\u00d7' || k==='\u00f7');
            if(!isOp) {
                ck_tokens = [];
                ckExpr.innerText = '';
            }
            ck_justEvaled = false;
        }

        var isOperator = (k==='+' || k==='\u00d7' || k==='\u00f7');
        if(isOperator && ck_lastIsNum()) {
            ck_insertPendingCloses();
        }

        if(k === '(') {
            ck_tokens.push({ e:'(', d:'(', kind:'open' });

        } else if(k === ')') {
            if(ck_openDepth() > 0) {
                var innermostOpen = null;
                var innermostIdx = -1;
                var depthCheck = 0;
                for(var ci = 0; ci < ck_tokens.length; ci++) {
                    var ck = ck_tokens[ci].kind;
                    if(ck === 'open' || ck === 'sqrt-open') { depthCheck++; innermostOpen = ck_tokens[ci]; innermostIdx = ci; }
                    else if(ck === 'close') { depthCheck--; }
                }
                if(ck_inferBrackets && innermostOpen && innermostOpen.kind === 'sqrt-open' && !innermostOpen.closingDeleted) {
                    innermostOpen.closingDeleted = true;
                    ck_tokens.push({ e:')', d:')', kind:'close',
                        realizedFromId: innermostOpen.autoCloseId });
                } else {
                    ck_tokens.push({ e:')', d:')', kind:'close' });
                }
            }

        } else if(k === '+') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'+', d:'+', kind:'op' });
            }

        } else if(k === '-') {
            ck_tokens.push({ e:'-', d:'-', kind:'op' });

        } else if(k === '\u00d7') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }

        } else if(k === '\u00f7') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'/', d:'\u00f7', kind:'op' });
            }

        } else if(k === '\u221a') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            var id = ck_newId();
            ck_tokens.push({
                e: 'Math.sqrt(', d: '\u221a(',
                kind: 'sqrt-open',
                autoCloseId: id,
                closingDeleted: false
            });

        } else if(k === '\u03c0') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            ck_tokens.push({ e:'π', d:'\u03c0', kind:'pi' });

        } else if(k === '.') {
            var lastNumTok = null;
            for(var ni = ck_tokens.length - 1; ni >= 0; ni--) {
                if(ck_tokens[ni].kind === 'num') { lastNumTok = ck_tokens[ni]; break; }
                if(ck_tokens[ni].kind !== 'num') break;
            }
            var lastTokIsNum = ck_lastKind() === 'num';
            if(lastTokIsNum && ck_tokens[ck_tokens.length-1].e.indexOf('.') < 0) {
                ck_tokens[ck_tokens.length-1].e += '.';
                ck_tokens[ck_tokens.length-1].d += '.';
            } else if(!lastTokIsNum) {
                ck_tokens.push({ e:'0.', d:'0.', kind:'num' });
            }

        } else {
            if(ck_lastKind() === 'num') {
                var nt = ck_tokens[ck_tokens.length-1];
                if(nt.e === '0') { nt.e = k; nt.d = k; }
                else { nt.e += k; nt.d += k; }
            } else {
                ck_tokens.push({ e: k, d: k, kind: 'num' });
            }
        }

        ck_renderDisplay();
    }

    document.querySelectorAll('.ck').forEach(function(btn){
        btn.addEventListener('click', function(e) {
