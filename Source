        if(sm.style.display!=='none'&&!sm.contains(e.target)&&e.target!==sb) sm.style.display='none';
        if(hm.style.display!=='none'&&!hm.contains(e.target)&&e.target!==hb) hm.style.display='none';
        // Only close the calculator if: not pinned AND click was outside AND not the toggle button
        var pinEl = get('calcPinOpen');
        var isPinned = pinEl && pinEl.checked;
        var clickedInside = _calcClickedInside;
        _calcClickedInside = false; // reset for next click
