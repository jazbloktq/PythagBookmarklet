                cx2.strokeStyle=col;cx2.lineWidth=1.8;cx2.stroke();
            }
            function lbl3d(px,py,t,accent){
                cx2.font='bold 10px system-ui,sans-serif';
                var tw=cx2.measureText(t).width;
                cx2.fillStyle=d?'rgba(8,12,28,0.82)':'rgba(255,255,255,0.88)';
                cx2.beginPath();if(cx2.roundRect)cx2.roundRect(px-tw/2-3,py-7,tw+6,13,3);else cx2.rect(px-tw/2-3,py-7,tw+6,13);
                cx2.fill();cx2.fillStyle=accent?unk:lc;cx2.fillText(t,px-tw/2,py+3);
            }
            var bpd=[pt3d(0,0,0),pt3d(ld,0,0),pt3d(ld,0,wd),pt3d(0,0,wd)];
            var tpd=[pt3d(0,hvd,0),pt3d(ld,hvd,0),pt3d(ld,hvd,wd),pt3d(0,hvd,wd)];
            seg3d(bpd[0],bpd[1],true);seg3d(bpd[0],bpd[3],true);seg3d(bpd[0],tpd[0],true);
            poly3d([tpd[0],tpd[1],tpd[2],tpd[3]],fill3d);
            poly3d([bpd[3],bpd[2],tpd[2],tpd[3]],fillSide3d);
            poly3d([bpd[2],bpd[1],tpd[1],tpd[2]],fill3d);
            seg3d(bpd[1],bpd[2],false);seg3d(bpd[2],bpd[3],false);
            seg3d(bpd[1],tpd[1],false);seg3d(bpd[2],tpd[2],false);seg3d(bpd[3],tpd[3],false);
            for(var tiid=0;tiid<4;tiid++)seg3d(tpd[tiid],tpd[(tiid+1)%4],false);
            var dA=pt3d(ld,0,0),dB=pt3d(0,hvd,wd);
            seg3d(dA,dB,false,unk,[7,4]);
            cx2.beginPath();cx2.arc(dA[0],dA[1],3,0,2*Math.PI);cx2.fillStyle=unk;cx2.fill();
            cx2.beginPath();cx2.arc(dB[0],dB[1],3,0,2*Math.PI);cx2.fillStyle=unk;cx2.fill();
            lbl3d((bpd[2][0]+bpd[3][0])/2,(bpd[2][1]+bpd[3][1])/2+12,'l='+ld,false);
            lbl3d((bpd[1][0]+bpd[2][0])/2+10,(bpd[1][1]+bpd[2][1])/2+6,'w='+wd,false);
            lbl3d((bpd[2][0]+tpd[2][0])/2+14,(bpd[2][1]+tpd[2][1])/2,'h='+hvd,false);
            lbl3d((dA[0]+dB[0])/2-14,(dA[1]+dB[1])/2-12,'x=?',true);
        }
    }

