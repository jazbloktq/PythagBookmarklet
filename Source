        var W=canvas.width,H=canvas.height;
        var padT=38,padB=52,padL=52,padR=52;
        var minX=raw[0][0],maxX=raw[0][0];
        for(var i=1;i<3;i++){if(raw[i][0]<minX)minX=raw[i][0];if(raw[i][0]>maxX)maxX=raw[i][0];}
        var rangeX=maxX-minX||1,rangeY=h||1;
        var scale2=Math.min((W-padL-padR)/rangeX,(H-padT-padB)/rangeY);
        var offX2=(W-rangeX*scale2)/2-minX*scale2,offY2=padT+(H-padT-padB-rangeY*scale2)/2;
        function tr2(pt){return[pt[0]*scale2+offX2,pt[1]*scale2+offY2];}
