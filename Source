    // ── Right-triangle diagram ────────────────────────────────────────
    function _trigDrawDiagramRight(ctx2, W, H, res) {
        var d = getDark(), bw = getBW();
        var bg  = bw?'#fff':(d?'#181828':'#fafbff');
        var ln  = bw?'#000':(d?'#8888bb':'#aab0cc');
        var acc = bw?'#000':(d?'#4a9eff':'#1a73e8');
        var lbl = bw?'#000':(d?'#e0e0f0':'#222');
        var sub = bw?'#444':(d?'#9090b0':'#666');
        ctx2.fillStyle=bg; ctx2.fillRect(0,0,W,H);

        var prec=getPrec(), deg=getDeg(), aLbl=deg?'°':'r';
        var outer = getOuterAngles();
        var extFull = deg ? 180 : Math.PI;
        function fmtV(id,isAngle,fallback) {
            var v = (res && res[id]!==undefined) ? res[id] : NaN;
            if(isNaN(v)) { var el=get('trigIn_'+id); v=el?parseFloat(el.value):NaN; }
            if(isNaN(v)) return fallback||'?';
            if(isAngle && outer) v = extFull - v;
            return isAngle ? parseFloat(v.toFixed(Math.min(prec,2)))+aLbl : parseFloat(v.toFixed(Math.min(prec,3)))+'';
        }
        var aVal = (res&&res.a!==undefined)?res.a:NaN;
        var bVal = (res&&res.b!==undefined)?res.b:NaN;
        if(isNaN(aVal)){var el=get('trigIn_a');if(el)aVal=parseFloat(el.value);}
        if(isNaN(bVal)){var el=get('trigIn_b');if(el)bVal=parseFloat(el.value);}
        if(isNaN(aVal)||isNaN(bVal)||aVal<=0||bVal<=0){aVal=3;bVal=4;}
        var maxSide=Math.max(aVal,bVal), na=aVal/maxSide, nb=bVal/maxSide;
        var pad={l:54,r:50,t:36,b:36};
        var drawW=W-pad.l-pad.r, drawH=H-pad.t-pad.b;
        var scale=Math.min(drawW/nb,drawH/na);
        var bPx=nb*scale, aPx=na*scale;
        var offX=pad.l+(drawW-bPx)/2, offY=pad.t+(drawH-aPx)/2;
        var ox=offX, oy=offY+aPx, bx=offX+bPx, by=oy, tx=offX, ty=offY;
        var rmk=Math.min(12,bPx*0.12,aPx*0.12);
        ctx2.strokeStyle=ln; ctx2.lineWidth=1.2;
        ctx2.beginPath(); ctx2.moveTo(ox+rmk,oy); ctx2.lineTo(ox+rmk,oy-rmk); ctx2.lineTo(ox,oy-rmk); ctx2.stroke();
        ctx2.strokeStyle=acc; ctx2.lineWidth=2.2;
        ctx2.beginPath(); ctx2.moveTo(ox,oy); ctx2.lineTo(bx,by); ctx2.lineTo(tx,ty); ctx2.closePath(); ctx2.stroke();
        var th_to_top=Math.atan2(ty-by,tx-bx), th_to_left=Math.atan2(oy-by,ox-bx);
        ctx2.strokeStyle=bw?'#555':(d?'#f0a040':'#d97706'); ctx2.lineWidth=1.5;
        ctx2.beginPath(); ctx2.arc(bx,by,Math.min(22,bPx*0.18),th_to_top,th_to_left,!outer); ctx2.stroke();
        var al_to_bot=Math.atan2(oy-ty,ox-tx), al_to_right=Math.atan2(by-ty,bx-tx);
        ctx2.strokeStyle=bw?'#888':(d?'#60c060':'#22a05a'); ctx2.lineWidth=1.5;
        ctx2.beginPath(); ctx2.arc(tx,ty,Math.min(20,aPx*0.18),al_to_bot,al_to_right,!outer); ctx2.stroke();
        ctx2.textAlign='center';
        ctx2.fillStyle=acc; ctx2.font='bold 11px system-ui,sans-serif';
        var hypAngle=Math.atan2(ty-by,tx-bx);
        var hypMx=(bx+tx)/2, hypMy=(by+ty)/2;
        var hypNx=Math.sin(hypAngle), hypNy=-Math.cos(hypAngle);
        ctx2.save(); ctx2.translate(hypMx+hypNx*16,hypMy+hypNy*16); ctx2.rotate(hypAngle); ctx2.fillText('c = '+fmtV('hyp',false),0,0); ctx2.restore();
        ctx2.fillStyle=lbl;
        ctx2.save(); ctx2.translate(ox-16,(oy+ty)/2); ctx2.rotate(-Math.PI/2); ctx2.fillText('a = '+fmtV('a',false),0,0); ctx2.restore();
        ctx2.fillText('b = '+fmtV('b',false),(ox+bx)/2,oy+16);
        ctx2.font='11px system-ui,sans-serif';
        ctx2.fillStyle=bw?'#555':(d?'#f0a040':'#d97706'); ctx2.fillText((outer?'ext-θ':'θ')+'='+fmtV('B',true),Math.min(bx-8,W-52),by-24);
        ctx2.fillStyle=bw?'#888':(d?'#60c060':'#22a05a'); ctx2.fillText((outer?'ext-α':'α')+'='+fmtV('A',true),Math.max(tx+8,38),Math.max(ty+22,20));
        ctx2.fillStyle=sub; ctx2.font='10px system-ui,sans-serif'; ctx2.fillText('90°',ox+rmk+14,oy-rmk-2);
    }

    // ── Any-triangle diagram (with altitude) ─────────────────────────
    function _trigDrawDiagramAny(ctx2, W, H, res) {
        var d = getDark(), bw = getBW();
        var bg      = bw?'#fff':(d?'#181828':'#fafbff');
        var acc     = bw?'#000':(d?'#4a9eff':'#1a73e8');
        var ln      = bw?'#000':(d?'#8888bb':'#aab0cc');
        var lbl     = bw?'#000':(d?'#e0e0f0':'#222');
        var alt_col = bw?'#888':(d?'#cc88ff':'#9333ea');
        ctx2.fillStyle=bg; ctx2.fillRect(0,0,W,H);

        var R=res||{}, sa=R.sa, sb=R.sb, sc=R.sc, AA=R.AA, AB=R.AB, AC=R.AC;
        var deg=getDeg(), toRad=function(x){return deg?x*Math.PI/180:x;};
        var prec=getPrec(), aLbl=deg?'°':'r';
        function fv(v){return v!==undefined?parseFloat(v.toFixed(Math.min(prec,3)))+'':'?';}
        function fa(v){return v!==undefined?parseFloat(v.toFixed(Math.min(prec,2)))+aLbl:'?';}

        // Derive angle A in radians for vertex placement
        var AA_rad=null;
        if(AA!==undefined) AA_rad=toRad(AA);
        else if(sa&&sb&&sc) AA_rad=Math.acos(Math.min(1,Math.max(-1,(sb*sb+sc*sc-sa*sa)/(2*sb*sc))));
        if(AA_rad===null||isNaN(AA_rad)) AA_rad=Math.PI/3;

        // Clamp to sane range so triangle is always visible
        AA_rad=Math.max(0.12,Math.min(Math.PI-0.24,AA_rad));

        // World coords: A=(0,0), B=(sc,0), C=(sb*cosA, sb*sinA)
        var useC=(sc&&sc>0)?sc:10;
        var useSB=(sb&&sb>0)?sb:useC*0.8;
        var Ax=0, Ay=0, Bx=useC, By=0;
        var Cx=Math.cos(AA_rad)*useSB, Cy=Math.sin(AA_rad)*useSB;
        if(Cy<0.01*useC) Cy=0.01*useC;

        // Fit to canvas with padding
        var pad=44;
        var pts=[[Ax,Ay],[Bx,By],[Cx,Cy]];
        var minX=Ax,maxX=Ax,minY=Ay,maxY=Ay;
        pts.forEach(function(p){
            if(p[0]<minX)minX=p[0]; if(p[0]>maxX)maxX=p[0];
            if(p[1]<minY)minY=p[1]; if(p[1]>maxY)maxY=p[1];
        });
        var rangeX=maxX-minX||1, rangeY=maxY-minY||1;
        var sc2=Math.min((W-pad*2)/rangeX,(H-pad*2)/rangeY);
        var drawW=rangeX*sc2, drawH=rangeY*sc2;
        var ofsX=(W-drawW)/2-minX*sc2;
        var ofsY=(H+drawH)/2+minY*sc2;
        function toCanv(wx,wy){return [ofsX+wx*sc2, ofsY-wy*sc2];}

        var PA=toCanv(Ax,Ay),PB=toCanv(Bx,By),PC=toCanv(Cx,Cy);
        var PAx=PA[0],PAy=PA[1],PBx=PB[0],PBy=PB[1],PCx=PC[0],PCy=PC[1];

        // Altitude from C perpendicular to AB (AB is horizontal after transform)
        var PHx=PCx, PHy=PAy;
        var altLen=Math.abs(PHy-PCy);
        var rmk=Math.min(9,altLen*0.12);
        if(altLen>15){
            ctx2.strokeStyle=alt_col; ctx2.lineWidth=1.3; ctx2.setLineDash([4,3]);
            ctx2.beginPath(); ctx2.moveTo(PCx,PCy); ctx2.lineTo(PHx,PHy); ctx2.stroke();
            ctx2.setLineDash([]);
            if(rmk>3){
                var hDir=PHx>PAx+1?1:-1;
                ctx2.strokeStyle=ln; ctx2.lineWidth=1;
                ctx2.beginPath(); ctx2.moveTo(PHx-hDir*rmk,PHy); ctx2.lineTo(PHx-hDir*rmk,PHy-rmk); ctx2.lineTo(PHx,PHy-rmk); ctx2.stroke();
            }
        }

        // Main triangle
        ctx2.strokeStyle=acc; ctx2.lineWidth=2.2;
        ctx2.beginPath(); ctx2.moveTo(PAx,PAy); ctx2.lineTo(PBx,PBy); ctx2.lineTo(PCx,PCy); ctx2.closePath(); ctx2.stroke();

        // Angle arcs
        var colA=bw?'#555':(d?'#f0a040':'#d97706');
        var colB=bw?'#888':(d?'#60c060':'#22a05a');
        var colC=bw?'#aaa':(d?'#60bbff':'#1a73e8');
        var arcR=Math.min(20,drawW*0.07,drawH*0.12);
        function drawArc(vx,vy,p1x,p1y,p2x,p2y,r,col,ccw){
            var a1=Math.atan2(p1y-vy,p1x-vx),a2=Math.atan2(p2y-vy,p2x-vx);
            ctx2.strokeStyle=col; ctx2.lineWidth=1.5;
            ctx2.beginPath(); ctx2.arc(vx,vy,r,a1,a2,ccw||false); ctx2.stroke();
        }
        drawArc(PAx,PAy,PBx,PBy,PCx,PCy,arcR,colA,false);
        drawArc(PBx,PBy,PAx,PAy,PCx,PCy,arcR,colB,true);
        drawArc(PCx,PCy,PAx,PAy,PBx,PBy,Math.min(arcR,14),colC,false);

        // Edge labels — offset away from opposite vertex
        ctx2.font='bold 11px system-ui,sans-serif'; ctx2.textAlign='center';
        function edgeLbl(x1,y1,x2,y2,ox,oy,text,col){
            var mx=(x1+x2)/2,my=(y1+y2)/2;
            var nx=mx-ox,ny=my-oy,len=Math.sqrt(nx*nx+ny*ny)||1;
            ctx2.fillStyle=col;
            var ex=mx+nx/len*15, ey=my+ny/len*15;
            ctx2.save(); ctx2.translate(ex,ey); ctx2.rotate(Math.atan2(y2-y1,x2-x1));
            ctx2.fillText(text,0,0); ctx2.restore();
        }
        edgeLbl(PAx,PAy,PBx,PBy,PCx,PCy,'c='+(sc!==undefined?fv(sc):'?'),acc);
        edgeLbl(PAx,PAy,PCx,PCy,PBx,PBy,'b='+(sb!==undefined?fv(sb):'?'),lbl);
        edgeLbl(PBx,PBy,PCx,PCy,PAx,PAy,'a='+(sa!==undefined?fv(sa):'?'),lbl);

        // Angle labels — along inward bisector from each vertex
        ctx2.font='10px system-ui,sans-serif';
        function angleLbl(vx,vy,p1x,p1y,p2x,p2y,text,col){
            var a1=Math.atan2(p1y-vy,p1x-vx),a2=Math.atan2(p2y-vy,p2x-vx);
            var bisect=(a1+a2)/2;
            var cx=(PAx+PBx+PCx)/3,cy=(PAy+PBy+PCy)/3;
            if(Math.cos(bisect)*(cx-vx)+Math.sin(bisect)*(cy-vy)<0) bisect+=Math.PI;
            var off=arcR+14;
            ctx2.fillStyle=col;
            ctx2.fillText(text,vx+Math.cos(bisect)*off,vy+Math.sin(bisect)*off);
        }
        angleLbl(PAx,PAy,PBx,PBy,PCx,PCy,'A='+(AA!==undefined?fa(AA):'?'),colA);
        angleLbl(PBx,PBy,PAx,PAy,PCx,PCy,'B='+(AB!==undefined?fa(AB):'?'),colB);
        angleLbl(PCx,PCy,PAx,PAy,PBx,PBy,'C='+(AC!==undefined?fa(AC):'?'),colC);

        // Altitude label
        if(altLen>15){
            ctx2.fillStyle=alt_col; ctx2.font='9px system-ui,sans-serif'; ctx2.textAlign='left';
            ctx2.fillText('h',PHx+(PHx>(PAx+PBx)/2?-12:5),PCy+altLen*0.45);
        }
    }

    function _trigDrawDiagram(res) {
        var c=get('trigCanvas'); if(!c) return;
        var ctx2=c.getContext('2d');
        var W=c.width, H=c.height;
        ctx2.clearRect(0,0,W,H);
        if(_trigMode==='right') _trigDrawDiagramRight(ctx2,W,H,res);
        else _trigDrawDiagramAny(ctx2,W,H,res);
    }

    // ── Right-triangle solver ─────────────────────────────────────────
    function _solveRight() {
        var deg=getDeg();
        var toRad=function(x){return deg?x*Math.PI/180:x;};
        var toDeg=function(x){return deg?x*180/Math.PI:x;};
        var R={};
        ['a','b','hyp','A','B'].forEach(function(k){
            var el=get('trigIn_'+k); if(!el) return;
            var v=parseFloat(el.value);
            if(!isNaN(v)&&el.value.trim()!=='') R[k]=v;
        });
        if(Object.keys(R).length<2) return {error:'Enter at least 2 known values.'};
        var steps=[];
        for(var pass=0;pass<6;pass++){
            if(R.a!==undefined&&R.b!==undefined&&R.hyp===undefined){R.hyp=Math.sqrt(R.a*R.a+R.b*R.b);steps.push('c = √(a²+b²) = '+R.hyp.toFixed(6));}
            if(R.a!==undefined&&R.hyp!==undefined&&R.b===undefined){R.b=Math.sqrt(R.hyp*R.hyp-R.a*R.a);steps.push('b = √(c²−a²) = '+R.b.toFixed(6));}
            if(R.b!==undefined&&R.hyp!==undefined&&R.a===undefined){R.a=Math.sqrt(R.hyp*R.hyp-R.b*R.b);steps.push('a = √(c²−b²) = '+R.a.toFixed(6));}
            if(R.A!==undefined&&R.hyp!==undefined&&R.b===undefined){R.b=R.hyp*Math.sin(toRad(R.A));steps.push('b = c·sin(α) = '+R.b.toFixed(6));}
            if(R.A!==undefined&&R.hyp!==undefined&&R.a===undefined){R.a=R.hyp*Math.cos(toRad(R.A));steps.push('a = c·cos(α) = '+R.a.toFixed(6));}
            if(R.A!==undefined&&R.b!==undefined&&R.a===undefined){R.a=R.b/Math.tan(toRad(R.A));steps.push('a = b/tan(α) = '+R.a.toFixed(6));}
            if(R.A!==undefined&&R.a!==undefined&&R.b===undefined){R.b=R.a*Math.tan(toRad(R.A));steps.push('b = a·tan(α) = '+R.b.toFixed(6));}
            if(R.B!==undefined&&R.hyp!==undefined&&R.a===undefined){R.a=R.hyp*Math.sin(toRad(R.B));steps.push('a = c·sin(θ) = '+R.a.toFixed(6));}
            if(R.B!==undefined&&R.hyp!==undefined&&R.b===undefined){R.b=R.hyp*Math.cos(toRad(R.B));steps.push('b = c·cos(θ) = '+R.b.toFixed(6));}
            if(R.B!==undefined&&R.a!==undefined&&R.b===undefined){R.b=R.a/Math.tan(toRad(R.B));steps.push('b = a/tan(θ) = '+R.b.toFixed(6));}
            if(R.B!==undefined&&R.b!==undefined&&R.a===undefined){R.a=R.b*Math.tan(toRad(R.B));steps.push('a = b·tan(θ) = '+R.a.toFixed(6));}
            if(R.A===undefined&&R.b!==undefined&&R.hyp!==undefined){R.A=toDeg(Math.asin(R.b/R.hyp));steps.push('α = arcsin(b/c) = '+R.A.toFixed(6));}
            if(R.A===undefined&&R.a!==undefined&&R.hyp!==undefined){R.A=toDeg(Math.acos(R.a/R.hyp));steps.push('α = arccos(a/c) = '+R.A.toFixed(6));}
            if(R.A===undefined&&R.a!==undefined&&R.b!==undefined){R.A=toDeg(Math.atan2(R.b,R.a));steps.push('α = arctan(b/a) = '+R.A.toFixed(6));}
            if(R.B===undefined&&R.a!==undefined&&R.hyp!==undefined){R.B=toDeg(Math.asin(R.a/R.hyp));steps.push('θ = arcsin(a/c) = '+R.B.toFixed(6));}
            if(R.B===undefined&&R.b!==undefined&&R.hyp!==undefined){R.B=toDeg(Math.acos(R.b/R.hyp));steps.push('θ = arccos(b/c) = '+R.B.toFixed(6));}
            if(R.B===undefined&&R.a!==undefined&&R.b!==undefined){R.B=toDeg(Math.atan2(R.a,R.b));steps.push('θ = arctan(a/b) = '+R.B.toFixed(6));}
            if(R.A!==undefined&&R.B===undefined){R.B=(deg?90:Math.PI/2)-R.A;steps.push('θ = 90°−α = '+R.B.toFixed(6));}
            if(R.B!==undefined&&R.A===undefined){R.A=(deg?90:Math.PI/2)-R.B;steps.push('α = 90°−θ = '+R.A.toFixed(6));}
        }
        if(R.hyp!==undefined&&R.a!==undefined&&R.hyp<R.a-1e-8) return {error:'Hypotenuse must be ≥ side a.'};
        if(R.hyp!==undefined&&R.b!==undefined&&R.hyp<R.b-1e-8) return {error:'Hypotenuse must be ≥ side b.'};
        var prec=getPrec(), aLbl=deg?'°':' rad';
        var outer=getOuterAngles(), extFull=deg?180:Math.PI;
        function fv(v,isA){
            if(v===undefined) return '?';
            var disp = (isA && outer) ? extFull-v : v;
            return parseFloat(disp.toFixed(prec))+(isA?aLbl:'');
        }
        var aLblA = outer ? 'ext-α — exterior angle A (top)' : 'α — angle A (top)';
        var aLblB = outer ? 'ext-θ — exterior angle B (right)' : 'θ — angle B (right)';
        return {
            result:R,
            rows:[
                {label:'a — opposite',value:fv(R.a,false)},
                {label:'b — adjacent',value:fv(R.b,false)},
                {label:'c — hypotenuse',value:fv(R.hyp,false)},
                {label:aLblA,value:fv(R.A,true)},
                {label:aLblB,value:fv(R.B,true)},
            ],
            steps:steps
        };
    }

    // ── Any-triangle solver (sine rule + cosine rule) ─────────────────
    function _solveAny() {
        var deg=getDeg();
        var toRad=function(x){return deg?x*Math.PI/180:x;};
        var toDeg=function(x){return deg?x*180/Math.PI:x;};
        var full=deg?180:Math.PI;
        var R={};
        ['sa','sb','sc','AA','AB','AC'].forEach(function(k){
            var el=get('trigIn_'+k); if(!el) return;
            var v=parseFloat(el.value);
            if(!isNaN(v)&&el.value.trim()!=='') R[k]=v;
        });
        var nKnown=Object.keys(R).length;
        if(nKnown<3) return {error:'Enter at least 3 known values.'};
        var hasSide=R.sa!==undefined||R.sb!==undefined||R.sc!==undefined;
        if(!hasSide) return {error:'At least one side must be known.'};

        var steps=[];
        // Iterative passes: sine rule + cosine rule
        for(var pass=0;pass<8;pass++){
            // A+B+C = 180
            if(R.AA!==undefined&&R.AB!==undefined&&R.AC===undefined){R.AC=full-R.AA-R.AB;steps.push('C = 180°−A−B = '+R.AC.toFixed(6));}
            if(R.AA!==undefined&&R.AC!==undefined&&R.AB===undefined){R.AB=full-R.AA-R.AC;steps.push('B = 180°−A−C = '+R.AB.toFixed(6));}
            if(R.AB!==undefined&&R.AC!==undefined&&R.AA===undefined){R.AA=full-R.AB-R.AC;steps.push('A = 180°−B−C = '+R.AA.toFixed(6));}
            // Sine rule: a/sin(A) = b/sin(B) = c/sin(C)
            if(R.sa!==undefined&&R.AA!==undefined&&R.AB!==undefined&&R.sb===undefined){R.sb=R.sa*Math.sin(toRad(R.AB))/Math.sin(toRad(R.AA));steps.push('b = a·sin(B)/sin(A) = '+R.sb.toFixed(6));}
            if(R.sa!==undefined&&R.AA!==undefined&&R.AC!==undefined&&R.sc===undefined){R.sc=R.sa*Math.sin(toRad(R.AC))/Math.sin(toRad(R.AA));steps.push('c = a·sin(C)/sin(A) = '+R.sc.toFixed(6));}
            if(R.sb!==undefined&&R.AB!==undefined&&R.AA!==undefined&&R.sa===undefined){R.sa=R.sb*Math.sin(toRad(R.AA))/Math.sin(toRad(R.AB));steps.push('a = b·sin(A)/sin(B) = '+R.sa.toFixed(6));}
            if(R.sb!==undefined&&R.AB!==undefined&&R.AC!==undefined&&R.sc===undefined){R.sc=R.sb*Math.sin(toRad(R.AC))/Math.sin(toRad(R.AB));steps.push('c = b·sin(C)/sin(B) = '+R.sc.toFixed(6));}
            if(R.sc!==undefined&&R.AC!==undefined&&R.AA!==undefined&&R.sa===undefined){R.sa=R.sc*Math.sin(toRad(R.AA))/Math.sin(toRad(R.AC));steps.push('a = c·sin(A)/sin(C) = '+R.sa.toFixed(6));}
            if(R.sc!==undefined&&R.AC!==undefined&&R.AB!==undefined&&R.sb===undefined){R.sb=R.sc*Math.sin(toRad(R.AB))/Math.sin(toRad(R.AC));steps.push('b = c·sin(B)/sin(C) = '+R.sb.toFixed(6));}
            // Sine rule: find angles
            if(R.sa!==undefined&&R.AA===undefined&&R.sb!==undefined&&R.AB!==undefined){var v=R.sa*Math.sin(toRad(R.AB))/R.sb;if(Math.abs(v)<=1){R.AA=toDeg(Math.asin(v));steps.push('A = arcsin(a·sin(B)/b) = '+R.AA.toFixed(6));}}
            if(R.sa!==undefined&&R.AA===undefined&&R.sc!==undefined&&R.AC!==undefined){var v=R.sa*Math.sin(toRad(R.AC))/R.sc;if(Math.abs(v)<=1){R.AA=toDeg(Math.asin(v));steps.push('A = arcsin(a·sin(C)/c) = '+R.AA.toFixed(6));}}
            if(R.sb!==undefined&&R.AB===undefined&&R.sa!==undefined&&R.AA!==undefined){var v=R.sb*Math.sin(toRad(R.AA))/R.sa;if(Math.abs(v)<=1){R.AB=toDeg(Math.asin(v));steps.push('B = arcsin(b·sin(A)/a) = '+R.AB.toFixed(6));}}
            if(R.sb!==undefined&&R.AB===undefined&&R.sc!==undefined&&R.AC!==undefined){var v=R.sb*Math.sin(toRad(R.AC))/R.sc;if(Math.abs(v)<=1){R.AB=toDeg(Math.asin(v));steps.push('B = arcsin(b·sin(C)/c) = '+R.AB.toFixed(6));}}
            if(R.sc!==undefined&&R.AC===undefined&&R.sa!==undefined&&R.AA!==undefined){var v=R.sc*Math.sin(toRad(R.AA))/R.sa;if(Math.abs(v)<=1){R.AC=toDeg(Math.asin(v));steps.push('C = arcsin(c·sin(A)/a) = '+R.AC.toFixed(6));}}
            if(R.sc!==undefined&&R.AC===undefined&&R.sb!==undefined&&R.AB!==undefined){var v=R.sc*Math.sin(toRad(R.AB))/R.sb;if(Math.abs(v)<=1){R.AC=toDeg(Math.asin(v));steps.push('C = arcsin(c·sin(B)/b) = '+R.AC.toFixed(6));}}
            // Cosine rule: find sides
            if(R.sb!==undefined&&R.sc!==undefined&&R.AA!==undefined&&R.sa===undefined){R.sa=Math.sqrt(R.sb*R.sb+R.sc*R.sc-2*R.sb*R.sc*Math.cos(toRad(R.AA)));steps.push('a = √(b²+c²−2bc·cos(A)) = '+R.sa.toFixed(6));}
            if(R.sa!==undefined&&R.sc!==undefined&&R.AB!==undefined&&R.sb===undefined){R.sb=Math.sqrt(R.sa*R.sa+R.sc*R.sc-2*R.sa*R.sc*Math.cos(toRad(R.AB)));steps.push('b = √(a²+c²−2ac·cos(B)) = '+R.sb.toFixed(6));}
            if(R.sa!==undefined&&R.sb!==undefined&&R.AC!==undefined&&R.sc===undefined){R.sc=Math.sqrt(R.sa*R.sa+R.sb*R.sb-2*R.sa*R.sb*Math.cos(toRad(R.AC)));steps.push('c = √(a²+b²−2ab·cos(C)) = '+R.sc.toFixed(6));}
            // Cosine rule: find angles from 3 sides
            if(R.sa!==undefined&&R.sb!==undefined&&R.sc!==undefined){
                if(R.AA===undefined){R.AA=toDeg(Math.acos((R.sb*R.sb+R.sc*R.sc-R.sa*R.sa)/(2*R.sb*R.sc)));steps.push('A = arccos((b²+c²−a²)/2bc) = '+R.AA.toFixed(6));}
                if(R.AB===undefined){R.AB=toDeg(Math.acos((R.sa*R.sa+R.sc*R.sc-R.sb*R.sb)/(2*R.sa*R.sc)));steps.push('B = arccos((a²+c²−b²)/2ac) = '+R.AB.toFixed(6));}
                if(R.AC===undefined){R.AC=toDeg(Math.acos((R.sa*R.sa+R.sb*R.sb-R.sc*R.sc)/(2*R.sa*R.sb)));steps.push('C = arccos((a²+b²−c²)/2ab) = '+R.AC.toFixed(6));}
            }
        }
        // Altitude from C to c (base AB): h = b·sin(A) = a·sin(B)
        var altH = undefined;
        if(R.sb!==undefined&&R.AA!==undefined) altH=R.sb*Math.sin(toRad(R.AA));
        else if(R.sa!==undefined&&R.AB!==undefined) altH=R.sa*Math.sin(toRad(R.AB));
        var area = (R.sa!==undefined&&R.sb!==undefined&&R.AC!==undefined) ? 0.5*R.sa*R.sb*Math.sin(toRad(R.AC)) : undefined;

        var prec=getPrec(), aLbl=deg?'°':' rad';
        function fv(v,isA){return v!==undefined?parseFloat(v.toFixed(prec))+(isA?aLbl:''):'?';}
        var rows=[
            {label:'a',value:fv(R.sa,false)},{label:'b',value:fv(R.sb,false)},{label:'c',value:fv(R.sc,false)},
            {label:'A',value:fv(R.AA,true)},{label:'B',value:fv(R.AB,true)},{label:'C',value:fv(R.AC,true)},
        ];
        if(altH!==undefined) rows.push({label:'Altitude h (from C)',value:fv(altH,false)});
        if(area!==undefined) rows.push({label:'Area',value:fv(area,false)+'²'});
        return {result:R, rows:rows, steps:steps};
    }

    function _trigDoSolve() {
        // Easter eggs: check raw input values first
        var _trigAllInputs = ['a','b','hyp','A','B','sa','sb','sc','AA','AB','AC'];
        for(var _ti=0;_ti<_trigAllInputs.length;_ti++){
            var _tel=get('trigIn_'+_trigAllInputs[_ti]);
            if(_tel && _tel.value.trim().toLowerCase()==='space'){ _secretSpaceMode(); return; }
            if(_tel && parseFloat(_tel.value)===360){ _secret360trig(); return; }
        }
        var res = _trigMode==='right' ? _solveRight() : _solveAny();
        var errEl=get('trigError'), resEl=get('trigResults');
        if(res.error){
            errEl.textContent=res.error; errEl.style.display='block';
            resEl.style.display='none';
            _trigDrawDiagram(null); return;
        }
        errEl.style.display='none';
        // Draw diagram with solved values — do NOT fill input boxes
        _trigDrawDiagram(res.result);
        get('trigSummaryRows').innerHTML=res.rows.map(function(row){
            return '<div style="display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--gp-row-bdr);">'
                +'<span style="color:var(--gp-subtext);">'+row.label+'</span>'
                +'<strong style="color:var(--gp-accent);">'+row.value+'</strong></div>';
        }).join('');
        get('trigSteps').textContent=res.steps.join('\n');
        resEl.style.display='block';
    }

    function _trigClearAll() {
        ['a','b','hyp','A','B','sa','sb','sc','AA','AB','AC'].forEach(function(k){
            var el=get('trigIn_'+k); if(el) el.value='';
        });
        get('trigResults').style.display='none';
        get('trigError').style.display='none';
        _trigDrawDiagram(null);
        if(_exampleBanner&&_exampleBanner.parentNode){_exampleBanner.parentNode.removeChild(_exampleBanner);_exampleBanner=null;}
    }

