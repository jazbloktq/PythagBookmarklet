    function _quizGenQuestion() {
        var types=_quizEnabledTypes();
        var type=types[_quizRandInt(0,types.length-1)];
        var a,b,c,question,answer,hint,given,qtype;
        if(type===0) {
            a=_quizRandInt(3,15); b=_quizRandInt(3,15); c=Math.sqrt(a*a+b*b);
            question='Find x, the length of the hypotenuse.';
            answer=parseFloat(c.toPrecision(6)); hint='x = \u221a(a\u00b2 + b\u00b2)';
            given='a = '+a+', b = '+b; qtype='pythag_c';
        } else if(type===1) {
            a=_quizRandInt(3,12); b=_quizRandInt(3,12); c=Math.sqrt(a*a+b*b);
            question='Find x, the missing leg, given the hypotenuse and the other leg.';
            answer=parseFloat(a.toPrecision(6)); hint='x = \u221a(c\u00b2 \u2212 b\u00b2)';
            given='b = '+b+', c = '+parseFloat(c.toPrecision(4)); qtype='pythag_a';
        } else if(type===2) {
            a=_quizRandInt(2,10); b=_quizRandInt(2,10); c=Math.sqrt(a*a+b*b);
            var angA=Math.atan(a/b)*180/Math.PI;
            question='Find x\u00b0, the angle opposite the vertical leg. Give your answer in degrees to 2 dp.';
            answer=parseFloat(angA.toPrecision(5)); hint='x = arctan(opposite / adjacent)';
            given='a = '+a+', b = '+b; qtype='pythag_ang';
        } else if(type===6) {
            var dl=_quizRandInt(2,10),dw=_quizRandInt(2,10),dh=_quizRandInt(2,10);
            var diag=Math.sqrt(dl*dl+dw*dw+dh*dh);
            question='Find x, the space diagonal of this rectangular prism. Round to 2 dp.';
            answer=parseFloat(diag.toFixed(2)); hint='x = \u221a(l\u00b2 + w\u00b2 + h\u00b2)';
            given='l = '+dl+', w = '+dw+', h = '+dh; qtype='3d_diag_rect';
            a=dl; b=dw; c=dh;
        }
        return {type:type,qtype:qtype,a:a,b:b,c:c,question:question,answer:answer,hint:hint,given:given};
    }

    function _quizDrawDiagram(q) {
        var cv=document.getElementById('quizCanvas'); if(!cv) return;
        cv.style.display='block';
        var is3D=(q.qtype==='3d_diag_rect');
        cv.width=cv.offsetWidth||280; cv.height=is3D?180:150;
        var W=cv.width,H=cv.height;
        var cx2=cv.getContext('2d');
        cx2.clearRect(0,0,W,H);
        var d=getDark(),bw=getBW();
        cx2.fillStyle=bw?'#fff':(d?'#181828':'#f8faff'); cx2.fillRect(0,0,W,H);
        var col=bw?'#000':(d?'#4a9eff':'#1a73e8');
        var lc=bw?'#444':(d?'#a0c0ff':'#1a4080');
        var unk=bw?'#000':'#e05010';

        if(q.qtype==='pythag_c'||q.qtype==='pythag_a'||q.qtype==='pythag_ang') {
            var a=q.a,b=q.b;
            var pad=44,ow=W-2*pad,oh=H-2*pad;
            var sc=Math.min(ow/Math.max(b,1),oh/Math.max(a,1));
            var bx=pad,by=H-pad,ax2=pad,ay=H-pad-a*sc,ccx=pad+b*sc,ccy=H-pad;
            cx2.strokeStyle=col; cx2.lineWidth=2;
            cx2.beginPath(); cx2.moveTo(ax2,ay); cx2.lineTo(bx,by); cx2.lineTo(ccx,ccy); cx2.closePath(); cx2.stroke();
            var sq=9; cx2.strokeStyle=bw?'#888':(d?'#5070a0':'#aabbd0'); cx2.lineWidth=1;
            cx2.strokeRect(bx,by-sq,sq,sq);
            cx2.textAlign='center';
            cx2.font='bold 11px system-ui,sans-serif';
            if(q.qtype==='pythag_c'){
                cx2.fillStyle=lc; cx2.fillText('a='+a,(ax2+bx)/2-14,(ay+by)/2);
                cx2.fillText('b='+b,(bx+ccx)/2,by+16);
                cx2.fillStyle=unk; cx2.font='bold 13px system-ui,sans-serif';
                cx2.fillText('x=?',(ax2+ccx)/2+12,(ay+ccy)/2-8);
            } else if(q.qtype==='pythag_a'){
                cx2.fillStyle=unk; cx2.font='bold 13px system-ui,sans-serif';
                cx2.fillText('x=?',(ax2+bx)/2-14,(ay+by)/2);
                cx2.font='bold 11px system-ui,sans-serif';
                cx2.fillStyle=lc; cx2.fillText('b='+b,(bx+ccx)/2,by+16);
                cx2.fillText('c='+parseFloat(q.c.toPrecision(4)),(ax2+ccx)/2+12,(ay+ccy)/2-8);
            } else {
                cx2.fillStyle=lc; cx2.fillText('a='+a,(ax2+bx)/2-14,(ay+by)/2);
                cx2.fillText('b='+b,(bx+ccx)/2,by+16);
                cx2.fillText('c='+parseFloat(q.c.toPrecision(4)),(ax2+ccx)/2+12,(ay+ccy)/2-8);
                cx2.fillStyle=unk; cx2.font='bold 13px system-ui,sans-serif';
                cx2.fillText('x°',ax2-22,ay+18);
                cx2.strokeStyle=unk; cx2.lineWidth=1.5;
                cx2.beginPath(); cx2.arc(ax2,ay,15,Math.PI/2,Math.PI/2+Math.atan2(b*sc,a*sc)); cx2.stroke();
            }
        } else if(q.qtype==='3d_diag_rect') {
            var ld=q.a,wd=q.b,hvd=q.c;
            var fill3d=d?'rgba(30,50,90,0.75)':'rgba(220,235,255,0.75)';
            var fillSide3d=d?'rgba(15,25,55,0.75)':'rgba(190,210,245,0.6)';
            var strokeDim3d=d?'#334466':'#b0c8e8';
            var PAD3d=30;
            var ISO_AXd=0.866,ISO_AYd=0.5,ISO_ZXd=-0.866,ISO_ZYd=0.5;
            function iso3d(x,y,z){return[x*ISO_AXd+z*ISO_ZXd,x*ISO_AYd+z*ISO_ZYd-y];}
            var verts3d=[[0,0,0],[ld,0,0],[ld,0,wd],[0,0,wd],[0,hvd,0],[ld,hvd,0],[ld,hvd,wd],[0,hvd,wd]];
            var raw3d=verts3d.map(function(v){return iso3d(v[0],v[1],v[2]);});
            var mnX3d=Infinity,mxX3d=-Infinity,mnY3d=Infinity,mxY3d=-Infinity;
            raw3d.forEach(function(p){mnX3d=Math.min(mnX3d,p[0]);mxX3d=Math.max(mxX3d,p[0]);mnY3d=Math.min(mnY3d,p[1]);mxY3d=Math.max(mxY3d,p[1]);});
            var spX3d=mxX3d-mnX3d||1,spY3d=mxY3d-mnY3d||1;
            var sc3d=Math.min((W-PAD3d*2)/spX3d,(H-PAD3d*2)/spY3d);
            var oX3d=PAD3d+(W-PAD3d*2-spX3d*sc3d)/2-mnX3d*sc3d;
            var oY3d=PAD3d+(H-PAD3d*2-spY3d*sc3d)/2-mnY3d*sc3d;
            function pt3d(x,y,z){var p=iso3d(x,y,z);return[p[0]*sc3d+oX3d,p[1]*sc3d+oY3d];}
            function seg3d(p1,p2,dim,strokeCol,dash){
                cx2.beginPath();cx2.moveTo(p1[0],p1[1]);cx2.lineTo(p2[0],p2[1]);
                cx2.strokeStyle=strokeCol||(dim?strokeDim3d:col);cx2.lineWidth=dim?1.2:1.8;
                cx2.setLineDash(dash||(dim?[5,4]:[]));cx2.stroke();cx2.setLineDash([]);
            }
            function poly3d(pts,fs){
                cx2.beginPath();cx2.moveTo(pts[0][0],pts[0][1]);
                for(var i=1;i<pts.length;i++)cx2.lineTo(pts[i][0],pts[i][1]);
