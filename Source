            if(hypIn<=legA||hypIn<=legB){showError('Check your values','Hypotenuse must be larger than both legs.');return;}
            var hypCalc=Math.sqrt(legA*legA+legB*legB);
            var isRightTri=Math.abs(hypCalc-hypIn)/hypIn<0.001;
            var trip=checkTriple(legA,legB,hypIn);
            s1=legA;b=legB;s2=hypIn;h=legA;
            area=0.5*legA*legB;perim=legA+legB+hypIn;
            if(!isRightTri){showError('Not a right triangle','These sides do not satisfy a² + b² = c². Check your values.');return;}
            if(trip){
                res=hypIn;
                formula='Checking: '+legA+'\u00b2 + '+legB+'\u00b2 = '+hypIn+'\u00b2\n'+(legA*legA)+' + '+(legB*legB)+' = '+(hypIn*hypIn)+'\n\u2713 Valid right triangle\n\u2605 Pythagorean triple: '+trip;
                get('tripleBox').innerText='\u2605 Pythagorean triple: '+trip;
                get('tripleBox').style.display='block';
            } else {
                res=hypIn;
                formula='Checking: '+legA+'\u00b2 + '+legB+'\u00b2 = '+hypIn+'\u00b2\n'+(legA*legA)+' + '+(legB*legB)+' = '+(hypIn*hypIn)+'\n\u2713 Valid right triangle\n\u2715 Not a Pythagorean triple (sides are not integer ratios)';
                get('tripleBox').innerText='\u2715 Not a Pythagorean triple';
                get('tripleBox').style.display='block';
            }
            var angArr=computeAngles(s1,b,s2);
            var anglesForCanvas=[angArr[2],angArr[1],angArr[0]];
            get('res').style.display='block';
            get('final').innerText=trip?trip:'Not a triple';
            get('finalApprox').style.display='none';
            get('formulaText').innerText=formula;
            get('areaRes').innerText=area.toFixed(p);
            get('perimRes').innerText=perim.toFixed(p);
            var classTag=get('classTag');
            classTag.innerText='Right';classTag.style.display='inline-block';
            var anglesContent=get('anglesContent'); anglesContent.innerHTML='';
            var names=['A','B','C']; var d2=getDark();
            angArr.forEach(function(ang,i){var sp=document.createElement('span');sp.style.cssText='font-weight:600;color:'+(d2?'#4a9eff':'#1a73e8')+';';sp.innerText=names[i]+' = '+fmtAngle(ang);anglesContent.appendChild(sp);});
            get('anglesBox').style.display='block';
            drawTri(s1,h,b,s2,false,anglesForCanvas);
            applyDark();
            history.unshift({label:'Py. Triple: '+(trip||'Not a triple'),tri:currentTri,goal:currentGoal,method:currentMethod,inputs:vals.map(String),isExt:false,finalText:trip?trip:'Not a triple',approxText:'',approxVis:'none',formula:formula,area:area.toFixed(p),perim:perim.toFixed(p),ds1:s1,dh:h,db:b,ds2:s2,anglesForCanvas:anglesForCanvas});
            if(history.length>10)history.pop();
            get('histList').innerHTML=history.map(function(hh){return'<span style="display:block;padding:3px 0;border-bottom:1px solid #f0f0f0;">'+(hh.label||hh)+'</span>';}).join('');
            saveSettings();
            return;
        }

        try{
        if(type==='sc_b_shs'){
            s1=v0;h=v1;s2=v2;
            if(h>=s1){showError('Impossible','Height must be less than Side 1.');return;}
            if(h>=s2){showError('Impossible','Height must be less than Side 2.');return;}
            var xA=Math.sqrt(s1*s1-h*h),xB=Math.sqrt(s2*s2-h*h);
            res=isExt?Math.abs(xA-xB):(xA+xB);b=res;
            formula='Part1 = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xA)+'\nPart2 = \u221a('+s2+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xB)+'\nBase = '+fmtS(xA)+(isExt?' \u2212 ':' + ')+fmtS(xB)+' = '+fmtS(res);
        }else if(type==='sc_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Base = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='sc_s_shb'){
            s1=v0;h=v1;b=v2;
            if(h>=s1){showError('Impossible','Height must be less than Known Side.');return;}
            var xxS=Math.sqrt(s1*s1-h*h);
            if(isExt){
                if(xxS<=b){showError('Impossible','Side\'s reach must exceed base.');return;}
                res=Math.sqrt(b*b+h*h);s2=res;
                formula='Reach = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xxS)+'\nSide 2 = \u221a('+b+'\u00b2 + '+h+'\u00b2) = '+fmtS(res);
            }else{
                var yS=Math.abs(b-xxS);res=Math.sqrt(yS*yS+h*h);s2=res;
                formula='Reach = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(xxS)+'\nSeg = |'+b+' \u2212 '+fmtS(xxS)+'| = '+fmtS(yS)+'\nSide 2 = \u221a('+fmtS(yS)+'\u00b2 + '+h+'\u00b2) = '+fmtS(res);
            }
        }else if(type==='sc_s_hb'){
            h=v0;b=v1;res=Math.sqrt(h*h+b*b);s1=res;s2=res;
            formula='Side = \u221a(h\u00b2 + seg\u00b2)\n= \u221a('+h+'\u00b2 + '+b+'\u00b2) = '+fmtS(res);
        }else if(type==='sc_h_ab'){
            res=(2*v0)/v1;h=res;b=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Height = (2 \u00d7 Area) / Base\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='sc_h_ssb'){
            s1=v0;s2=v1;b=v2;
            if(b/2>=s1){showError('Impossible','Base is too wide for Side 1.');return;}
            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(S1\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='sc_a_heron'||type==='is_a_heron'){
            s1=v0;s2=v1;b=v2;
            var sv=(s1+s2+b)/2;
            var areaH=Math.sqrt(sv*(sv-s1)*(sv-s2)*(sv-b));
            if(isNaN(areaH)||areaH<=0){showError('Impossible','These sides don\'t form a valid triangle.');return;}
            res=areaH;area=areaH;h=(2*areaH)/b;perim=s1+s2+b;
            formula="Heron's: s = ("+s1+'+'+s2+'+'+b+') / 2 = '+sv.toFixed(p)+'\nArea = \u221a(s(s\u2212a)(s\u2212b)(s\u2212c))\n= \u221a('+sv.toFixed(p)+'\u00d7'+(sv-s1).toFixed(p)+'\u00d7'+(sv-s2).toFixed(p)+'\u00d7'+(sv-b).toFixed(p)+')\n= '+fmtS(res);
        }else if(type==='is_b_sh'){
            s1=v0;h=v1;s2=v0;
            if(h>=s1){showError('Impossible','Height must be less than Leg.');return;}
            var hfI=Math.sqrt(s1*s1-h*h);res=2*hfI;b=res;
            formula='Half-base = \u221a('+s1+'\u00b2 \u2212 '+h+'\u00b2) = '+fmtS(hfI)+'\nBase = 2 \u00d7 '+fmtS(hfI)+' = '+fmtS(res);
        }else if(type==='is_b_ah'){
            res=(2*v0)/v1;b=res;h=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Base = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='is_b_al'){
            var Ai=v0,Si=v1,inner=4*Si*Si*Si*Si-16*Ai*Ai;
            if(inner<0){showError('Impossible','Area too large for that leg.');return;}
            var u=2*Si*Si-Math.sqrt(inner);
            if(u<=0){showError('Impossible','No valid solution.');return;}
            res=Math.sqrt(u);b=res;s1=Si;s2=Si;h=(2*Ai)/b;
            formula='b\u00b2 = 2s\u00b2 \u2212 \u221a(4s\u2074\u22124A\u00b2)\nBase = \u221a'+fmtS(res);
        }else if(type==='is_s_bh'){
            b=v0;h=v1;res=Math.sqrt(h*h+(b/2)*(b/2));s1=res;s2=res;
            formula='Leg = \u221a(h\u00b2 + (b/2)\u00b2)\n= \u221a('+h+'\u00b2 + '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='is_s_ab'){
            var Ais=v0,bis=v1;h=(2*Ais)/bis;res=Math.sqrt(h*h+(bis/2)*(bis/2));s1=res;s2=res;b=bis;
            formula='h = 2A/b = '+fmtS(h)+'\nLeg = \u221a(h\u00b2+(b/2)\u00b2) = '+fmtS(res);
        }else if(type==='is_h_bl'){
            b=v0;s1=v1;s2=v1;
            if(b/2>=s1){showError('Impossible','Base too wide for Leg.');return;}
            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(Leg\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='is_h_ab'){
            res=(2*v0)/v1;h=res;b=v1;s1=Math.sqrt(h*h+(b/2)*(b/2));s2=s1;
            formula='Height = (2 \u00d7 Area) / Base\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='eq_h_s'){
            var side=v0;b=side;s1=side;s2=side;h=Math.sqrt(3)/2*side;
            res=currentGoal==='height'?h:side;
            formula='Height = (\u221a3 / 2) \u00d7 '+side+(useSurd?' = '+fmtS(h):' \u2248 '+h.toFixed(p));
        }else if(type==='eq_b_ah'){
            var hConsistent=Math.sqrt(v0*Math.sqrt(3));
            if(Math.abs(hConsistent-v1)>0.001*v1){
                showError('Impossible combination','For an equilateral triangle, Area and Height are not independent. With Area = '+v0+', the height must be \u2248 '+hConsistent.toFixed(getPrec())+', not '+v1+'.');
                return;
            }
            var beq=(2*v0)/v1;
            res=beq;b=beq;s1=beq;s2=beq;h=v1;
            formula='b = (2 \u00d7 Area) / Height\n= (2 \u00d7 '+v0+') / '+v1+' = '+fmtS(res);
        }else if(type==='eq_a_heron'){
            var seq=v0;s1=seq;s2=seq;b=seq;
            var svEq=3*seq/2;
            res=Math.sqrt(svEq*(svEq-seq)*(svEq-seq)*(svEq-seq));
            area=res;h=Math.sqrt(3)/2*seq;
            formula="Heron's (equilateral): s = 3a/2 = "+svEq.toFixed(p)+'\nArea = \u221a(s(s\u2212a)\u00b3) = '+fmtS(res);
        }else if(type==='rt_c_ll'){
            s1=v0;b=v1;res=Math.sqrt(s1*s1+b*b);s2=res;h=s1;
            formula='c = \u221a(a\u00b2 + b\u00b2)\n= \u221a('+s1+'\u00b2 + '+b+'\u00b2)\n= \u221a'+(s1*s1+b*b)+' = '+fmtS(res);
        }else if(type==='rt_c_al'){
            var legA=v1;h=(2*v0)/legA;res=Math.sqrt(legA*legA+h*h);s1=h;b=legA;s2=res;
            formula='Other leg = (2A)/known = '+fmtS(h)+'\nc = \u221a('+legA+'\u00b2 + '+fmtS(h)+'\u00b2) = '+fmtS(res);
        }else if(type==='rt_l_cl'){
            var hyp=v0,oLeg=v1;
            if(oLeg>=hyp){showError('Impossible','Leg must be shorter than hypotenuse.');return;}
            res=Math.sqrt(hyp*hyp-oLeg*oLeg);s1=res;b=oLeg;s2=hyp;h=res;
            formula='Leg = \u221a(c\u00b2 \u2212 b\u00b2)\n= \u221a('+hyp+'\u00b2 \u2212 '+oLeg+'\u00b2)\n= \u221a'+(hyp*hyp-oLeg*oLeg)+' = '+fmtS(res);
        }else if(type==='rt_l_ac'){
            var hypR=v1;
            var inner3=hypR*hypR-4*v0;
            if(inner3<0){showError('Impossible','Area is too large for that hypotenuse.');return;}
            res=(Math.sqrt(hypR*hypR+4*v0)+Math.sqrt(inner3))/2;
            s1=res;h=res;
            b=(Math.sqrt(hypR*hypR+4*v0)-Math.sqrt(inner3))/2;
            s2=hypR;
            formula='Leg = (\u221a(c\u00b2+4A) + \u221a(c\u00b2\u22124A)) / 2\n= (\u221a'+(hypR*hypR+4*v0).toFixed(getPrec())+' + \u221a'+inner3.toFixed(getPrec())+') / 2\n= '+fmtS(res);
        }else if(type==='rt_h_ll'){
            s1=v0;b=v1;var hyp2=Math.sqrt(s1*s1+b*b);
            res=(s1*b)/hyp2;h=res;s2=hyp2;
            formula='Altitude = (a \u00d7 b) / c\n= ('+s1+' \u00d7 '+b+') / \u221a'+(s1*s1+b*b)+' = '+fmtS(res);
        }else if(type==='rt_h_ac'){
            var hypH=v1;res=(2*v0)/hypH;h=res;
            var sumAB=Math.sqrt(hypH*hypH+4*v0);
            var inner2=hypH*hypH-4*v0;
