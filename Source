    function ck_evaluate() {
        if(!ck_tokens.length) return;
        ck_clearCalcError();

        ck_insertPendingCloses();

        var s = ck_buildStrings();
        var evalStr = s.e.replace(/\u03c0/g, '(' + Math.PI + ')');

        try {
            var result = Function('"use strict"; return (' + evalStr + ')')();
            if(!isFinite(result)) { ck_showCalcError('Cannot divide by zero'); return; }
            if(isNaN(result))     { ck_showCalcError('Invalid expression'); return; }
            var rounded = parseFloat(result.toPrecision(12));
            ckExpr.innerText = s.d + ' =';
            ck_tokens = [{ e: String(rounded), d: String(rounded), kind: 'num' }];
            ck_justEvaled = true;
            ck_renderDisplay();
        } catch(err) {
            ck_showCalcError('Invalid expression');
        }
    }

    function ck_handleKey(k) {
        ck_clearCalcError();

        if(k === 'C') {
            ck_tokens = [];
            ck_justEvaled = false;
            ck_clearCalcError();
            ckExpr.innerText = '';
            ckDisplay.innerHTML = '<span>0</span>';
            return;
        }

        if(k === '\u232b') {
            if(ck_justEvaled) {
                ck_tokens = [];
                ck_justEvaled = false;
                ckExpr.innerText = '';
                ck_renderDisplay();
                return;
            }
            if(!ck_tokens.length) return;

            var last = ck_tokens[ck_tokens.length - 1];

            if(last.isAutoClose) {
                var closeId = last.autoCloseId;
                ck_tokens.pop();
                for(var i = ck_tokens.length - 1; i >= 0; i--) {
                    if(ck_tokens[i].kind === 'sqrt-open' && ck_tokens[i].autoCloseId === closeId) {
                        ck_tokens[i].closingDeleted = true;
                        break;
                    }
                }
                ck_renderDisplay();
                return;
            }

            if(last.kind === 'sqrt-open') {
                var openId = last.autoCloseId;
                var closeIdx = -1;
                for(var j = ck_tokens.length - 1; j >= 0; j--) {
                    if(ck_tokens[j].isAutoClose && ck_tokens[j].autoCloseId === openId) {
                        closeIdx = j; break;
                    }
                }
                if(closeIdx >= 0) {
                    ck_tokens.splice(closeIdx, 1);
                }
                ck_tokens.pop();
                ck_renderDisplay();
                return;
            }

            ck_tokens.pop();
            ck_renderDisplay();
            return;
        }

        if(k === '=') {
            ck_evaluate();
            return;
        }

        if(ck_justEvaled) {
            var isOp  = (k==='+' || k==='-' || k==='\u00d7' || k==='\u00f7');
            if(!isOp) {
                ck_tokens = [];
                ckExpr.innerText = '';
            }
            ck_justEvaled = false;
        }

        var isOperator = (k==='+' || k==='\u00d7' || k==='\u00f7');
        if(isOperator && ck_lastIsNum()) {
            ck_insertPendingCloses();
        }

        if(k === '(') {
            ck_tokens.push({ e:'(', d:'(', kind:'open' });

        } else if(k === ')') {
            if(ck_openDepth() > 0) {
                var innermostOpen = null;
                var innermostIdx = -1;
                var depthCheck = 0;
                for(var ci = 0; ci < ck_tokens.length; ci++) {
                    var ck = ck_tokens[ci].kind;
                    if(ck === 'open' || ck === 'sqrt-open') { depthCheck++; innermostOpen = ck_tokens[ci]; innermostIdx = ci; }
                    else if(ck === 'close') { depthCheck--; }
                }
                if(ck_inferBrackets && innermostOpen && innermostOpen.kind === 'sqrt-open' && !innermostOpen.closingDeleted) {
                    innermostOpen.closingDeleted = true;
                    ck_tokens.push({ e:')', d:')', kind:'close',
                        realizedFromId: innermostOpen.autoCloseId });
                } else {
                    ck_tokens.push({ e:')', d:')', kind:'close' });
                }
            }

        } else if(k === '+') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'+', d:'+', kind:'op' });
            }

        } else if(k === '-') {
            ck_tokens.push({ e:'-', d:'-', kind:'op' });

        } else if(k === '\u00d7') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }

        } else if(k === '\u00f7') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'/', d:'\u00f7', kind:'op' });
            }

        } else if(k === '\u221a') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            var id = ck_newId();
            ck_tokens.push({
                e: 'Math.sqrt(', d: '\u221a(',
                kind: 'sqrt-open',
                autoCloseId: id,
                closingDeleted: false
            });

        } else if(k === '\u03c0') {
            if(ck_lastIsNum()) {
                ck_tokens.push({ e:'*', d:'\u00d7', kind:'op' });
            }
            ck_tokens.push({ e:'\u03c0', d:'\u03c0', kind:'pi' });

        } else if(k === '.') {
            var lastNumTok = null;
            for(var ni = ck_tokens.length - 1; ni >= 0; ni--) {
                if(ck_tokens[ni].kind === 'num') { lastNumTok = ck_tokens[ni]; break; }
                if(ck_tokens[ni].kind !== 'num') break;
            }
            var lastTokIsNum = ck_lastKind() === 'num';
            if(lastTokIsNum && ck_tokens[ck_tokens.length-1].e.indexOf('.') < 0) {
                ck_tokens[ck_tokens.length-1].e += '.';
                ck_tokens[ck_tokens.length-1].d += '.';
            } else if(!lastTokIsNum) {
                ck_tokens.push({ e:'0.', d:'0.', kind:'num' });
            }

        } else {
            if(ck_lastKind() === 'num') {
                var nt = ck_tokens[ck_tokens.length-1];
                if(nt.e === '0') { nt.e = k; nt.d = k; }
                else { nt.e += k; nt.d += k; }
            } else {
                ck_tokens.push({ e: k, d: k, kind: 'num' });
            }
        }

        ck_renderDisplay();
    }

    document.querySelectorAll('.ck').forEach(function(btn){
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            ck_handleKey(this.getAttribute('data-k'));
