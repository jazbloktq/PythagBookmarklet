    // ── FIXED: renderUnitConverter ─────────────────────────────────────────────
    // Shows the unit conversion table for the current result value.
    // Uses lastCalcResult.resOut (value already in effOutUnit) and effOutUnit.
    // Falls back to lastCalcResult.res + workingUnit if effOutUnit is not set.
    function renderUnitConverter(rawValue) {
        var ub=get('unitBox'), ur=get('unitRows');
        if(!ub||!ur) return;

        // Determine which unit the displayed result is in
        var displayUnit = null;
        var displayVal  = rawValue;

        if(lastCalcResult) {
            // Prefer the already-converted output value and its unit
            if(lastCalcResult.effOutUnit && lastCalcResult.effOutUnit !== 'none') {
                displayUnit = lastCalcResult.effOutUnit;
                displayVal  = (lastCalcResult.resOut !== undefined) ? lastCalcResult.resOut : rawValue;
            } else if(lastCalcResult.workingUnit && lastCalcResult.workingUnit !== 'none') {
                // Fall back: result is in workingUnit
                displayUnit = lastCalcResult.workingUnit;
                displayVal  = (lastCalcResult.resOut !== undefined) ? lastCalcResult.resOut : rawValue;
            }
        }

        // Also honour the global input unit setting as a last resort
        if(!displayUnit && currentUnit !== 'none') {
            displayUnit = currentUnit;
        }

        var show = getShowUnits() && displayUnit && !isNaN(displayVal) && displayVal > 0;
        ub.style.display = show ? 'block' : 'none';
        if(!show) return;

        var baseFactor = unitFactors[displayUnit] || 1;
        var valueInMetres = displayVal / baseFactor;
        var d = getDark();
        var allUnits = ['mm','cm','m','km','in','ft'];
        ur.innerHTML = allUnits.map(function(u){
            var converted = valueInMetres * unitFactors[u];
            var disp;
            if(converted >= 1000000 || converted < 0.0001) disp = converted.toExponential(3);
            else if(converted >= 1000) disp = converted.toFixed(1);
            else disp = converted.toFixed(4).replace(/\.?0+$/, '');
            var isActive = (u === displayUnit);
            return '<div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid '+(d?'rgba(255,255,255,0.06)':'#eef')+'">'+
                '<span style="font-size:11px;color:'+(d?'#9090b0':'#666')+';">'+unitLabels[u]+'</span>'+
