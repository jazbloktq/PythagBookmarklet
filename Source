        lastCalcResult = {res:res,s1:drawS1,h:drawH,b:drawB,s2:drawS2,area:area,perim:perim,anglesForCanvas:anglesForCanvas,isExt:isExt,goal:currentGoal};
        drawTri(drawS1, drawH, drawB, drawS2, isExt, anglesForCanvas, currentGoal);

