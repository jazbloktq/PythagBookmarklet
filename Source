        var d=getDark();
        return 'border:1.5px solid '+(d?'#444466':'#e8e8e8')+';border-radius:7px;padding:8px 11px;cursor:pointer;font-size:12px;background:'+(d?'#2a2a3e':'#fff')+';color:'+(d?'#c0c0e0':'#555')+';text-align:left;font-weight:500;';
    }
    function mActiveStyle() {
        var d=getDark();
