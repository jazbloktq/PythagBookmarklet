    get('calc').onclick = function() {
        clearError();
        var config = options[currentGoal][currentMethod];
        var inputs = config.inputs;
        var vals = [];
        var missing = [];
        for (var i=0; i<inputs.length; i++) {
            var el = get('v'+i);
            var v = el ? parseFloat(el.value) : NaN;
            vals.push(v);
            if (isNaN(v) || el.value.trim() === '') missing.push(inputs[i]);
        }
        if (missing.length > 0) {
            showError('Missing values', 'Please fill in: ' + missing.join(', ') + '.');
            return;
        }
        for (var j=0; j<vals.length; j++) {
            if (vals[j] <= 0) {
                showError('Values must be positive', inputs[j] + ' must be greater than zero.');
                return;
            }
        }
        var v0=vals[0], v1=vals[1]!==undefined?vals[1]:NaN, v2=vals[2]!==undefined?vals[2]:NaN;
        var p = parseInt(get('prec').value) || 2;
        var posEl = document.querySelector('input[name="pos"]:checked');
        var isExt = posEl ? posEl.value === 'ext' : false;
        var type = config.id;
        var res, area, perim, formula, s1, h, b, s2;

        try {
            if (type === 'b_shs') {
                s1=v0; h=v1; s2=v2;
                if (h >= s1) { showError('Impossible triangle', 'Height (' + h + ') must be shorter than Side 1 (' + s1 + ').'); return; }
                if (h >= s2) { showError('Impossible triangle', 'Height (' + h + ') must be shorter than Side 2 (' + s2 + ').'); return; }
                var x=Math.sqrt(s1*s1-h*h), x2=Math.sqrt(s2*s2-h*h);
                res = isExt ? Math.abs(x-x2) : (x+x2); b=res;
                formula = 'Part1 = sqrt('+s1+'^2 - '+h+'^2) = '+x.toFixed(p)+'\nPart2 = sqrt('+s2+'^2 - '+h+'^2) = '+x2.toFixed(p)+'\nBase = '+x.toFixed(p)+' '+(isExt?'-':'+')+' '+x2.toFixed(p)+' = '+res.toFixed(p);
            } else if (type === 'b_ah') {
                if (v1 <= 0) { showError('Invalid height', 'Height must be greater than zero.'); return; }
                res = (2*v0)/v1; b=res; h=v1; s1=Math.sqrt(h*h+(b/2)*(b/2)); s2=s1;
                formula = 'Base = (2 x Area) / Height\n= (2 x '+v0+') / '+v1+' = '+res.toFixed(p);
            } else if (type === 'b_as') {
                h=Math.sqrt(v1*v1-(v0/v1)*(v0/v1)); res=(2*v0)/h; b=res; s1=v1; s2=v1;
                formula = 'Height estimated from slant + area\nBase = (2 x '+v0+') / h';
            } else if (type === 's_shb') {
                s1=v0; h=v1; b=v2;
                if (h >= s1) { showError('Impossible triangle', 'Height (' + h + ') must be shorter than the known side (' + s1 + ').'); return; }
                var xx=Math.sqrt(s1*s1-h*h), y=isExt?(b+xx):Math.abs(b-xx);
                res=Math.sqrt(y*y+h*h); s2=res;
                formula = 'Dist = sqrt('+s1+'^2 - '+h+'^2) = '+xx.toFixed(p)+'\nOther leg = '+(isExt?b+' + ':b+' - ')+xx.toFixed(p)+' = '+y.toFixed(p)+'\nSide = sqrt('+y.toFixed(p)+'^2 + '+h+'^2) = '+res.toFixed(p);
            } else if (type === 's_hb') {
                h=v0; b=v1; res=Math.sqrt(h*h+b*b); s1=res; s2=res;
                formula = 'Side = sqrt(h^2 + base^2)\n= sqrt('+h+'^2 + '+b+'^2) = '+res.toFixed(p);
            } else if (type === 's_ah') {
                res = Math.sqrt(v0*v0 + (v1/2)*(v1/2)); s1=res; s2=res; h=v0; b=v1;
                formula = 'Approx slant from area + height';
            } else if (type === 'h_pyth') {
                res=Math.sqrt(v0*v0+v1*v1);
                formula='Hypotenuse = sqrt(A^2 + B^2)\n= sqrt('+v0+'^2 + '+v1+'^2) = '+res.toFixed(p);
                s1=v0; s2=v1; b=res; h=(v0*v1)/res;
            } else if (type === 'h_ah') {
                var leg=v1; h=(2*v0)/leg; res=Math.sqrt(leg*leg+h*h);
                formula='Height = (2 x Area) / Leg = '+h.toFixed(p)+'\nHyp = sqrt('+leg+'^2 + h^2) = '+res.toFixed(p);
                s1=h; s2=leg; b=res; h=h;
            } else if (type === 'hg_side') {
                if (v1 >= v0) { showError('Impossible triangle', 'The base segment (' + v1 + ') must be shorter than the hypotenuse (' + v0 + ').'); return; }
                s1=v0; b=v1; res=Math.sqrt(v0*v0-v1*v1); h=res; s2=Math.sqrt(h*h+(b)*(b));
                formula='Height = sqrt(Hyp^2 - Seg^2)\n= sqrt('+v0+'^2 - '+v1+'^2) = '+res.toFixed(p);
            } else if (type === 'hg_ab') {
                res=(2*v0)/v1; h=res; b=v1; s1=Math.sqrt(h*h+(b/2)*(b/2)); s2=s1;
                formula='Height = (2 x Area) / Base\n= (2 x '+v0+') / '+v1+' = '+res.toFixed(p);
            } else if (type === 'hg_ss') {
                s1=v0; s2=v1; b=v2;
                if (b/2 >= s1) { showError('Impossible triangle', 'Base (' + b + ') is too wide for Side 1 (' + s1 + ').'); return; }
                var x1c=Math.sqrt(s1*s1-(b/2)*(b/2));
                res=x1c; h=res;
                formula='Height = sqrt(S1^2 - (Base/2)^2)\n= sqrt('+s1+'^2 - '+(b/2)+'^2) = '+res.toFixed(p);
            }
        } catch(e) {
            showError('Calculation error', 'Something went wrong. Double-check your values make a valid triangle.');
            return;
        }

        if (isNaN(res) || res <= 0 || !isFinite(res)) {
            showError('No solution found', 'These values don\'t form a valid triangle. Check that your inputs are geometrically possible.');
            return;
        }

        if (!s1) s1=res; if (!s2) s2=res; if (!b) b=res; if (!h) h=res;
        area=0.5*b*h; perim=s1+s2+b;
        get('res').style.display='block';
        get('final').innerText=res.toFixed(p);
        get('formulaText').innerText=formula;
        get('areaRes').innerText=area.toFixed(p);
        get('perimRes').innerText=perim.toFixed(p);
        drawTri(s1,h,b,s2,isExt);
        history.unshift(goals.filter(function(g){return g.id===currentGoal;})[0].label+': '+res.toFixed(p));
        if (history.length>5) history.pop();
        get('histList').innerHTML = history.map(function(h){ return '<span style="display:block;padding:3px 0;border-bottom:1px solid #f0f0f0;">'+h+'</span>'; }).join('');
        saveSettings();
    };

    get('copy').onclick = function() { navigator.clipboard.writeText(get('final').innerText); this.innerText='Copied!'; var self=this; setTimeout(function(){self.innerText='Copy';},1500); };
    get('dlBtn').onclick = function() { var link=document.createElement('a'); link.download='triangle.png'; link.href=canvas.toDataURL(); link.click(); };
    get('clear').onclick = function() { document.querySelectorAll('#inputStack input').forEach(function(i){i.value='';}); get('res').style.display='none'; ctx.clearRect(0,0,340,190); };
    get('close').onclick = function() { ui.remove(); };
    get('errClose').onclick = function() { clearError(); };
    // save prec on change
    document.addEventListener('change', function(e) { if (e.target && e.target.id === 'prec') saveSettings(); });

    buildGoalBtns();
    buildMethodBtns();
    renderInputs();
    // restore saved prec after DOM is built
    if (saved.prec) { var precEl = document.getElementById('prec'); if (precEl) precEl.value = saved.prec; }
    // restore saved method index safely
    var methodList = options[currentGoal];
    if (currentMethod >= methodList.length) currentMethod = 0;
})();
