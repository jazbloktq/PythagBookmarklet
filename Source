                if(!isNaN(sc)&&!isNaN(sC)&&!isNaN(sB)&&isNaN(sb)) sb=sc*Math.sin(sB*Math.PI/180)/Math.sin(sC*Math.PI/180);
                // Law of cosines (SAS → opposite side)
                if(!isNaN(sa)&&!isNaN(sb)&&!isNaN(sC)&&isNaN(sc)) sc=Math.sqrt(sa*sa+sb*sb-2*sa*sb*Math.cos(sC*Math.PI/180));
