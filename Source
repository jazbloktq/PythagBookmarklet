    // Ordered longest-first for reliable suffix matching
    var unitSuffixes=['mm','cm','km','in','ft','m'];

    // Detect explicit unit suffix from a raw string. Returns unit string or null.
    function detectUnitSuffix(raw) {
        var lraw = String(raw).trim().toLowerCase().replace(/\s+/g, '');
        for(var ui=0; ui<unitSuffixes.length; ui++) {
            if(lraw.endsWith(unitSuffixes[ui])) return unitSuffixes[ui];
        }
        return null;
    }

    // ── FIXED: inferWorkingUnit ────────────────────────────────────────────────
    // Rule: if currentUnit is set (not 'none'), always use it.
    // Otherwise: scan ALL non-angle inputs in order; the FIRST one with an explicit
    // unit suffix wins — that unit is adopted for ALL bare-number inputs.
    // Mixed units (e.g. '4cm' and '6in') → first explicit unit wins, second field
    // is converted from its detected unit into the working unit.
    // If no explicit units anywhere → working unit = 'none' (raw numbers).
    function inferWorkingUnit(rawStrs, angleFlags) {
        if(currentUnit !== 'none') return currentUnit;
        for(var i = 0; i < rawStrs.length; i++) {
            if(angleFlags[i]) continue;
            var u = detectUnitSuffix(rawStrs[i]);
            if(u) return u;
        }
        return 'none';
    }

    // Parse a single input value into working-unit scale.
    // If the field has an explicit unit, convert it → workingUnit.
    // If bare number, it's already in workingUnit scale.
    function parseInputValWithUnit(raw, angleField, workingUnit) {
        raw = String(raw).trim();
        if(raw === '') return NaN;
        if(angleField) return parseFloat(raw);
        var detectedUnit = detectUnitSuffix(raw);
        var lraw = raw.toLowerCase().replace(/\s+/g, '');
        var numStr = detectedUnit ? lraw.slice(0, lraw.length - detectedUnit.length) : lraw;
        var num = parseFloat(numStr);
        if(isNaN(num)) return NaN;
        if(detectedUnit === null) return num; // bare number: already in workingUnit scale
        if(workingUnit === 'none') return num; // no scale context: use raw number
        // Convert: detectedUnit → workingUnit via metres
        var fromFactor = unitFactors[detectedUnit] || 1;
        var toFactor   = unitFactors[workingUnit]  || 1;
        return num * (toFactor / fromFactor);
    }

    function parseInputVal(raw, angleField) {
        return parseInputValWithUnit(raw, angleField, currentUnit);
    }

