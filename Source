            lastCalcResult={res:allArea,s1:allS1d,h:allHd,b:allBd,s2:allS2d,area:allArea,perim:allPerim,anglesForCanvas:angFC2,isExt:false,goal:'all',workingUnit:workingUnit,resOut:allArea,effOutUnit:'none'};
            drawTri(allS1d,allHd,allBd,allS2d,false,angFC2,'all');
