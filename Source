    var svResults = get('svResults');

    var svFields = {
        right:       [{id:'sva',lbl:'Leg a'},{id:'svb',lbl:'Leg b'},{id:'svc',lbl:'Hypotenuse (c)'},{id:'svh',lbl:'Height (altitude)'},{id:'svA',lbl:'Angle A (°)',isAngle:true},{id:'svB',lbl:'Angle B (°)',isAngle:true}],
        scalene:     [{id:'sva',lbl:'Side a'},{id:'svb',lbl:'Side b'},{id:'svc',lbl:'Side c'},{id:'svh',lbl:'Height'},{id:'svA',lbl:'Angle A (°)',isAngle:true},{id:'svB',lbl:'Angle B (°)',isAngle:true},{id:'svC',lbl:'Angle C (°)',isAngle:true}],
        isosceles:   [{id:'sva',lbl:'Leg (equal side)'},{id:'svb',lbl:'Base'},{id:'svh',lbl:'Height'},{id:'svApex',lbl:'Apex angle (°)',isAngle:true},{id:'svBase',lbl:'Base angle (°)',isAngle:true}],
        equilateral: [{id:'sva',lbl:'Side'}]
    };

    function buildSvTriBtns() {
        var el = get('svTriBtns'); el.innerHTML='';
        var types=[{id:'right',lbl:'Right'},{id:'scalene',lbl:'Scalene'},{id:'isosceles',lbl:'Isosceles'},{id:'equilateral',lbl:'Equilateral'}];
        var d=getDark();
        types.forEach(function(t){
            var b=document.createElement('button');
            var active=t.id===svTriType;
            b.style.cssText=(active?'border:2px solid #1a73e8;background:'+(d?'#1e2e4e':'#e8f0fe')+';color:'+(d?'#4a9eff':'#1a73e8')+';font-weight:700;':'border:2px solid '+(d?'#444466':'#e0e0e0')+';background:'+(d?'#2a2a3e':'#fff')+';color:'+(d?'#c0c0e0':'#555')+';font-weight:600;')+'border-radius:7px;padding:7px 8px;cursor:pointer;font-size:12px;text-align:center;';
            b.innerText=t.lbl;
            b.onclick=function(e){e.stopPropagation();svTriType=t.id;buildSvTriBtns();buildSvInputs();get('svResults').style.display='none';};
            el.appendChild(b);
        });
    }

    function buildSvInputs() {
        var cont = get('svInputs'); cont.innerHTML='';
        var fields = svFields[svTriType]||[];
        var d=getDark();
        fields.forEach(function(f){
            var wrap=document.createElement('div');
            wrap.style.cssText='display:flex;align-items:center;gap:8px;';
            wrap.innerHTML='<label style="font-size:11px;font-weight:600;color:'+(d?'#9090b0':'#888')+';width:140px;flex-shrink:0;">'+f.lbl+'</label>'+
                '<input type="text" inputmode="decimal" id="'+f.id+'" placeholder="'+(f.isAngle?'e.g. 45':'e.g. 5')+'" style="flex:1;padding:7px 10px;border:1.5px solid '+(d?'#444466':'#ddd')+';border-radius:6px;font-size:13px;box-sizing:border-box;background:'+(d?'#2a2a3e':'#fff')+';color:'+(d?'#e0e0f0':'#222')+';">';
            cont.appendChild(wrap);
        });
    }

    function svGetVal(id) { var el=get(id); return el&&el.value.trim()!==''?parseFloat(el.value):NaN; }
    function svFmt(v) { return isNaN(v)?'?':v.toFixed(getPrec()); }
    function svRow(label, val, unit) {
        var d=getDark();
        return '<div style="display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid '+(d?'rgba(200,200,255,0.08)':'#e8effe')+';">'+
            '<span style="color:'+(d?'#9090b0':'#666')+';">'+label+'</span>'+
            '<span style="font-weight:700;color:'+(d?'#e0e8ff':'#222')+';">'+(isNaN(val)?'—':val.toFixed(getPrec()))+(unit||'')+'</span>'+
            '</div>';
    }
    function svBadge(txt, col, bg) {
        return '<div style="display:inline-block;padding:3px 9px;border-radius:10px;font-size:11px;font-weight:700;color:'+col+';background:'+bg+';margin-top:6px;">'+txt+'</div>';
    }

    function doSolve() {
        get('svResults').style.display='none';
        var d=getDark();
        var html='', warn='';
        try {
        if(svTriType==='right') {
            var a=svGetVal('sva'), b=svGetVal('svb'), c=svGetVal('svc');
            var h=svGetVal('svh'), angA=svGetVal('svA'), angB=svGetVal('svB');
            // Derive from known combos
            if(!isNaN(a)&&!isNaN(b)) { c=Math.sqrt(a*a+b*b); h=a*b/c; angA=Math.atan2(a,b)*180/Math.PI; angB=90-angA; }
            else if(!isNaN(a)&&!isNaN(c)) { if(a>=c){warn='Leg must be shorter than hypotenuse.';} else {b=Math.sqrt(c*c-a*a);h=a*b/c;angA=Math.asin(a/c)*180/Math.PI;angB=90-angA;} }
            else if(!isNaN(b)&&!isNaN(c)) { if(b>=c){warn='Leg must be shorter than hypotenuse.';} else {a=Math.sqrt(c*c-b*b);h=a*b/c;angA=Math.asin(a/c)*180/Math.PI;angB=90-angA;} }
            else if(!isNaN(a)&&!isNaN(angA)) { angA=Math.min(89.9,Math.max(0.1,angA));b=a/Math.tan(angA*Math.PI/180);c=a/Math.sin(angA*Math.PI/180);h=a*b/c;angB=90-angA; }
            else if(!isNaN(a)&&!isNaN(angB)) { angB=Math.min(89.9,Math.max(0.1,angB));angA=90-angB;b=a/Math.tan(angA*Math.PI/180);c=a/Math.sin(angA*Math.PI/180);h=a*b/c; }
            else if(!isNaN(b)&&!isNaN(angA)) { angA=Math.min(89.9,Math.max(0.1,angA));a=b*Math.tan(angA*Math.PI/180);c=b/Math.cos(angA*Math.PI/180);h=a*b/c;angB=90-angA; }
            else if(!isNaN(c)&&!isNaN(angA)) { angA=Math.min(89.9,Math.max(0.1,angA));a=c*Math.sin(angA*Math.PI/180);b=c*Math.cos(angA*Math.PI/180);h=a*b/c;angB=90-angA; }
            else if(!isNaN(h)&&!isNaN(a)) { b=a*a/h; /* h=ab/c, if we know h and a... need more info */ b=NaN; warn='Not enough info — try leg a + leg b, or a side + angle.'; }
            else { warn='Please enter at least 2 known values (e.g. both legs, or leg + angle).'; }
            if(!warn && (isNaN(a)||isNaN(b)||isNaN(c))) { warn='Could not solve — check your inputs.'; }
            if(!warn) {
                var perim=a+b+c, area=0.5*a*b;
                var td=checkTripleDetail(a,b,c);
                html+=svRow('Leg a', a);
                html+=svRow('Leg b', b);
                html+=svRow('Hypotenuse c', c);
                html+=svRow('Height (altitude)', h);
                html+=svRow('Angle A', angA, '°');
                html+=svRow('Angle B', angB, '°');
                html+=svRow('Angle C', 90, '°');
                html+=svRow('Area', area);
                html+=svRow('Perimeter', perim);
                if(td.isTriple) html+=svBadge('★ Pythagorean triple: '+td.pa+'-'+td.pb+'-'+td.pc+(td.isPrimitive?'':' ×'+td.scale),'#2a7a2a',d?'#1a2e1a':'#e8f8e8');
                else html+=svBadge('Not a Pythagorean triple', d?'#9090b0':'#888', d?'#2a2a3e':'#f0f0f0');
            }
        } else if(svTriType==='scalene') {
            var sa=svGetVal('sva'), sb=svGetVal('svb'), sc2=svGetVal('svc');
            var sA=svGetVal('svA'), sB=svGetVal('svB'), sC=svGetVal('svC');
            var sh=svGetVal('svh');
            // Convert angles to radians for computation
            var rA=sA*Math.PI/180, rB=sB*Math.PI/180, rC=sC*Math.PI/180;
            // Fill in missing angle
            var knownAngs=[!isNaN(sA),!isNaN(sB),!isNaN(sC)].filter(Boolean).length;
            if(knownAngs===2&&isNaN(sC)) { sC=180-sA-sB; rC=sC*Math.PI/180; }
            else if(knownAngs===2&&isNaN(sB)) { sB=180-sA-sC; rB=sB*Math.PI/180; }
            else if(knownAngs===2&&isNaN(sA)) { sA=180-sB-sC; rA=sA*Math.PI/180; }
            // SSS
            if(!isNaN(sa)&&!isNaN(sb)&&!isNaN(sc2)) {
                if(sa+sb<=sc2||sa+sc2<=sb||sb+sc2<=sa){warn='These sides don\'t form a valid triangle.';}
                else{rA=Math.acos((sb*sb+sc2*sc2-sa*sa)/(2*sb*sc2));rB=Math.acos((sa*sa+sc2*sc2-sb*sb)/(2*sa*sc2));rC=Math.PI-rA-rB;sA=rA*180/Math.PI;sB=rB*180/Math.PI;sC=rC*180/Math.PI;}
            }
            // AAS / ASA
            else if(!isNaN(sa)&&!isNaN(sA)&&!isNaN(sB)) { rA=sA*Math.PI/180;rB=sB*Math.PI/180;rC=Math.PI-rA-rB;sC=180-sA-sB;sb=sa*Math.sin(rB)/Math.sin(rA);sc2=sa*Math.sin(rC)/Math.sin(rA); }
            else if(!isNaN(sb)&&!isNaN(sA)&&!isNaN(sB)) { rA=sA*Math.PI/180;rB=sB*Math.PI/180;rC=Math.PI-rA-rB;sC=180-sA-sB;sa=sb*Math.sin(rA)/Math.sin(rB);sc2=sb*Math.sin(rC)/Math.sin(rB); }
            // SAS
            else if(!isNaN(sa)&&!isNaN(sb)&&!isNaN(sC)) { rC=sC*Math.PI/180;sc2=Math.sqrt(sa*sa+sb*sb-2*sa*sb*Math.cos(rC));rA=Math.acos((sb*sb+sc2*sc2-sa*sa)/(2*sb*sc2));rB=Math.PI-rA-rC;sA=rA*180/Math.PI;sB=rB*180/Math.PI; }
            else if(!isNaN(sa)&&!isNaN(sc2)&&!isNaN(sB)) { rB=sB*Math.PI/180;sb=Math.sqrt(sa*sa+sc2*sc2-2*sa*sc2*Math.cos(rB));rA=Math.acos((sb*sb+sc2*sc2-sa*sa)/(2*sb*sc2));rC=Math.PI-rA-rB;sA=rA*180/Math.PI;sC=rC*180/Math.PI; }
            else if(!isNaN(sb)&&!isNaN(sc2)&&!isNaN(sA)) { rA=sA*Math.PI/180;sa=Math.sqrt(sb*sb+sc2*sc2-2*sb*sc2*Math.cos(rA));rB=Math.acos((sa*sa+sc2*sc2-sb*sb)/(2*sa*sc2));rC=Math.PI-rA-rB;sB=rB*180/Math.PI;sC=rC*180/Math.PI; }
            else { warn='Enter at least 3 values (e.g. SSS, SAS, AAS).'; }
            if(!warn) {
                if(isNaN(sa)||isNaN(sb)||isNaN(sc2)){warn='Could not solve — check your inputs.';}
                else {
                    var sv2=(sa+sb+sc2)/2, areaS=Math.sqrt(sv2*(sv2-sa)*(sv2-sb)*(sv2-sc2));
                    var htS=isNaN(sh)?(2*areaS)/sc2:sh;
                    html+=svRow('Side a', sa); html+=svRow('Side b', sb); html+=svRow('Side c', sc2);
                    html+=svRow('Height (to c)', htS); html+=svRow('Angle A', sA,'°'); html+=svRow('Angle B', sB,'°'); html+=svRow('Angle C', sC,'°');
                    html+=svRow('Area', areaS); html+=svRow('Perimeter', sa+sb+sc2);
                    html+=svBadge(classifyTriangle(sa,sb,sc2)+' triangle','#1a73e8',d?'#1e2e4e':'#e8f0fe');
                }
            }
        } else if(svTriType==='isosceles') {
            var ia=svGetVal('sva'), ib=svGetVal('svb'), ih=svGetVal('svh');
            var iApex=svGetVal('svApex'), iBase=svGetVal('svBase');
            if(!isNaN(ia)&&!isNaN(ib)) { ih=Math.sqrt(ia*ia-(ib/2)*(ib/2)); iApex=2*Math.asin(ib/(2*ia))*180/Math.PI; iBase=(180-iApex)/2; }
            else if(!isNaN(ia)&&!isNaN(ih)) { ib=2*Math.sqrt(ia*ia-ih*ih); iApex=2*Math.asin(ib/(2*ia))*180/Math.PI; iBase=(180-iApex)/2; }
            else if(!isNaN(ia)&&!isNaN(iApex)) { ih=ia*Math.cos(iApex/2*Math.PI/180); ib=2*ia*Math.sin(iApex/2*Math.PI/180); iBase=(180-iApex)/2; }
            else if(!isNaN(ia)&&!isNaN(iBase)) { iApex=180-2*iBase; ih=ia*Math.cos(iApex/2*Math.PI/180); ib=2*ia*Math.sin(iApex/2*Math.PI/180); }
            else if(!isNaN(ib)&&!isNaN(ih)) { ia=Math.sqrt(ih*ih+(ib/2)*(ib/2)); iApex=2*Math.asin(ib/(2*ia))*180/Math.PI; iBase=(180-iApex)/2; }
            else if(!isNaN(ib)&&!isNaN(iApex)) { ia=ib/(2*Math.sin(iApex/2*Math.PI/180)); ih=ia*Math.cos(iApex/2*Math.PI/180); iBase=(180-iApex)/2; }
            else { warn='Enter at least 2 known values.'; }
            if(!warn) {
                if(isNaN(ia)||isNaN(ib)||isNaN(ih)){warn='Could not solve — check inputs.';}
                else {
                    var iPerim=2*ia+ib, iArea=0.5*ib*ih;
                    html+=svRow('Leg (equal side)', ia); html+=svRow('Base', ib); html+=svRow('Height', ih);
                    html+=svRow('Apex angle', iApex,'°'); html+=svRow('Base angle', iBase,'°'); html+=svRow('Area', iArea); html+=svRow('Perimeter', iPerim);
                }
            }
        } else if(svTriType==='equilateral') {
            var ea=svGetVal('sva');
            if(isNaN(ea)){warn='Enter the side length.';}
            else {
                var eh=Math.sqrt(3)/2*ea, eArea=Math.sqrt(3)/4*ea*ea, ePerim=3*ea;
                var eInR=ea/(2*Math.sqrt(3)), eCircR=ea/Math.sqrt(3);
                html+=svRow('Side', ea); html+=svRow('Height', eh); html+=svRow('Area', eArea); html+=svRow('Perimeter', ePerim);
                html+=svRow('All angles', 60,'°'); html+=svRow('Inradius', eInR); html+=svRow('Circumradius', eCircR);
            }
        }
        } catch(err) { warn='Calculation error: '+err.message; }
        var rd=get('svResults');
        rd.style.display='block';
        if(warn) {
            rd.innerHTML='<div style="color:#c0392b;font-weight:600;font-size:12px;">⚠ '+warn+'</div>';
        } else {
            rd.innerHTML='<div style="font-size:10px;font-weight:700;color:#1a73e8;letter-spacing:0.5px;margin-bottom:8px;">RESULTS</div>'+html;
        }
    }

    get('svCalcBtn').addEventListener('click', function(e){e.stopPropagation();doSolve();});
    get('svResults').addEventListener('click',function(e){e.stopPropagation();});

    get('solverBtn').addEventListener('click', function(e) {
        e.stopPropagation();
        var m=get('solverMenu');
        var isOpen=m.style.display!=='none';
        m.style.display=isOpen?'none':'block';
        get('histMenu').style.display='none';
        get('setMenu').style.display='none';
        get('miniCalc').style.display='none';
        if(!isOpen){buildSvTriBtns();buildSvInputs();get('svResults').style.display='none';}
    });
    get('closeSolver').addEventListener('click',function(e){e.stopPropagation();get('solverMenu').style.display='none';});
    get('solverMenu').addEventListener('click',function(e){e.stopPropagation();});

    buildSvTriBtns(); buildSvInputs();

    get('setMenu').style.display = 'none';
    get('histMenu').style.display = 'none';
    get('miniCalc').style.display = 'none';
    get('calcSettingsPanel').style.display = 'none';
})();
