            res=Math.sqrt(s1*s1-(b/2)*(b/2));h=res;
            formula='Height = \u221a(S1\u00b2 \u2212 (Base/2)\u00b2)\n= \u221a('+s1+'\u00b2 \u2212 '+(b/2)+'\u00b2) = '+fmtS(res);
        }else if(type==='sc_a_heron'||type==='is_a_heron'){
