    // ── drawCirclesOnDiag: draw incircle + circumcircle on canvas ────────────
    function drawCirclesOnDiag(s1,h,b,s2,inR,circumR){
        if(!canvas||!ctx) return;
        var d=getDark();
        var raw;
        if(currentTri==='equilateral'||currentTri==='isosceles') raw=[[0,h],[b/2,0],[b,h]];
        else if(currentTri==='right') raw=[[0,h],[0,0],[b,h]];
        else { var ax2=Math.sqrt(Math.max(0,s1*s1-h*h)); raw=[[0,h],[ax2,0],[b,h]]; }
        var W=canvas.width,H=canvas.height;
        var padT=38,padB=52,padL=52,padR=52;
        var minX=raw[0][0],maxX=raw[0][0];
        for(var i=1;i<3;i++){if(raw[i][0]<minX)minX=raw[i][0];if(raw[i][0]>maxX)maxX=raw[i][0];}
        var rangeX=maxX-minX||1,rangeY=h||1;
        var scale2=Math.min((W-padL-padR)/rangeX,(H-padT-padB)/rangeY);
        var offX2=(W-rangeX*scale2)/2-minX*scale2,offY2=padT+(H-padT-padB-rangeY*scale2)/2;
        function tr2(pt){return[pt[0]*scale2+offX2,pt[1]*scale2+offY2];}
        var pA2=tr2(raw[0]),pB2=tr2(raw[1]),pC2=tr2(raw[2]);

        // Incircle center: weighted average of vertices by opposite side lengths
        var aa2=Math.sqrt((pB2[0]-pC2[0])*(pB2[0]-pC2[0])+(pB2[1]-pC2[1])*(pB2[1]-pC2[1]));
        var bb2=Math.sqrt((pA2[0]-pC2[0])*(pA2[0]-pC2[0])+(pA2[1]-pC2[1])*(pA2[1]-pC2[1]));
        var cc2=Math.sqrt((pA2[0]-pB2[0])*(pA2[0]-pB2[0])+(pA2[1]-pB2[1])*(pA2[1]-pB2[1]));
        var perim2=aa2+bb2+cc2;
        var ix=(aa2*pA2[0]+bb2*pB2[0]+cc2*pC2[0])/perim2;
        var iy=(aa2*pA2[1]+bb2*pB2[1]+cc2*pC2[1])/perim2;
        var inRpx=inR*scale2;

        // Circumcircle center: circumscribed circle passes through all three vertices
        var ax3=pA2[0],ay3=pA2[1],bx3=pB2[0],by3=pB2[1],cx3=pC2[0],cy3=pC2[1];
        var D=2*(ax3*(by3-cy3)+bx3*(cy3-ay3)+cx3*(ay3-by3));
        var ux=((ax3*ax3+ay3*ay3)*(by3-cy3)+(bx3*bx3+by3*by3)*(cy3-ay3)+(cx3*cx3+cy3*cy3)*(ay3-by3))/D;
        var uy=((ax3*ax3+ay3*ay3)*(cx3-bx3)+(bx3*bx3+by3*by3)*(ax3-cx3)+(cx3*cx3+cy3*cy3)*(bx3-ax3))/D;
        var circumRpx=circumR*scale2;

        // Draw circumcircle (purple, dashed)
        ctx.save();
        ctx.setLineDash([6,4]);
        ctx.beginPath();
        ctx.arc(ux,uy,circumRpx,0,2*Math.PI);
        ctx.strokeStyle=d?'#c084fc':'#9333ea';
        ctx.lineWidth=1.5;
        ctx.stroke();
        // Label R
        ctx.font='bold 9px system-ui';
        ctx.fillStyle=d?'#c084fc':'#9333ea';
        ctx.textAlign='left';
        ctx.fillText('R='+circumR.toFixed(2),ux+circumRpx*0.7,uy-circumRpx*0.7);

        // Draw incircle (green, dashed)
        ctx.beginPath();
        ctx.arc(ix,iy,inRpx,0,2*Math.PI);
        ctx.strokeStyle=d?'#4ade80':'#16a34a';
        ctx.lineWidth=1.5;
        ctx.stroke();
        // Label r
        ctx.fillStyle=d?'#4ade80':'#16a34a';
        ctx.textAlign='center';
        ctx.fillText('r='+inR.toFixed(2),ix,iy);
        ctx.setLineDash([]);
        ctx.restore();
    }

        function doCalculate(silent) {
        if(!silent) clearError();
        var list=getMethodList();
        if(!list.length){if(!silent)showError('Not available','No formula for this combination.');return;}
        var cfg=list[Math.min(currentMethod,list.length-1)];

        // ── Step 1: collect raw strings and angle flags ────────────────────────
        var rawStrs=[], angleFls=[];
        cfg.inputs.forEach(function(lbl,i){
            var el=get('v'+i);
            rawStrs.push(el?el.value.trim():'');
            angleFls.push(isAngleLbl(lbl));
        });

        // ── Step 2: infer the working unit (first-input-wins when no global unit)
        var workingUnit = inferWorkingUnit(rawStrs, angleFls);

        // ── Step 3: parse and validate ─────────────────────────────────────────
        var vals=[], missing=[];
        cfg.inputs.forEach(function(lbl,i){
            var el=get('v'+i);
            var rawStr=rawStrs[i];
            var isAng=angleFls[i];
            var v=parseInputValWithUnit(rawStr, isAng, workingUnit);
            vals.push(v);
            if(el) updateInputUnitBadge(el, rawStr, workingUnit);
            if(isNaN(v)||rawStr==='') missing.push(lbl);
        });
        if(missing.length){if(!silent)showError('Missing values','Please fill in: '+missing.join(', ')+'.');return;}
        for(var j=0;j<vals.length;j++){
            if(isAngleLbl(cfg.inputs[j])){
                if(vals[j]<=0||vals[j]>=180){if(!silent)showError('Invalid angle',cfg.inputs[j]+' must be between 0\u00b0 and 180\u00b0.');return;}
            } else {
                if(vals[j]<=0){if(!silent)showError('Values must be positive',cfg.inputs[j]+' must be greater than zero.');return;}
            }
        }

        var v0=vals[0],v1=vals.length>1?vals[1]:NaN,v2=vals.length>2?vals[2]:NaN;
        var p=getPrec(),useSurd=getSurd();
        var posEl=ui.querySelector('input[name="geopro_pos"]:checked');
        var isExt=posEl?posEl.value==='ext':false;
        var type=cfg.id;
        var res,area,perim,formula,s1,h,b,s2;

        // ── SOLVE ALL GOAL ─────────────────────────────────────────────────────
        if(currentGoal==='all') {
            var allA,allB,allC,allS1,allS2,allBase,allH,allArea,allPerim,allAngA,allAngB,allAngC,allErr='';
            try {
            if(currentTri==='right') {
                // rt_all_ll: Leg a, Leg b
                // rt_all_cl: Hypotenuse, Leg a
                // rt_all_la: Leg a, Angle A
                if(type==='rt_all_ll') { allS1=v0; allBase=v1; allS2=Math.sqrt(allS1*allS1+allBase*allBase); }
                else if(type==='rt_all_cl') { allS2=v0; allS1=v1; if(allS1>=allS2){allErr='Leg must be less than hypotenuse.';} else{allBase=Math.sqrt(allS2*allS2-allS1*allS1);} }
                else if(type==='rt_all_la') { allS1=v0; var allAngAr=toRad(v1); allBase=allS1/Math.tan(allAngAr); allS2=allS1/Math.sin(allAngAr); }
                if(!allErr){
                    allH=allS1*allBase/allS2;
                    allArea=0.5*allS1*allBase;
                    allPerim=allS1+allBase+allS2;
                    allAngA=Math.atan2(allS1,allBase)*180/Math.PI;
                    allAngB=90-allAngA;
                    allAngC=90;
                }
            } else if(currentTri==='equilateral') {
                allS1=v0; allS2=v0; allBase=v0;
                allH=Math.sqrt(3)/2*v0;
                allArea=Math.sqrt(3)/4*v0*v0;
                allPerim=3*v0;
                allAngA=60; allAngB=60; allAngC=60;
            } else if(currentTri==='isosceles') {
                if(type==='is_all_lb') { allS1=v0; allBase=v1; allH=Math.sqrt(allS1*allS1-(allBase/2)*(allBase/2)); }
                else if(type==='is_all_lh') { allS1=v0; allH=v1; allBase=2*Math.sqrt(allS1*allS1-allH*allH); }
                else if(type==='is_all_la') { allS1=v0; var apexR=toRad(v1); allBase=2*allS1*Math.sin(apexR/2); allH=allS1*Math.cos(apexR/2); }
                else if(type==='is_all_ba') { allBase=v0; var baseAr=toRad(v1); allS1=allBase/(2*Math.cos(baseAr)); allH=allS1*Math.sin(baseAr); }
                if(!allErr){
                    allS2=allS1;
                    allArea=0.5*allBase*allH;
                    allPerim=2*allS1+allBase;
                    var apexFull=2*Math.asin(allBase/(2*allS1))*180/Math.PI;
                    allAngA=apexFull; allAngB=(180-apexFull)/2; allAngC=allAngB;
                }
            } else { // scalene
                if(type==='sc_all_sss') { allS1=v0; allS2=v1; allBase=v2; if(allS1+allS2<=allBase||allS1+allBase<=allS2||allS2+allBase<=allS1){allErr='These sides don\'t form a valid triangle.';} }
                else if(type==='sc_all_aas') { var aasA2=toRad(v0),aasB2=toRad(v1),aasC2=Math.PI-aasA2-aasB2; if(aasC2<=0){allErr='Angles must sum to < 180°.';} else{ allS1=v2; allS2=allS1*Math.sin(aasB2)/Math.sin(aasA2); allBase=allS1*Math.sin(aasC2)/Math.sin(aasA2); } }
                else if(type==='sc_all_sas') { allS1=v0; var angC3=toRad(v1); allS2=v2; allBase=Math.sqrt(allS1*allS1+allS2*allS2-2*allS1*allS2*Math.cos(angC3)); }
                if(!allErr){
                    var sv3=(allS1+allS2+allBase)/2;
                    allArea=Math.sqrt(sv3*(sv3-allS1)*(sv3-allS2)*(sv3-allBase));
                    allH=(2*allArea)/allBase;
                    allPerim=allS1+allS2+allBase;
                    var cosA3=(allS2*allS2+allBase*allBase-allS1*allS1)/(2*allS2*allBase);
                    var cosB3=(allS1*allS1+allBase*allBase-allS2*allS2)/(2*allS1*allBase);
                    allAngA=Math.acos(Math.max(-1,Math.min(1,cosA3)))*180/Math.PI;
                    allAngB=Math.acos(Math.max(-1,Math.min(1,cosB3)))*180/Math.PI;
                    allAngC=180-allAngA-allAngB;
                }
            }
            } catch(e2) { allErr='Calculation error.'; }
            if(allErr){if(!silent)showError('Cannot solve',allErr);return;}
            // Display full results panel
            var d2a=getDark();
            get('res').style.display='block';
            get('final').style.display='none';
            get('finalApprox').style.display='none';
            var existingAllDisp=get('allResultDisp'); if(existingAllDisp) existingAllDisp.remove();
            var existingAngleDisp=get('angleResultDisp'); if(existingAngleDisp) existingAngleDisp.remove();
            var existingCircDisp=get('circleResultDisp'); if(existingCircDisp) existingCircDisp.remove();
            var allDisp=document.createElement('div'); allDisp.id='allResultDisp';
            var bdrC=d2a?'rgba(200,200,255,0.08)':'#e8effe';
            function allRow(lbl,val,unit){return '<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid '+bdrC+'"><span style="font-size:12px;color:'+(d2a?'#9090b0':'#666')+';">'+lbl+'</span><span style="font-size:13px;font-weight:700;color:'+(d2a?'#e0e8ff':'#222')+';">'+val+(unit||'')+'</span></div>';}
            var html2='';
