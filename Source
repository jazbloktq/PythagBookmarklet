                formulaLines.push('');
                formulaLines.push('Step 3 \u2014 Find primitive triple (divide by GCD):');
                var g=td.scale;
                formulaLines.push('  GCD('+td.Ar+', '+td.Br+', '+td.Cr+') = '+g);
                formulaLines.push('  Primitive: ('+td.Ar+'/'+g+', '+td.Br+'/'+g+', '+td.Cr+'/'+g+') = ('+td.pa+', '+td.pb+', '+td.pc+')');
                formulaLines.push('  Check: '+td.pa+'\u00b2+'+td.pb+'\u00b2 = '+(td.pa*td.pa+td.pb*td.pb)+' = '+td.pc+'\u00b2 \u2713');
                formulaLines.push('');
                if(td.isPrimitive){
