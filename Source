    var historyIndex=-1;
    function restoreEntry(entry){
        if(!entry||!entry.tri) return;
        currentTri=entry.tri;currentGoal=entry.goal;currentMethod=entry.method;
        buildTriBtns();buildGoalBtns();buildMethodBtns();renderInputs();
        entry.inputs.forEach(function(val,i){var el=get('v'+i);if(el)el.value=val;});
        if(entry.isExt){var r=ui.querySelector('input[name="geopro_pos"][value="ext"]');if(r)r.checked=true;}
        get('final').innerText=entry.finalText;
        var ae=get('finalApprox');ae.innerText=entry.approxText;ae.style.display=entry.approxVis;
        get('formulaText').innerText=entry.formula;
        get('areaRes').innerText=entry.area;get('perimRes').innerText=entry.perim;
        get('res').style.display='block';
        drawTri(entry.ds1,entry.dh,entry.db,entry.ds2,entry.isExt,entry.anglesForCanvas);
        applyDark();
        applyDiagramVisibility();
        applyResultVisibility();
    }
    document.addEventListener('keydown',function(e){
        if(get('miniCalc').style.display!=='none') return;
        var key=e.key||e.keyCode, active=document.activeElement;
        if(active&&!ui.contains(active)&&active!==document.body) return;
        if(active&&active.type==='number'&&(key==='ArrowLeft'||key===37||key==='ArrowRight'||key===39)) return;
        if(key==='ArrowLeft'||key===37){
            if(!history.length) return;
            e.preventDefault();e.stopPropagation();
            historyIndex=Math.min(historyIndex+1,history.length-1);
            restoreEntry(history[historyIndex]);
        } else if(key==='ArrowRight'||key===39){
            if(historyIndex<=0){historyIndex=-1;return;}
            e.preventDefault();e.stopPropagation();
            historyIndex--;restoreEntry(history[historyIndex]);
        }
    },true);

    if(triGoals[currentTri].indexOf(currentGoal)<0) currentGoal=triGoals[currentTri][0];
    var mLen=(methods[currentTri]&&methods[currentTri][currentGoal]?methods[currentTri][currentGoal].length:0);
    if(currentMethod>=mLen) currentMethod=0;
    buildTriBtns();buildGoalBtns();buildMethodBtns();renderInputs();
    if(initDark) { ui.classList.add('geo-dark'); applyDark(); }
    applyDiagramVisibility();
    applyResultVisibility();
})();
